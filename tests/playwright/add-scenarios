#!/usr/bin/env node
/**
 * Crawl a URL and append up to N internal links as scenarios (label + relative url).
 * Usage: ./create-scenarios <base-url> <amount>
 */
const fs = require('fs');
const path = require('path');
const { chromium } = require('@playwright/test');

const [inputUrl, amountArg] = process.argv.slice(2);
const amount = Number.parseInt(amountArg, 10) || 0;

if (!inputUrl || !amount) {
  console.error('Usage: ./create-scenarios <base-url> <amount>');
  process.exit(1);
}

const scenariosPath = path.join(__dirname, 'scenarios.json');

const readConfig = () => JSON.parse(fs.readFileSync(scenariosPath, 'utf-8'));

const writeConfig = config => {
  fs.writeFileSync(scenariosPath, JSON.stringify(config, null, 2) + '\n');
};

const normalizeLink = (href, origin) => {
  try {
    if (!href || href.startsWith('#')) return null;
    if (href.startsWith('mailto:') || href.startsWith('tel:') || href.startsWith('javascript:')) return null;

    const urlObj = new URL(href, origin);
    if (urlObj.origin !== origin) return null; // external
    return urlObj.pathname + urlObj.search;
  } catch {
    return null;
  }
};

const trimToLength = (str, max) => {
  if (!str) return '';
  const trimmed = str.trim();
  return trimmed.length > max ? trimmed.slice(0, max).trimEnd() : trimmed;
};

const buildBaseLabel = (text, relUrl) => {
  const clean = trimToLength(text.replace(/\s+/g, ' '), 15);
  if (clean) return clean;
  const parts = relUrl.split('/').filter(Boolean);
  const fallback = parts.length ? parts[parts.length - 1].replace(/[-_]/g, ' ') : relUrl || 'Unnamed';
  return trimToLength(fallback, 15) || 'Unnamed';
};

const makeUniqueLabel = (base, existing) => {
  let candidate = base || 'Unnamed';
  let counter = 2;
  while (existing.has(candidate)) {
    const suffix = ` ${counter}`;
    const allowed = Math.max(1, 15 - suffix.length);
    const prefix = trimToLength(base, allowed) || 'Unnamed';
    candidate = `${prefix}${suffix}`;
    counter += 1;
  }
  existing.add(candidate);
  return candidate;
};

const collectLinks = async (page, origin, existingLabels) => {
  const links = await page.$$eval('a[href]', (anchors, originParam) => {
    return anchors.map(a => ({
      href: a.getAttribute('href') || '',
      text: a.innerText || ''
    }));
  }, origin);

  const seen = new Set();
  const result = [];

  for (const link of links) {
    const rel = normalizeLink(link.href, origin);
    if (!rel || seen.has(rel)) continue;
    seen.add(rel);
    const baseLabel = buildBaseLabel(link.text, rel);
    const label = makeUniqueLabel(baseLabel, existingLabels);
    result.push({ url: rel, label });
  }

  return result;
};

(async () => {
  const baseOrigin = new URL(inputUrl).origin;
  const browser = await chromium.launch({ headless: true });
  const page = await browser.newPage();
  await page.goto(inputUrl, { waitUntil: 'networkidle' });

  const config = readConfig();
  config.scenarios = config.scenarios || [];
  const existingUrls = new Set(config.scenarios.map(s => s.url));
  const existingLabels = new Set(config.scenarios.map(s => s.label));

  const discovered = await collectLinks(page, baseOrigin, existingLabels);
  await browser.close();

  if (!discovered.length) {
    console.error('No internal links found.');
    process.exit(1);
  }

  const toAdd = [];
  for (const entry of discovered) {
    if (existingUrls.has(entry.url)) continue;
    toAdd.push({ label: entry.label, url: entry.url });
    if (toAdd.length >= amount) break;
  }

  if (!toAdd.length) {
    console.log('No new scenarios to add (all links already present).');
    process.exit(0);
  }

  config.scenarios.push(...toAdd);
  writeConfig(config);

  console.log(`Added ${toAdd.length} scenario(s)`);
  // display all links added
  // for (const s of toAdd) {
  //   console.log(`- ${s.label}: ${s.url}`);
  // }
})().catch(err => {
  console.error(err);
  process.exit(1);
});

+  /**
+   * Purge notifications older than the configured threshold.
+   */
+  public function purgeOldNotificationsIfNeeded(): void {
+    $days = (int) ($this->config->get('purge_days_old') ?? 0);
+    if ($days <= 0) {
+      return;
+    }
+
+    $cutoff = $this->time->getRequestTime() - ($days * 86400);
+    $this->database->delete('notify_widget')
+      ->condition('timestamp', $cutoff, '<')
+      ->execute();
+  }
+

   /**
+   * Mark all notifications as read for a user.
+   *
+   * @param int $uid
+   *   The user ID whose notifications should be marked as read.
+   */
+  public function markAllAsReadByUserId(int $uid = 0): void {
+    if ($uid === 0) {
+      $uid = $this->currentUser->id();
+    }
+
+    $this->database->update('notify_widget')
+      ->fields([
+        'read' => 1,
+      ])
+      ->condition('uid', $uid)
+      ->execute();
+
+    $this->clearNotifyWidgetCacheForUser($uid);
+  }

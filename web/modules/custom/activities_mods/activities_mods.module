<?php

/**
 * @file
 * Hooks for activities_mods.
 */

use Drupal\activities\Entity\UserActivitiesInterface;
use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Field\FieldItemListInterface;
use Drupal\file\FileInterface;
use Drupal\node\NodeInterface;
use Drupal\paragraphs\ParagraphInterface;
use Drupal\user\UserInterface;
use Drupal\views\ViewExecutable;
use Drupal\views\Plugin\views\query\QueryPluginBase;

/**
 * Implements hook_activities_logger_log().
 */
function activities_mods_activities_logger_log(UserActivitiesInterface $activities) {
  // Only append moderation info for incoming nodes.
  $entity_type = $activities->getRelatedEntityTypeId();
  $bundle = $activities->getBundle();
  if ($entity_type !== 'node' || $bundle !== 'incoming') {
    return;
  }

  $op = $activities->getOperation();
  // Incoming create/update/delete info is now built deterministically in
  // ActivitiesLogger::buildInfo() from the current entity + original.
  if (in_array($op, ['delete', 'create', 'update'], TRUE)) {
    return;
  }

  $storage = \Drupal::entityTypeManager()->getStorage('node');
  $entity_id = $activities->getRelatedEntityId();
  $base_entity = $storage->load($entity_id);
  if (!$base_entity) {
    return;
  }

  $revision_ids = $storage->revisionIds($base_entity);

  if (empty($revision_ids)) {
    return;
  }

  // Latest revision is last in the list.
  $latest_revision_id = $revision_ids[count($revision_ids) - 1];
  /** @var \Drupal\node\NodeInterface|null $latest */
  $latest = $storage->loadRevision($latest_revision_id);
  if (!$latest || !$latest->hasField('moderation_state')) {
    return;
  }

  $new_state = $latest->get('moderation_state')->value ?? NULL;
  $old_state = NULL;
  $previous = NULL;

  if (count($revision_ids) > 1) {
    $prev_revision_id = $revision_ids[count($revision_ids) - 2];
    /** @var \Drupal\node\NodeInterface|null $previous */
    $previous = $storage->loadRevision($prev_revision_id);
    if ($previous instanceof EntityInterface && $previous->hasField('moderation_state')) {
      $old_state = $previous->get('moderation_state')->value ?? NULL;
    }
  }

  if (!$new_state) {
    return;
  }

  // If no previous state was found, fall back to the current state so we log
  // "no change" transitions as well.
  if (!$old_state) {
    $old_state = $new_state;
  }

  $changes_lines = activities_mods_incoming_build_change_lines(
    $latest,
    $previous instanceof NodeInterface ? $previous : NULL,
    NULL,
    'full'
  );
  $changes_text = activities_mods_incoming_render_change_lines($changes_lines, FALSE);

  $workflow = \Drupal::service('content_moderation.moderation_information')->getWorkflowForEntity($latest);
  $plugin = $workflow ? $workflow->getTypePlugin() : NULL;
  $old_label = $plugin && $plugin->hasState($old_state) ? $plugin->getState($old_state)->label() : $old_state;
  $new_label = $plugin && $plugin->hasState($new_state) ? $plugin->getState($new_state)->label() : $new_state;
  $state_extra = (string) t('State: @from -> @to', [
    '@from' => $old_label,
    '@to' => $new_label,
  ]);
  // Avoid appending duplicate state-only info on update rows.
  if ($changes_text === '') {
    return;
  }
  $extra = $changes_text;

  // Avoid double-appending if the logger already added state info.
  $info = (string) $activities->getInfo();
  if (strpos($info, $extra) === FALSE) {
    $activities->setInfo($info ? sprintf("%s\n%s", $info, $extra) : $extra);
  }
}

/**
 * Enforce ASC sorting for the node activity view.
 */
function activities_mods_views_query_alter(ViewExecutable $view, QueryPluginBase $query) {
  if ($view->id() !== 'activities_mods_node_activity') {
    return;
  }

  $query->orderby = [];
  $query->addOrderBy('user_activities', 'created', 'ASC');
  $query->addOrderBy('user_activities', 'id', 'ASC');
}

/**
 * Builds a human-readable incoming title for notifications.
 */
function activities_mods_incoming_build_title(NodeInterface $node): string {
  $ref_id = '';
  if ($node->hasField('field_ref_id') && !$node->get('field_ref_id')->isEmpty()) {
    $ref_id = trim((string) $node->get('field_ref_id')->value);
  }

  $subject = '';
  if ($node->hasField('field_subject') && !$node->get('field_subject')->isEmpty()) {
    $subject = trim(strip_tags((string) $node->get('field_subject')->value));
  }

  if ($ref_id !== '' && $subject !== '') {
    return activities_mods_incoming_trim_with_ellipsis($ref_id . ' - ' . $subject, 100);
  }
  if ($ref_id !== '') {
    return activities_mods_incoming_trim_with_ellipsis($ref_id, 100);
  }
  if ($subject !== '') {
    return activities_mods_incoming_trim_with_ellipsis($subject, 100);
  }

  $fallback = trim((string) $node->label());
  return $fallback !== '' ? $fallback : (string) t('Χωρίς REF ID');
}

/**
 * Builds lines describing the latest incoming changes.
 *
 * @return string[]
 *   Change lines.
 */
function activities_mods_incoming_build_change_lines(
  NodeInterface $node,
  ?NodeInterface $original = NULL,
  ?ParagraphInterface $remark = NULL,
  string $fields_profile = 'full',
  bool $include_initial_values = FALSE
): array {
  $lines = [];
  $remark_lines = [];

  if ($remark instanceof ParagraphInterface) {
    foreach (activities_mods_incoming_get_new_remark_file_names($remark) as $filename) {
      $remark_lines[] = '- Νέο αρχείο: ' . activities_mods_incoming_trim_with_ellipsis($filename, 100);
    }
    $remark_comment = activities_mods_incoming_get_remark_comment_with_limit($remark, 100);
    if ($remark_comment !== '') {
      $remark_lines[] = '- παρατήρηση: ' . $remark_comment;
    }
  }

  $langcode = $node->language()->getId();
  foreach (activities_mods_incoming_get_changed_field_lines($node, $langcode, $original, $fields_profile, $remark, $include_initial_values) as $line) {
    $lines[] = $line;
  }
  foreach ($remark_lines as $line) {
    $lines[] = $line;
  }

  if (empty($lines)) {
    return [];
  }
  array_unshift($lines, 'Τελευταίες Αλλαγές');
  return $lines;
}

/**
 * Renders change lines for plain text or notify widget.
 */
function activities_mods_incoming_render_change_lines(array $lines, bool $for_notify): string {
  $lines = array_values(array_filter(array_map(static fn($line) => trim((string) $line), $lines)));
  if (empty($lines)) {
    return '';
  }
  if ($for_notify) {
    return implode("\n", $lines);
  }
  return implode("\n", $lines);
}

/**
 * Returns filenames attached to the given remark.
 *
 * @return string[]
 *   File names.
 */
function activities_mods_incoming_get_new_remark_file_names(ParagraphInterface $remark): array {
  if (!$remark->hasField('field_files') || $remark->get('field_files')->isEmpty()) {
    return [];
  }

  $names = [];
  foreach ($remark->get('field_files')->referencedEntities() as $file) {
    if ($file instanceof FileInterface) {
      $filename = trim((string) $file->getFilename());
      if ($filename !== '') {
        $names[] = $filename;
      }
    }
  }
  return array_values(array_unique($names));
}

/**
 * Returns lines for changed incoming fields.
 *
 * @return string[]
 *   Changed field lines.
 */
function activities_mods_incoming_get_changed_field_lines(
  NodeInterface $node,
  string $langcode,
  ?NodeInterface $original = NULL,
  string $fields_profile = 'full',
  ?ParagraphInterface $remark = NULL,
  bool $include_initial_values = FALSE
): array {
  $original_node = $original;
  if (!$include_initial_values && !$original_node && isset($node->original) && ($node->original instanceof NodeInterface)) {
    $original_node = $node->original;
  }
  if (!$original_node && !$include_initial_values) {
    return [];
  }

  $ordered_fields = [
    'moderation_state',
    'field_notes',
    'field_sender',
    'field_protocol_number_sender',
    'field_protocol_number_doc',
    'field_incoming_type',
    'field_incoming_subtype',
    'field_priority',
    'field_related_incoming',
    'field_documents',
    'field_attachments',
    'field_legal_deadline',
    'field_legal_entity',
    'field_basic_operator',
    'field_operators',
    'field_supervisor',
    'field_case',
    'field_tags',
    'field_answer',
    'field_answer_files',
    'field_plan',
    'field_plan_signed',
    'field_completion_date',
    'field_remarks',
  ];
  $minimal_fields = [
    'field_amke_status',
    'field_documents',
    'field_attachments',
    'field_plan_signed',
    'field_remarks',
  ];
  $selected_fields = $fields_profile === 'minimal' ? $minimal_fields : $ordered_fields;

  $lines = [];
  foreach ($selected_fields as $field_name) {
    if (!$node->hasField($field_name)) {
      continue;
    }
    if (!$include_initial_values && $original_node) {
      if (!$original_node->hasField($field_name)) {
        continue;
      }
      if ($node->get($field_name)->getValue() === $original_node->get($field_name)->getValue()) {
        continue;
      }
    }
    elseif ($node->get($field_name)->isEmpty()) {
      continue;
    }

    if ($field_name === 'moderation_state') {
      $new_state = (string) ($node->get('moderation_state')->value ?? '');
      if ($new_state === 'published') {
        // Do not emit a change line for "Published" state transitions.
        continue;
      }
      $label = 'Κατάσταση';
    }
    else {
      $definition = $node->getFieldDefinition($field_name);
      $label = trim((string) ($definition ? $definition->getLabel() : ''));
      if ($label === '') {
        $label = $field_name;
      }
    }

    if ($field_name === 'field_remarks' && $remark instanceof ParagraphInterface) {
      // Already included as "- παρατήρηση: ..." when remark context exists.
      continue;
    }

    $value = activities_mods_incoming_get_field_value_for_notification(
      $node->get($field_name),
      $field_name,
      $langcode,
      $node,
      $original_node
    );
    if (
      trim($value) === '-' &&
      in_array($field_name, ['field_documents', 'field_attachments', 'field_related_incoming', 'field_plan', 'field_plan_signed', 'field_remarks'], TRUE)
    ) {
      // For delta-only fields, '-' means no effective new change for this save.
      continue;
    }
    $lines[] = '- ' . $label . ': ' . $value;
  }

  return $lines;
}

/**
 * Returns a trimmed remark comment string with a configurable limit.
 */
function activities_mods_incoming_get_remark_comment_with_limit(ParagraphInterface $remark, int $limit): string {
  if (!$remark->hasField('field_comment') || $remark->get('field_comment')->isEmpty()) {
    return '';
  }
  $comment = trim(strip_tags((string) $remark->get('field_comment')->value));
  return activities_mods_incoming_trim_with_ellipsis($comment, $limit);
}

/**
 * Extracts a readable field value for notifications/activity text.
 */
function activities_mods_incoming_get_field_value_for_notification(
  FieldItemListInterface $field,
  string $field_name,
  string $langcode,
  ?NodeInterface $node = NULL,
  ?NodeInterface $original_node = NULL
): string {
  if ($field->isEmpty()) {
    return '-';
  }

  if ($field_name === 'moderation_state') {
    $raw_state = (string) ($field->value ?? '');
    return $raw_state !== '' ? activities_mods_incoming_get_state_label($raw_state, $langcode) : '-';
  }

  if ($field_name === 'field_amke_status') {
    $raw = (string) ($field->value ?? '');
    if ($raw === '') {
      return '-';
    }
    $allowed = options_allowed_values($field->getFieldDefinition()->getFieldStorageDefinition());
    if (isset($allowed[$raw]) && $allowed[$raw] !== '') {
      return activities_mods_incoming_trim_with_ellipsis((string) $allowed[$raw], 100);
    }
    return activities_mods_incoming_trim_with_ellipsis($raw, 100);
  }

  if ($field_name === 'field_remarks' && $node instanceof NodeInterface) {
    return activities_mods_incoming_get_latest_inserted_remark_comment($node, $original_node);
  }

  if (in_array($field_name, ['field_completion_date', 'field_legal_deadline'], TRUE)) {
    $raw = trim((string) ($field->value ?? ''));
    if ($raw === '') {
      return '-';
    }
    $timestamp = strtotime($raw);
    if ($timestamp !== FALSE) {
      return date('m/d/Y', $timestamp);
    }
    return activities_mods_incoming_trim_with_ellipsis($raw, 100);
  }

  if (method_exists($field, 'referencedEntities')) {
    $entities = $field->referencedEntities();
    if (!empty($entities)) {
      if (
        in_array($field_name, ['field_documents', 'field_attachments', 'field_plan', 'field_plan_signed'], TRUE) &&
        $node instanceof NodeInterface &&
        $original_node instanceof NodeInterface &&
        $node->hasField($field_name) &&
        $original_node->hasField($field_name)
      ) {
        $new_ids = array_map(
          static fn(array $item) => (int) ($item['target_id'] ?? 0),
          $node->get($field_name)->getValue()
        );
        $old_ids = array_map(
          static fn(array $item) => (int) ($item['target_id'] ?? 0),
          $original_node->get($field_name)->getValue()
        );
        $added_ids = array_values(array_unique(array_diff($new_ids, $old_ids)));
        if (empty($added_ids)) {
          return '-';
        }

        $target_type = (string) $field->getFieldDefinition()->getSetting('target_type');
        $storage_type = $target_type !== '' ? $target_type : 'file';
        $loaded = \Drupal::entityTypeManager()->getStorage($storage_type)->loadMultiple($added_ids);

        $ordered_entities = [];
        foreach ($added_ids as $id) {
          if (isset($loaded[$id])) {
            $ordered_entities[] = $loaded[$id];
          }
        }
        $file_names = activities_mods_incoming_extract_document_file_names($ordered_entities);
        if (!empty($file_names)) {
          $text = trim(implode(', ', array_filter(array_map('trim', $file_names))));
          return $text !== '' ? activities_mods_incoming_trim_with_ellipsis($text, 100) : '-';
        }
        return '-';
      }

      if ($field_name === 'field_related_incoming' && $node instanceof NodeInterface && $original_node instanceof NodeInterface) {
        $new_ids = array_map(
          static fn(array $item) => (int) ($item['target_id'] ?? 0),
          $node->get('field_related_incoming')->getValue()
        );
        $old_ids = array_map(
          static fn(array $item) => (int) ($item['target_id'] ?? 0),
          $original_node->get('field_related_incoming')->getValue()
        );
        $added_ids = array_values(array_unique(array_diff($new_ids, $old_ids)));
        if (empty($added_ids)) {
          return '-';
        }
        $loaded = \Drupal::entityTypeManager()->getStorage('node')->loadMultiple($added_ids);
        $parts = [];
        foreach ($added_ids as $nid) {
          if (isset($loaded[$nid])) {
            $parts[] = (string) $loaded[$nid]->label();
          }
        }
        $text = trim(implode(', ', array_filter(array_map('trim', $parts))));
        return $text !== '' ? activities_mods_incoming_trim_with_ellipsis($text, 100) : '-';
      }

      if (in_array($field_name, ['field_documents', 'field_attachments', 'field_answer_files', 'field_plan', 'field_plan_signed'], TRUE)) {
        $file_names = activities_mods_incoming_extract_document_file_names($entities);
        if (!empty($file_names)) {
          $text = trim(implode(', ', array_filter(array_map('trim', $file_names))));
          return $text !== '' ? activities_mods_incoming_trim_with_ellipsis($text, 100) : '-';
        }
      }

      $parts = [];
      if (in_array($field_name, ['field_basic_operator', 'field_operators', 'field_supervisor'], TRUE)) {
        foreach ($entities as $entity) {
          if ($entity instanceof UserInterface) {
            $parts[] = activities_mods_incoming_get_user_full_name($entity);
          }
          else {
            $parts[] = (string) $entity->label();
          }
        }
        $text = trim(implode(', ', array_filter(array_map('trim', $parts))));
        return $text !== '' ? activities_mods_incoming_trim_with_ellipsis($text, 100) : '-';
      }

      foreach ($entities as $entity) {
        if ($entity instanceof FileInterface) {
          $parts[] = (string) $entity->getFilename();
        }
        else {
          $parts[] = (string) $entity->label();
        }
      }
      $text = trim(implode(', ', array_filter(array_map('trim', $parts))));
      return $text !== '' ? activities_mods_incoming_trim_with_ellipsis($text, 100) : '-';
    }
  }

  $parts = [];
  foreach ($field as $item) {
    $item_value = $item->getValue();
    $raw = '';
    if (array_key_exists('value', $item_value) && $item_value['value'] !== NULL && $item_value['value'] !== '') {
      $raw = (string) $item_value['value'];
    }
    elseif (array_key_exists('uri', $item_value) && $item_value['uri'] !== NULL && $item_value['uri'] !== '') {
      $raw = (string) $item_value['uri'];
    }
    elseif (array_key_exists('target_id', $item_value) && $item_value['target_id'] !== NULL && $item_value['target_id'] !== '') {
      $raw = (string) $item_value['target_id'];
    }
    if ($raw !== '') {
      $parts[] = trim(strip_tags($raw));
    }
  }

  $text = trim(implode(', ', array_filter($parts)));
  return $text !== '' ? activities_mods_incoming_trim_with_ellipsis($text, 100) : '-';
}

/**
 * Extracts filenames from incoming document/attachment references.
 *
 * @param array $entities
 *   Referenced entities.
 *
 * @return string[]
 *   File names.
 */
function activities_mods_incoming_extract_document_file_names(array $entities): array {
  $names = [];
  foreach ($entities as $entity) {
    if ($entity instanceof FileInterface) {
      $filename = trim((string) $entity->getFilename());
      if ($filename !== '') {
        $names[] = $filename;
      }
      continue;
    }

    if (!$entity instanceof ParagraphInterface || !$entity->hasField('field_files') || $entity->get('field_files')->isEmpty()) {
      continue;
    }
    foreach ($entity->get('field_files')->referencedEntities() as $file) {
      if ($file instanceof FileInterface) {
        $filename = trim((string) $file->getFilename());
        if ($filename !== '') {
          $names[] = $filename;
        }
      }
    }
  }
  return array_values(array_unique($names));
}

/**
 * Returns a readable full name for user references.
 */
function activities_mods_incoming_get_user_full_name(UserInterface $user): string {
  $first_name = $user->hasField('field_first_name')
    ? trim((string) $user->get('field_first_name')->value)
    : '';
  $last_name = $user->hasField('field_last_name')
    ? trim((string) $user->get('field_last_name')->value)
    : '';
  $full_name = trim($first_name . ' ' . $last_name);
  if ($full_name !== '') {
    return $full_name;
  }
  $label = trim((string) $user->label());
  return $label !== '' ? $label : (string) $user->id();
}

/**
 * Returns the localized moderation state label.
 */
function activities_mods_incoming_get_state_label(string $state, string $langcode): string {
  $entity_type_manager = \Drupal::entityTypeManager();
  if (!$entity_type_manager->hasDefinition('moderation_state')) {
    $fallback_labels = [
      'draft' => t('Εισερχόμενο', [], ['langcode' => $langcode]),
      'to_be_assigned' => t('Προς χρέωση', [], ['langcode' => $langcode]),
      'fullness_check' => t('Έλεγχος πληρότητας', [], ['langcode' => $langcode]),
      'pending_issues' => t('Με εκκρεμότητες', [], ['langcode' => $langcode]),
      'issues_to_check' => t('Προς έλεγχο εκκρεμοτήτων', [], ['langcode' => $langcode]),
      'under_processing' => t('Υπό επεξεργασία', [], ['langcode' => $langcode]),
      'for_signature' => t('Εγκεκριμένο – Αποστολή στο ΣΗΔΕ προς υπογραφή', [], ['langcode' => $langcode]),
      'published' => t('Δημοσιευμένο', [], ['langcode' => $langcode]),
    ];
    return (string) ($fallback_labels[$state] ?? $state);
  }

  $labels = &drupal_static(__FUNCTION__, []);
  if (!isset($labels[$langcode])) {
    $storage = $entity_type_manager->getStorage('moderation_state');
    $states = $storage->loadMultiple();
    $labels[$langcode] = [];
    foreach ($states as $state_entity) {
      if ($state_entity->hasTranslation($langcode)) {
        $state_entity = $state_entity->getTranslation($langcode);
      }
      $labels[$langcode][$state_entity->id()] = $state_entity->label();
    }
  }
  return (string) ($labels[$langcode][$state] ?? $state);
}

/**
 * Trims a string to a max length and adds an ellipsis when needed.
 */
function activities_mods_incoming_trim_with_ellipsis(string $value, int $limit): string {
  $value = trim($value);
  if ($value === '' || $limit <= 0) {
    return $value;
  }
  if (function_exists('mb_strlen') && function_exists('mb_substr')) {
    if (mb_strlen($value) <= $limit) {
      return $value;
    }
    return rtrim(mb_substr($value, 0, $limit - 1)) . '…';
  }
  if (strlen($value) <= $limit) {
    return $value;
  }
  return rtrim(substr($value, 0, $limit - 3)) . '...';
}

/**
 * Returns latest newly inserted remark comment, trimmed for notifications.
 */
function activities_mods_incoming_get_latest_inserted_remark_comment(NodeInterface $node, ?NodeInterface $original_node = NULL): string {
  if (!$node->hasField('field_remarks') || $node->get('field_remarks')->isEmpty()) {
    return '-';
  }

  $previous_ids = [];
  if ($original_node instanceof NodeInterface && $original_node->hasField('field_remarks')) {
    foreach ($original_node->get('field_remarks')->referencedEntities() as $previous) {
      if ($previous instanceof ParagraphInterface && $previous->id()) {
        $previous_ids[(int) $previous->id()] = TRUE;
      }
    }
  }

  $remarks = $node->get('field_remarks')->referencedEntities();
  foreach (array_reverse($remarks) as $remark) {
    if (!$remark instanceof ParagraphInterface || $remark->bundle() !== 'remark') {
      continue;
    }
    $remark_id = $remark->id() ? (int) $remark->id() : NULL;
    if ($remark_id && isset($previous_ids[$remark_id])) {
      continue;
    }
    if (!$remark->hasField('field_comment') || $remark->get('field_comment')->isEmpty()) {
      continue;
    }
    $comment = trim(strip_tags((string) $remark->get('field_comment')->value));
    if ($comment !== '') {
      return activities_mods_incoming_trim_with_ellipsis($comment, 100);
    }
  }

  return '-';
}

<?php

use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Form\FormStateInterface;
use Drupal\Component\Utility\NestedArray;
use Drupal\taxonomy\TermInterface;

/**
 * Implements hook_entity_prepare_form().
 */
function taxonomy_tweaks_entity_prepare_form(EntityInterface $entity, string $operation, FormStateInterface $form_state): void {
  if (!$entity instanceof TermInterface || $entity->bundle() !== 'case' || !$entity->isNew()) {
    return;
  }

  if (!\Drupal::currentUser()->hasRole('administrator')) {
    $parent_id = (int) \Drupal::request()->query->get('parent');
    if ($parent_id > 0) {
      $entity->set('parent', [$parent_id]);
    }
  }
}

/**
 * Implements hook_form_BASE_FORM_ID_alter().
 */
function taxonomy_tweaks_form_taxonomy_term_form_alter(array &$form, FormStateInterface $form_state, string $form_id): void {
  if (\Drupal::currentUser()->hasRole('administrator')) {
    return;
  }

  $term = $form_state->getFormObject()->getEntity();
  if (!$term instanceof TermInterface) {
    return;
  }

  if ($term->bundle() === 'case') {
    $allow_keys = [
      'name',
      'parent',
      'field_name_typed',
      'actions',
      'form_build_id',
      'form_token',
      'form_id',
    ];

    if (isset($form['name'])) {
      $form['name']['#attributes']['class'][] = 'visually-hidden';
    }

    if (isset($form['parent']['#description'])) {
      $form['parent']['#description'] = NULL;
    }
    if (isset($form['parent']['widget']['#description'])) {
      $form['parent']['widget']['#description'] = NULL;
    }
  }
  else {
    $allow_keys = [
      'name',
      'actions',
      'form_build_id',
      'form_token',
      'form_id',
    ];
  }

  foreach ($form as $key => &$element) {
    if (isset($element['#type']) && $element['#type'] === 'hidden') {
      continue;
    }
    if (in_array($key, $allow_keys, TRUE)) {
      continue;
    }
    if (str_starts_with((string) $key, '#')) {
      continue;
    }

    $element['#access'] = FALSE;
  }
  unset($element);

  if (isset($form['actions']['overview'])) {
    $form['actions']['overview']['#value'] = t('Αποθήκευση');
    $form['actions']['overview']['#button_type'] = 'primary';
    unset($form['actions']['submit']);
  }

  if (!$term->isNew()) {
    return;
  }

  $vocabulary = \Drupal::entityTypeManager()->getStorage('taxonomy_vocabulary')->load($term->bundle());
  if (!$vocabulary) {
    return;
  }

  $prefix_map = [
    'legal_entity' => 'Νέος',
  ];

  $prefix = $prefix_map[$term->bundle()] ?? 'Νέα';
  $form['#title'] = t('@prefix @vocabulary', [
    '@prefix' => $prefix,
    '@vocabulary' => $vocabulary->label(),
  ]);
}

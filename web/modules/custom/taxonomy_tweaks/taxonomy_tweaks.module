<?php

use Drupal\Component\Utility\Html;
use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Link;
use Drupal\Core\Url;
use Drupal\taxonomy\TermInterface;
use Drupal\taxonomy\VocabularyInterface;
use Drupal\views\Plugin\views\query\Sql;
use Drupal\views\ViewExecutable;

/**
 * Implements hook_entity_base_field_info_alter().
 */
function taxonomy_tweaks_entity_base_field_info_alter(array &$fields, \Drupal\Core\Entity\EntityTypeInterface $entity_type): void {
  if ($entity_type->id() !== 'taxonomy_term' || !isset($fields['name'])) {
    return;
  }

  $fields['name']->setSetting('max_length', 1024);
}

/**
 * Implements hook_entity_prepare_form().
 */
function taxonomy_tweaks_entity_prepare_form(EntityInterface $entity, string $operation, FormStateInterface $form_state): void {
  if (!$entity instanceof TermInterface || $entity->bundle() !== 'case' || !$entity->isNew()) {
    return;
  }

  if (!\Drupal::currentUser()->hasRole('administrator')) {
    $parent_id = (int) \Drupal::request()->query->get('parent');
    if ($parent_id > 0) {
      $entity->set('parent', [$parent_id]);
    }
  }
}

/**
 * Implements hook_preprocess_breadcrumb().
 */
function taxonomy_tweaks_preprocess_breadcrumb(array &$variables): void {
  if (\Drupal::routeMatch()->getRouteName() !== 'entity.taxonomy_term.edit_form') {
    return;
  }

  if (empty($variables['breadcrumb']) || !is_array($variables['breadcrumb'])) {
    return;
  }

  $last_index = array_key_last($variables['breadcrumb']);
  if ($last_index === NULL) {
    return;
  }

  $last_item = &$variables['breadcrumb'][$last_index];
  if ($last_item instanceof Link) {
    $last_item = Link::fromTextAndUrl($last_item->getText(), Url::fromRoute('<nolink>'));
    return;
  }

  if (is_array($last_item) && isset($last_item['url'])) {
    unset($last_item['url']);
  }
}

/**
 * Implements hook_form_BASE_FORM_ID_alter().
 */
function taxonomy_tweaks_form_taxonomy_term_form_alter(array &$form, FormStateInterface $form_state, string $form_id): void {
  $existing_style = $form['#attributes']['style'] ?? '';
  $form['#attributes']['style'] = trim($existing_style . ' max-width: 600px; margin: 0 auto;');

  $term = $form_state->getFormObject()->getEntity();
  if (!$term instanceof TermInterface) {
    return;
  }

  if ($term->bundle() === 'case') {
    if (isset($form['parent']['#title'])) {
      $form['parent']['#title'] = t('Υφιστάμενες Υποθέσεις');
    }
    if (isset($form['parent']['widget']['#title'])) {
      $form['parent']['widget']['#title'] = t('Υφιστάμενες Υποθέσεις');
    }
  }

  if (\Drupal::currentUser()->hasRole('administrator')) {
    return;
  }

  if ($term->bundle() === 'case') {
    $allow_keys = [
      'field_name_typed',
      'parent',
      'actions',
      'form_build_id',
      'form_token',
      'form_id',
    ];

    if (isset($form['name'])) {
      $form['name']['#attributes']['class'][] = 'visually-hidden';
    }

    if (isset($form['parent']['#description'])) {
      $form['parent']['#description'] = NULL;
    }
    if (isset($form['parent']['widget']['#description'])) {
      $form['parent']['widget']['#description'] = NULL;
    }
  }
  else {
    $allow_keys = [
      'name',
      'parent',
      'actions',
      'form_build_id',
      'form_token',
      'form_id',
    ];

    if ($term->bundle() !== 'legal_entity') {
      $allow_keys = array_values(array_diff($allow_keys, ['parent']));
    }
  }

  foreach ($form as $key => &$element) {
    if (isset($element['#type']) && $element['#type'] === 'hidden') {
      continue;
    }
    if (in_array($key, $allow_keys, TRUE)) {
      continue;
    }
    if (str_starts_with((string) $key, '#')) {
      continue;
    }

    $element['#access'] = FALSE;
  }
  unset($element);

  if (isset($form['actions']['overview'])) {
    $form['actions']['overview']['#value'] = t('Αποθήκευση');
    $form['actions']['overview']['#button_type'] = 'primary';
    unset($form['actions']['submit']);
  }

  if (!$term->isNew()) {
    return;
  }

  $vocabulary = \Drupal::entityTypeManager()->getStorage('taxonomy_vocabulary')->load($term->bundle());
  if (!$vocabulary) {
    return;
  }

  $prefix_map = [
    'legal_entity' => 'Νέος',
  ];

  $prefix = $prefix_map[$term->bundle()] ?? 'Νέα';
  $form['#title'] = t('@prefix @vocabulary', [
    '@prefix' => $prefix,
    '@vocabulary' => $vocabulary->label(),
  ]);
}

/**
 * Implements hook_form_FORM_ID_alter().
 */
function taxonomy_tweaks_form_taxonomy_overview_terms_alter(array &$form, FormStateInterface $form_state): void {
  if (empty($form['terms']) || !is_array($form['terms'])) {
    return;
  }

  if (isset($form['help'])) {
    unset($form['help']);
  }

  if (isset($form['terms']['#header']) && is_array($form['terms']['#header'])) {
    unset($form['terms']['#header']['status'], $form['terms']['#header']['weight']);
    $form['terms']['#header'] = array_filter(
      $form['terms']['#header'],
      static fn($value) => $value !== NULL
    );
  }

  foreach (array_keys($form['terms']) as $key) {
    if (!is_array($form['terms'][$key]) || !isset($form['terms'][$key]['term']) || !is_array($form['terms'][$key]['term'])) {
      continue;
    }

    if (isset($form['terms'][$key]['status'])) {
      $form['terms'][$key]['status'] = NULL;
    }
    if (isset($form['terms'][$key]['weight'])) {
      $form['terms'][$key]['weight'] = NULL;
    }

    $term_element = &$form['terms'][$key]['term'];
    if (isset($term_element['#type']) && $term_element['#type'] === 'link') {
      $title = $term_element['#title'] ?? '';
      $term_element['#type'] = 'item';
      $term_element['#plain_text'] = Html::decodeEntities((string) $title);
      unset($term_element['#title'], $term_element['#url']);
      continue;
    }

    if (isset($term_element['#markup'])) {
      $term_element['#markup'] = Html::escape(Html::decodeEntities((string) $term_element['#markup']));
    }
  }
}

/**
 * Implements hook_preprocess_HOOK() for menu local actions.
 */
function taxonomy_tweaks_preprocess_menu_local_action(array &$variables): void {
  $link = $variables['element']['#link'] ?? NULL;
  if (!is_array($link) || empty($link['url']) || !$link['url'] instanceof Url) {
    return;
  }

  if ($link['url']->getRouteName() !== 'entity.taxonomy_term.add_form') {
    return;
  }

  $route_parameters = $link['url']->getRouteParameters();
  if (empty($route_parameters['taxonomy_vocabulary'])) {
    return;
  }

  $label = taxonomy_tweaks_get_add_term_action_title($route_parameters['taxonomy_vocabulary']);
  $variables['element']['#link']['title'] = $label;
  // Ensure the rendered variable used by Twig gets the updated title.
  $variables['link'] = [
    '#type' => 'link',
    '#title' => $label,
    '#url' => $link['url'],
    '#options' => (array) ($link['localized_options'] ?? []),
  ];
}

/**
 * Builds the custom add-term label for taxonomy overview pages.
 */
function taxonomy_tweaks_get_add_term_action_title(VocabularyInterface|string|null $taxonomy_vocabulary = NULL): string {
  if (is_string($taxonomy_vocabulary) && $taxonomy_vocabulary !== '') {
    $taxonomy_vocabulary = \Drupal::entityTypeManager()
      ->getStorage('taxonomy_vocabulary')
      ->load($taxonomy_vocabulary);
  }

  if (!$taxonomy_vocabulary instanceof VocabularyInterface) {
    return (string) t('Προσθήκη όρου');
  }

  // Override per vocabulary where grammar should not directly follow the label.
  // Key: vocabulary machine name (vid), Value: custom Greek text after
  // "Προσθήκη". Leave NULL to use the vocabulary name as-is.
  $label_overrides = [
    'case' => 'υπόθεσης',
    'incoming_subtype' => NULL,
    'incoming_type' => NULL,
    'legal_entity' => NULL,
    'priority' => NULL,
    'tags' => 'λέξή κλειδί',
  ];

  $vid = $taxonomy_vocabulary->id();
  $override = $label_overrides[$vid] ?? NULL;
  $label = is_string($override) && trim($override) !== ''
    ? $override
    : trim((string) $taxonomy_vocabulary->label());
  if ($label === '') {
    return (string) t('Προσθήκη όρου');
  }

  return 'Προσθήκη ' . taxonomy_tweaks_strtolower($label);
}

/**
 * Lowercases UTF-8 text safely.
 */
function taxonomy_tweaks_strtolower(string $text): string {
  if (function_exists('mb_strtolower')) {
    return mb_strtolower($text, 'UTF-8');
  }

  return strtolower($text);
}

/**
 * Implements hook_views_pre_view().
 */
function taxonomy_tweaks_views_pre_view(ViewExecutable $view, string $display_id, array &$args): void {
  if (!taxonomy_tweaks_is_cases_filterable_display($view, $display_id)) {
    return;
  }

  $input = $view->getExposedInput();
  $name = trim((string) ($input['name'] ?? ''));
  if ($name === '') {
    return;
  }

  // Stash the original input so we can alter the query later, but prevent the
  // default name filter from locking results to the parent term only.
  $view->taxonomy_tweaks_name_filter = $name;
  $input['name'] = '';
  $view->setExposedInput($input);
}

/**
 * Implements hook_views_query_alter().
 */
function taxonomy_tweaks_views_query_alter(ViewExecutable $view, Sql $query): void {
  if (!taxonomy_tweaks_is_cases_filterable_display($view, $view->current_display)) {
    return;
  }

  $name = trim((string) ($view->taxonomy_tweaks_name_filter ?? ''));
  if ($name === '') {
    return;
  }

  $term_storage = \Drupal::entityTypeManager()->getStorage('taxonomy_term');
  $match_query = \Drupal::entityQuery('taxonomy_term')
    ->condition('vid', 'case')
    ->condition('name', $name, '=')
    ->accessCheck(FALSE);
  $matched_tids = $match_query->execute();

  if (!$matched_tids) {
    $match_query = \Drupal::entityQuery('taxonomy_term')
      ->condition('vid', 'case')
      ->condition('name', $name, 'CONTAINS')
      ->accessCheck(FALSE);
    $matched_tids = $match_query->execute();
  }

  if (!$matched_tids) {
    return;
  }

  $all_tids = array_map('intval', $matched_tids);
  foreach ($matched_tids as $tid) {
    $children = $term_storage->loadTree('case', (int) $tid, NULL, FALSE);
    foreach ($children as $child) {
      $all_tids[] = (int) $child->tid;
    }
  }
  $all_tids = array_values(array_unique($all_tids));

  $base_alias = $query->ensureTable('taxonomy_term_field_data');
  $query->addWhere(0, $base_alias . '.tid', $all_tids, 'IN');
}

/**
 * Checks whether the display should use the custom case-name filtering logic.
 */
function taxonomy_tweaks_is_cases_filterable_display(ViewExecutable $view, ?string $display_id): bool {
  return $view->id() === 'cases' && in_array((string) $display_id, ['page_1', 'data_export_1'], TRUE);
}

<?php

use Drupal\Core\Entity\EntityInterface;
use Drupal\node\NodeInterface;

/**
 * Implements hook_entity_presave().
 */
function field_ref_id_entity_presave(EntityInterface $entity) {
  if (!$entity instanceof NodeInterface) {
    return;
  }
  if ($entity->isNew()) {
    // The numeric ID is assigned after insert, so handle new nodes there.
    return;
  }

  field_ref_id_populate_field($entity);
}

/**
 * Implements hook_ENTITY_TYPE_insert() for nodes.
 */
function field_ref_id_node_insert(NodeInterface $node) {
  if (!field_ref_id_populate_field($node)) {
    return;
  }

  // Avoid creating a revision just for the auto-generated value.
  $node->setNewRevision(FALSE);
  $node->save();
}

/**
 * Returns an auto-generated ID for the field_ref_id field.
 */
function field_ref_id_generate_value(NodeInterface $node) {
  // Deterministic format so editors can reference cases easily.
  return "REF-" . (10000 + $node->id());
}

/**
 * Sets the field_ref_id field if it is empty.
 *
 * @return bool
 *   TRUE if the field was populated, FALSE otherwise.
 */
function field_ref_id_populate_field(NodeInterface $node) {
  if (!$node->hasField('field_ref_id') || !$node->get('field_ref_id')->isEmpty()) {
    return FALSE;
  }

  $node->set('field_ref_id', field_ref_id_generate_value($node));
  return TRUE;
}

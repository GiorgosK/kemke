<?php

use Drupal\Core\Access\AccessResult;
use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Session\AccountInterface;
use Drupal\node\NodeInterface;
use Drupal\paragraphs\ParagraphInterface;

/**
 * Implements hook_entity_access().
 */
function documents_lock_entity_access(EntityInterface $entity, $operation, AccountInterface $account) {
  if ($entity instanceof ParagraphInterface && $entity->bundle() === 'documents') {
    if (in_array($operation, ['update', 'delete'], TRUE) && !$entity->isNew()) {
      return AccessResult::forbidden()->addCacheableDependency($entity);
    }
  }

  return AccessResult::neutral();
}

/**
 * Implements hook_form_FORM_ID_alter() for the incoming content type form.
 */
function documents_lock_form_node_incoming_form_alter(array &$form, FormStateInterface $form_state) {
  documents_lock_alter_incoming_documents_widget($form, $form_state);
}

/**
 * Implements hook_form_FORM_ID_alter() for the incoming edit form.
 */
function documents_lock_form_node_incoming_edit_form_alter(array &$form, FormStateInterface $form_state) {
  documents_lock_alter_incoming_documents_widget($form, $form_state);
}

/**
 * Adds a read-only listing of existing documents paragraphs on the node form.
 */
function documents_lock_alter_incoming_documents_widget(array &$form, FormStateInterface $form_state) {
  if (empty($form['field_documents']['widget'])) {
    return;
  }

  $form_object = $form_state->getFormObject();
  if (!$form_object) {
    return;
  }

  /** @var \Drupal\node\NodeInterface $node */
  $node = $form_object->getEntity();
  if (!$node instanceof NodeInterface || $node->isNew()) {
    return;
  }

  if (!is_array($form['field_documents']['widget'])) {
    return;
  }
  $widget =& $form['field_documents']['widget'];

  $form['#attached']['library'][] = 'documents_lock/form';

  // Remove drag & drop support for the documents field entirely.
  if (isset($widget['#tabledrag'])) {
    unset($widget['#tabledrag']);
  }
  if (!empty($widget['#attributes']['class'])) {
    $widget['#attributes']['class'] = array_values(array_diff($widget['#attributes']['class'], ['draggable-table']));
  }
  if (isset($widget['top']['actions']['dropdown_actions']['dragdrop_mode'])) {
    unset($widget['top']['actions']['dropdown_actions']['dragdrop_mode']);
  }

  $view_builder = \Drupal::entityTypeManager()->getViewBuilder('paragraph');

  foreach ($node->get('field_documents') as $delta => $item) {
    if ($item->isEmpty()) {
      continue;
    }
    $paragraph = $item->entity;
    if ($paragraph instanceof ParagraphInterface && !$paragraph->isNew() && isset($widget[$delta])) {
      if (!empty($widget[$delta]['#attributes']['class'])) {
        $widget[$delta]['#attributes']['class'] = array_values(array_diff($widget[$delta]['#attributes']['class'], ['draggable', 'drag']));
      }
      if (isset($widget[$delta]['title'])) {
        $widget[$delta]['title']['#access'] = FALSE;
      }
      if (isset($widget[$delta]['weight'])) {
        $widget[$delta]['weight']['#access'] = FALSE;
      }
      // Remove reordering and reference-change controls.
      if (isset($widget[$delta]['actions'])) {
        unset($widget[$delta]['actions']['remove'], $widget[$delta]['actions']['duplicate'], $widget[$delta]['actions']['convert']);
      }

      $widget[$delta]['documents_lock_display'] = [
        '#type' => 'container',
        '#attributes' => ['class' => ['documents-lock-existing-item']],
        '#weight' => 100,
        'content' => $view_builder->view($paragraph, 'default'),
      ];
      if (isset($widget[$delta]['subform'])) {
        $widget[$delta]['subform']['#access'] = FALSE;
      }
    }
  }
}

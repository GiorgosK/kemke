<?php

/**
 * @file
 * Views query alteration for operators absenses display.
 */

use Drupal\Core\Datetime\DrupalDateTime;
use Drupal\datetime\Plugin\Field\FieldType\DateTimeItemInterface;
use Drupal\views\ViewExecutable;

/**
 * Implements hook_views_pre_render().
 */
function operators_reference_view_views_pre_render(ViewExecutable $view): void {
  if ($view->id() !== 'operators') {
    return;
  }

  $timezone = new \DateTimeZone('UTC');
  $now = new DrupalDateTime('now', $timezone);
  $now->setTime(0, 0, 0);
  $end = (clone $now)->modify('+3 months');
  $window_start_ts = $now->getTimestamp();
  $window_end_ts = $end->getTimestamp();

  $storage = \Drupal::entityTypeManager()->getStorage('paragraph');

  foreach ($view->result as $row) {
    if (empty($row->_entity) || !$row->_entity->hasField('field_absenses_ref')) {
      continue;
    }

    $filtered = [];
    foreach ($row->_entity->get('field_absenses_ref') as $item) {
      $revision_id = $item->get('target_revision_id')->getValue();
      $target_id = $item->get('target_id')->getValue();
      if (!$revision_id && !$target_id) {
        continue;
      }

      $paragraph = $revision_id ? $storage->loadRevision($revision_id) : $storage->load($target_id);
      if (!$paragraph || !$paragraph->hasField('field_dates')) {
        continue;
      }

      $start_value = $paragraph->get('field_dates')->value;
      if (!$start_value) {
        continue;
      }

      $end_value = $paragraph->get('field_dates')->end_value ?: $start_value;
      $start_date = DrupalDateTime::createFromFormat(
        DateTimeItemInterface::DATE_STORAGE_FORMAT,
        $start_value,
        new \DateTimeZone(DateTimeItemInterface::STORAGE_TIMEZONE)
      );
      $end_date = DrupalDateTime::createFromFormat(
        DateTimeItemInterface::DATE_STORAGE_FORMAT,
        $end_value,
        new \DateTimeZone(DateTimeItemInterface::STORAGE_TIMEZONE)
      );
      if (!$start_date || !$end_date) {
        continue;
      }

      $absence_start_ts = $start_date->getTimestamp();
      $absence_end_ts = $end_date->getTimestamp();

      // Keep absences that overlap with [now, now + 3 months).
      if ($absence_start_ts < $window_end_ts && $absence_end_ts >= $window_start_ts) {
        $filtered[] = [
          'target_id' => $target_id,
          'target_revision_id' => $revision_id,
        ];
      }
    }

    $row->_entity->set('field_absenses_ref', $filtered);
  }
}

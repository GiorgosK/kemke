<?php

use Drupal\Core\Datetime\DrupalDateTime;
use Drupal\Core\Entity\Query\QueryInterface;
use Drupal\datetime\Plugin\Field\FieldType\DateTimeItemInterface;
use Drupal\node\NodeInterface;
use Drupal\paragraphs\ParagraphInterface;
use Drupal\user\UserInterface;

/**
 * Counts incoming nodes for a given year and filters.
 */
function kemke_reports_incoming_get_number_for(int $year, array $conditions = ['field_incoming_type' => 'Γνωμοδότηση'], string $state = 'published'): int {
  $conditions += ['field_incoming_type' => 'Γνωμοδότηση'];

  $query = \Drupal::entityTypeManager()
    ->getStorage('node')
    ->getQuery()
    ->accessCheck(FALSE)
    ->condition('type', 'incoming');

  kemke_reports_apply_year_condition($query, $year);
  kemke_reports_apply_incoming_filters($query, $conditions, $state);

  return (int) $query->count()->execute();
}

/**
 * Returns incoming node IDs for a given year and filters.
 */
function kemke_reports_incoming_get_ids_for(int $year, array $conditions = ['field_incoming_type' => 'Γνωμοδότηση'], string $state = 'published'): array {
  $conditions += ['field_incoming_type' => 'Γνωμοδότηση'];

  $query = \Drupal::entityTypeManager()
    ->getStorage('node')
    ->getQuery()
    ->accessCheck(FALSE)
    ->condition('type', 'incoming');

  kemke_reports_apply_year_condition($query, $year);
  kemke_reports_apply_incoming_filters($query, $conditions, $state);

  $nids = $query->execute();
  return $nids ? array_values($nids) : [];
}

/**
 * Sets objective-specific on-time field based on completion date and deadlines.
 *
 * @return int
 *   The number of updated nodes.
 */
function kemke_reports_incoming_set_on_time_for(array $conditions = ['field_incoming_type' => 'Γνωμοδότηση'], string $state = 'published', bool $force_recalculate = FALSE, string $objective_key = 'objective_1', ?int $year = NULL): int {
  $conditions += ['field_incoming_type' => 'Γνωμοδότηση'];

  $query = \Drupal::entityTypeManager()
    ->getStorage('node')
    ->getQuery()
    ->accessCheck(FALSE)
    ->condition('type', 'incoming');

  if ($year) {
    kemke_reports_apply_year_condition($query, $year);
  }

  kemke_reports_apply_incoming_filters($query, $conditions, $state);

  $nids = $query->execute();
  if (empty($nids)) {
    return 0;
  }

  $node_storage = \Drupal::entityTypeManager()->getStorage('node');
  $nodes = $node_storage->loadMultiple($nids);

  $updated = 0;
  foreach ($nodes as $node) {
    if (!$node instanceof NodeInterface) {
      continue;
    }

    $is_on_time = kemke_reports_evaluate_objective_on_time($node, $objective_key);
    $target_value = $is_on_time ? 'yes' : 'no';
    $on_time_field = kemke_reports_get_on_time_field_for_objective($objective_key);
    $current_value = $node->get($on_time_field)->value ?? NULL;

    if ($force_recalculate || $current_value !== $target_value) {
      $node->set($on_time_field, $target_value);
      $node->save();
      $updated++;
    }
  }

  // Report the number of nodes updated for visibility.
  \Drupal::logger('kemke_reports')->notice('On time recalculation updated @count nodes.', ['@count' => $updated]);

  return $updated;
}

/**
 * Counts incoming nodes marked on time for a given year and objective.
 */
function kemke_reports_incoming_get_on_time_for(int $year, array $conditions = ['field_incoming_type' => 'Γνωμοδότηση'], string $state = 'published', string $objective_key = 'objective_1'): int {
  $conditions += ['field_incoming_type' => 'Γνωμοδότηση'];
  $on_time_field = kemke_reports_get_on_time_field_for_objective($objective_key);

  $query = \Drupal::entityTypeManager()
    ->getStorage('node')
    ->getQuery()
    ->accessCheck(FALSE)
    ->condition('type', 'incoming')
    ->condition($on_time_field . '.value', 'yes');

  kemke_reports_apply_year_condition($query, $year);
  kemke_reports_apply_incoming_filters($query, $conditions, $state);

  return (int) $query->count()->execute();
}

/**
 * Adds incoming type, state, and other supported filters to a query.
 */
function kemke_reports_apply_incoming_filters(QueryInterface $query, array $conditions, string $state = 'published'): void {
  $query->condition('field_primary', 1);

  if (isset($conditions['field_incoming_type'])) {
    $tids = kemke_reports_resolve_incoming_type_ids($conditions['field_incoming_type']);
    if (!empty($tids)) {
      $query->condition('field_incoming_type.target_id', $tids, 'IN');
    }
  }

  if (array_key_exists('field_incoming_subtype', $conditions)) {
    $subtype_condition = $conditions['field_incoming_subtype'];
    if (is_array($subtype_condition)) {
      $operator = $subtype_condition['operator'] ?? '=';
      $value = $subtype_condition['value'] ?? 0;
      $include_null = (bool) ($subtype_condition['include_null'] ?? FALSE);
      if ($include_null && $operator === '<>') {
        $group = $query->orConditionGroup()
          ->condition('field_incoming_subtype.target_id', (int) $value, $operator)
          ->notExists('field_incoming_subtype');
        $query->condition($group);
      }
      else {
        $query->condition('field_incoming_subtype.target_id', (int) $value, $operator);
      }
    }
    else {
      $query->condition('field_incoming_subtype.target_id', (int) $subtype_condition);
    }
  }

  foreach (['field_on_time_obj1.value', 'field_on_time_obj2.value', 'field_on_time_obj3.value', 'field_on_time_obj5.value'] as $on_time_condition_key) {
    if (array_key_exists($on_time_condition_key, $conditions)) {
      $query->condition($on_time_condition_key, $conditions[$on_time_condition_key]);
    }
  }

  if (array_key_exists('field_signature_rejection', $conditions)) {
    $signature_condition = $conditions['field_signature_rejection'];
    if (is_array($signature_condition)) {
      $operator = $signature_condition['operator'] ?? '=';
      $value = $signature_condition['value'] ?? '';
      $query->condition('field_signature_rejection', $value, $operator);
    }
    else {
      $query->condition('field_signature_rejection', $signature_condition);
    }
  }

  if (!empty($conditions['required_non_empty_fields']) && is_array($conditions['required_non_empty_fields'])) {
    foreach ($conditions['required_non_empty_fields'] as $required_field) {
      if (!is_string($required_field) || $required_field === '') {
        continue;
      }
      $query->exists($required_field);
    }
  }

  if ($state !== '') {
    $definitions = \Drupal::service('entity_field.manager')->getFieldStorageDefinitions('node');
    if (isset($definitions['moderation_state'])) {
      $query->condition('moderation_state', $state);
    }
    if ($state === 'published') {
      // Ensure only published nodes are included.
      $query->condition('status', 1);
    }
  }
}

/**
 * Returns the on-time field name used for the given objective.
 */
function kemke_reports_get_on_time_field_for_objective(string $objective_key): string {
  return match ($objective_key) {
    'objective_1' => 'field_on_time_obj1',
    'objective_2' => 'field_on_time_obj2',
    'objective_3' => 'field_on_time_obj3',
    'objective_5' => 'field_on_time_obj5',
    default => 'field_on_time_obj5',
  };
}

function kemke_reports_get_objective_calculation_definition(string $objective_key): array {
  return match ($objective_key) {
    'objective_1' => [
      'filters' => [
        'field_incoming_type' => 'Γνωμοδότηση',
        'required_non_empty_fields' => ['field_completion_date'],
        'field_incoming_subtype' => [
          'operator' => '<>',
          'value' => 60, // Όχι Αίτημα από ιεραρχία
          'include_null' => TRUE,
        ],
      ],
      'on_time_field' => kemke_reports_get_on_time_field_for_objective('objective_1'),
      'calculation' => [
        'mode' => 'deadline',
        // Needed only when `config_days` entries are enabled in `deadline_fields`
        // (e.g. `deadline_days_for_report` / `deadline_days_default`).
        // 'start_date_field' => ['field_fullness_check_date'],
        'completion_fields' => ['field_completion_date'],
        'comparison' => '<=',
        'deadline_fields' => [
          // Optional: use configured days from start date.
          // Uncomment to include in on-time calculation order.
          // ['config_days' => 'deadline_days_for_report'],

          // If extension is enabled, use the extension legal deadline.
          // [
          //   'field' => 'field_extension_date',
          //   'requires' => 'field_extension',
          // ],
          // Otherwise use the regular legal deadline field.
          [
            'field' => 'field_legal_deadline',
          ],
          // Optional fallback: default configured days from start date.
          // ['config_days' => 'deadline_days_default'],
        ],
      ],
    ],
    'objective_2' => [
      'filters' => [
        'field_incoming_type' => ['Άποψη', 'Γνωμοδότηση'],
        'required_non_empty_fields' => ['field_completion_date'],
        'field_incoming_subtype' => 60, // Αίτημα από ιεραρχία
      ],
      'on_time_field' => kemke_reports_get_on_time_field_for_objective('objective_2'),
      'calculation' => [
        'mode' => 'deadline',
        'completion_fields' => ['field_completion_date'],
        'comparison' => '<=',
        'deadline_fields' => [
          [
            'field' => 'field_legal_deadline',
          ],
        ],
      ],
    ],
    'objective_3' => [
      'filters' => [
        'field_incoming_type' => ['Γνωστοποίηση', 'Κοινοποίηση'],
        'required_non_empty_fields' => ['field_signature_rejection_date'],
        'field_signature_rejection' => [
          'operator' => '<>',
          'value' => '',
        ],
      ],
      'on_time_field' => kemke_reports_get_on_time_field_for_objective('objective_3'),
      'calculation' => [
        'mode' => 'deadline',
        'completion_fields' => ['field_signature_rejection_date'],
        'comparison' => '<=',
        'deadline_fields' => [
          [
            'field' => 'field_legal_deadline',
          ],
        ],
      ],
    ],
    'objective_4' => [
      'filters' => [
        'field_incoming_type' => ['Επικοινωνία με ΕΕ'],
        'required_non_empty_fields' => ['field_completion_date'],
        'field_incoming_subtype' => 59, // Έκθεση Δαπανών SARI
      ],
      'on_time_field' => NULL,
      'report_expected_documents' => 1,
      'report_fields' => [
        'total' => 'field_total_cases',
        'on_time' => 'field_on_time_cases',
      ],
    ],
    'objective_5' => [
      'filters' => [
        'field_incoming_type' => ['Επικοινωνία με ΕΕ'],
        'required_non_empty_fields' => ['field_completion_date'],
        'field_incoming_subtype' => 61, // Ανάκτηση
      ],
      'on_time_field' => kemke_reports_get_on_time_field_for_objective('objective_5'),
      'calculation' => [
        'mode' => 'deadline',
        'completion_fields' => ['field_completion_date'],
        'comparison' => '<=',
        'deadline_fields' => [
          [
            'field' => 'field_extension_date',
            'requires' => 'field_extension',
          ],
          [
            'field' => 'field_legal_deadline',
          ],
        ],
      ],
    ],
    default => [],
  };
}

/**
 * Returns standardized incoming filters for a report objective.
 */
function kemke_reports_get_objective_filters(string $objective_key): array {
  $definition = kemke_reports_get_objective_calculation_definition($objective_key);
  return $definition['filters'] ?? [];
}

/**
 * Recalculates on-time values for selected objectives and returns update counts.
 *
 * @return array<string, int>
 *   Updated counts keyed by objective key.
 */
function kemke_reports_incoming_recalculate_on_time(array $objective_keys, int $year, bool $force_recalculate = FALSE, bool $only_not_calculated = FALSE, string $state = 'published'): array {
  $updated_by_objective = [];

  foreach (array_unique($objective_keys) as $objective_key) {
    $definition = kemke_reports_get_objective_calculation_definition((string) $objective_key);
    if (empty($definition)) {
      continue;
    }

    $on_time_field = $definition['on_time_field'] ?? NULL;
    if (!$on_time_field) {
      continue;
    }

    $conditions = $definition['filters'] ?? [];
    if ($only_not_calculated) {
      $conditions[$on_time_field . '.value'] = 'not_calculated';
    }

    $updated_by_objective[$objective_key] = kemke_reports_incoming_set_on_time_for(
      $conditions,
      $state,
      $force_recalculate,
      $objective_key,
      $year
    );
  }

  return $updated_by_objective;
}

/**
 * Returns report metrics for objectives that use aggregated report fields.
 *
 * @return array{
 *   ids: array,
 *   found_count: int,
 *   expected_count: int,
 *   total: int,
 *   on_time: int,
 *   percentage: float
 * }
 */
function kemke_reports_get_objective_report_metrics(int $year, string $objective_key, string $state = 'published'): array {
  $definition = kemke_reports_get_objective_calculation_definition($objective_key);
  $filters = $definition['filters'] ?? [];
  $ids = kemke_reports_incoming_get_ids_for($year, $filters, $state);
  $found_count = count($ids);
  $expected_count = (int) ($definition['report_expected_documents'] ?? 0);

  $result = [
    'ids' => $ids,
    'found_count' => $found_count,
    'expected_count' => $expected_count,
    'total' => 0,
    'on_time' => 0,
    'percentage' => 0.0,
  ];

  $report_fields = $definition['report_fields'] ?? [];
  if (empty($report_fields) || !is_array($report_fields)) {
    return $result;
  }

  if ($expected_count > 0 && $found_count !== $expected_count) {
    return $result;
  }

  if ($found_count === 0) {
    return $result;
  }

  $node = \Drupal::entityTypeManager()->getStorage('node')->load((int) reset($ids));
  if (!$node instanceof NodeInterface) {
    return $result;
  }

  $total_field = (string) ($report_fields['total'] ?? '');
  $on_time_field = (string) ($report_fields['on_time'] ?? '');
  if ($total_field === '' || $on_time_field === '') {
    return $result;
  }

  $result['on_time'] = (int) ($node->get($on_time_field)->value ?? 0);
  $result['total'] = (int) ($node->get($total_field)->value ?? 0);
  if ($result['total'] > 0 && $result['on_time'] > 0) {
    $result['percentage'] = ($result['on_time'] / $result['total']) * 100;
  }

  return $result;
}

/**
 * Returns objective metrics for both node-level and report-field objectives.
 *
 * @return array{
 *   ids: array,
 *   on_time_ids: array,
 *   found_count: int,
 *   expected_count: int,
 *   total: int,
 *   on_time: int,
 *   percentage: float
 * }
 */
function kemke_reports_get_objective_metrics(int $year, string $objective_key, string $state = 'published'): array {
  $definition = kemke_reports_get_objective_calculation_definition($objective_key);
  $filters = $definition['filters'] ?? [];
  $on_time_field = (string) ($definition['on_time_field'] ?? '');
  $expected_count = (int) ($definition['report_expected_documents'] ?? 0);

  $result = [
    'ids' => [],
    'on_time_ids' => [],
    'found_count' => 0,
    'expected_count' => $expected_count,
    'total' => 0,
    'on_time' => 0,
    'percentage' => 0.0,
  ];

  if (!empty($definition['report_fields']) && is_array($definition['report_fields'])) {
    $report = kemke_reports_get_objective_report_metrics($year, $objective_key, $state);
    $result['ids'] = $report['ids'];
    $result['found_count'] = (int) $report['found_count'];
    $result['expected_count'] = (int) $report['expected_count'];
    $result['total'] = (int) $report['total'];
    $result['on_time'] = (int) $report['on_time'];
    $result['percentage'] = (float) $report['percentage'];
    return $result;
  }

  $result['ids'] = kemke_reports_incoming_get_ids_for($year, $filters, $state);
  $result['found_count'] = count($result['ids']);
  $result['total'] = kemke_reports_incoming_get_number_for($year, $filters, $state);

  if ($on_time_field !== '') {
    $result['on_time'] = kemke_reports_incoming_get_on_time_for($year, $filters, $state, $objective_key);
    $result['on_time_ids'] = kemke_reports_incoming_get_ids_for($year, $filters + [$on_time_field . '.value' => 'yes'], $state);
  }

  if ($result['total'] > 0) {
    $result['percentage'] = ($result['on_time'] / $result['total']) * 100;
  }

  return $result;
}

/**
 * Adds year boundaries to an entity query.
 */
function kemke_reports_apply_year_condition(QueryInterface $query, int $year): void {
  $start = new DrupalDateTime("$year-01-01 00:00:00", new \DateTimeZone(DateTimeItemInterface::STORAGE_TIMEZONE));
  $end = clone $start;
  $end->modify('+1 year');

  $query->condition(
    'field_entry_date.value',
    [
      $start->format(DateTimeItemInterface::DATE_STORAGE_FORMAT),
      $end->format(DateTimeItemInterface::DATE_STORAGE_FORMAT),
    ],
    'BETWEEN'
  );
}

/**
 * Resolves incoming type names or IDs to taxonomy term IDs.
 *
 * @param string|int|array $value
 *   The provided value(s), e.g. 'Γνωμοδότηση'.
 *
 * @return array
 *   An array of taxonomy term IDs.
 */
function kemke_reports_resolve_incoming_type_ids($value): array {
  $values = is_array($value) ? $value : [$value];
  $tids = [];

  foreach ($values as $item) {
    if (is_numeric($item)) {
      $tids[] = (int) $item;
      continue;
    }

    $terms = \Drupal::entityTypeManager()
      ->getStorage('taxonomy_term')
      ->loadByProperties([
        'name' => $item,
        'vid' => 'incoming_type',
      ]);

    foreach ($terms as $term) {
      $tids[] = (int) $term->id();
    }
  }

  return array_values(array_unique($tids));
}

/**
 * Evaluates if a node is on time based on objective calculation definition.
 */
function kemke_reports_evaluate_objective_on_time(NodeInterface $node, string $objective_key): bool {
  $definition = kemke_reports_get_objective_calculation_definition($objective_key);
  if (empty($definition['calculation']) || !is_array($definition['calculation'])) {
    return FALSE;
  }

  $calculation = $definition['calculation'];

  $completion_fields = (array) ($calculation['completion_fields'] ?? []);
  if (empty($completion_fields)) {
    return FALSE;
  }

  $completion = kemke_reports_get_first_date_from_ordered_fields($node, $completion_fields);
  if (!$completion) {
    return FALSE;
  }

  if (($calculation['mode'] ?? 'deadline') === 'after_completion') {
    foreach ((array) ($calculation['checks'] ?? []) as $source) {
      if (!is_array($source)) {
        continue;
      }

      if (!kemke_reports_node_meets_requirement($node, (string) ($source['requires'] ?? ''))) {
        continue;
      }

      $field = (string) ($source['field'] ?? '');
      if ($field === '') {
        continue;
      }

      $candidate = kemke_reports_get_first_date_value($node, $field);
      if (!$candidate) {
        continue;
      }

      $comparison = (string) ($source['comparison'] ?? '>');
      if (kemke_reports_compare_dates($candidate, $completion, $comparison)) {
        return TRUE;
      }
    }

    return FALSE;
  }

  $deadline = kemke_reports_resolve_deadline_from_definition($node, $objective_key, $calculation);
  if (!$deadline) {
    return FALSE;
  }

  return kemke_reports_compare_dates(
    $completion,
    $deadline,
    (string) ($calculation['comparison'] ?? '<=')
  );
}

/**
 * Resolves objective deadline using configured source priority.
 */
function kemke_reports_resolve_deadline_from_definition(NodeInterface $node, string $objective_key, array $calculation): ?DrupalDateTime {
  $config = \Drupal::config('kemke_reports.settings');
  foreach ((array) ($calculation['deadline_fields'] ?? []) as $source) {
    $source_definition = is_string($source) ? ['field' => $source] : (is_array($source) ? $source : []);
    if (empty($source_definition)) {
      continue;
    }

    if (!kemke_reports_node_meets_requirement($node, (string) ($source_definition['requires'] ?? ''))) {
      continue;
    }

    if (!empty($source_definition['field'])) {
      $deadline = kemke_reports_get_first_date_value($node, (string) $source_definition['field']);
      if ($deadline) {
        return $deadline;
      }
      continue;
    }

    if (!empty($source_definition['config_days'])) {
      $deadline = kemke_reports_get_deadline_from_config_days(
        $node,
        $config,
        $objective_key,
        (string) $source_definition['config_days'],
        (array) ($source_definition['start_date_field'] ?? $calculation['start_date_field'] ?? [])
      );
      if ($deadline) {
        return $deadline;
      }
    }
  }

  return NULL;
}

/**
 * Builds a deadline from configured day offset and start date fields.
 */
function kemke_reports_get_deadline_from_config_days(NodeInterface $node, \Drupal\Core\Config\ImmutableConfig $config, string $objective_key, string $config_key, array $start_fields): ?DrupalDateTime {
  $days = (int) ($config->get($objective_key . '.' . $config_key) ?? 0);
  if ($days <= 0) {
    return NULL;
  }

  $start_date = kemke_reports_get_first_date_from_ordered_fields($node, $start_fields);
  if (!$start_date) {
    return NULL;
  }

  return greek_holidays_calculate_date_after($start_date, $days);
}

/**
 * Checks whether a node satisfies a calculation requirement.
 */
function kemke_reports_node_meets_requirement(NodeInterface $node, string $requirement): bool {
  if ($requirement === '') {
    return TRUE;
  }

  if (!$node->hasField($requirement) || $node->get($requirement)->isEmpty()) {
    return FALSE;
  }

  $item = $node->get($requirement)->first();
  if (!$item) {
    return FALSE;
  }

  $values = $item->getValue();
  $value = $values['value'] ?? $values['target_id'] ?? NULL;
  if ($value === NULL) {
    return FALSE;
  }

  return !in_array((string) $value, ['', '0'], TRUE);
}

/**
 * Returns first valid date from ordered fields.
 */
function kemke_reports_get_first_date_from_ordered_fields(NodeInterface $node, array $fields): ?DrupalDateTime {
  foreach ($fields as $field) {
    if (!is_string($field) || $field === '') {
      continue;
    }

    $date = kemke_reports_get_first_date_value($node, $field);
    if ($date) {
      return $date;
    }
  }

  return NULL;
}

/**
 * Compares two dates using a supported operator.
 */
function kemke_reports_compare_dates(DrupalDateTime $left, DrupalDateTime $right, string $operator): bool {
  $left_ts = $left->getTimestamp();
  $right_ts = $right->getTimestamp();

  return match ($operator) {
    '<' => $left_ts < $right_ts,
    '<=' => $left_ts <= $right_ts,
    '>' => $left_ts > $right_ts,
    '>=' => $left_ts >= $right_ts,
    '=' => $left_ts === $right_ts,
    default => FALSE,
  };
}

/**
 * Extracts a date value from a node field.
 */
function kemke_reports_get_first_date_value(NodeInterface $node, string $field_name): ?DrupalDateTime {
  if (!$node->hasField($field_name) || $node->get($field_name)->isEmpty()) {
    return NULL;
  }

  $item = $node->get($field_name)->first();
  if (!$item) {
    return NULL;
  }

  $value = $item->getValue()['value'] ?? NULL;
  if (!$value) {
    return NULL;
  }

  try {
    return DrupalDateTime::createFromFormat(DateTimeItemInterface::DATE_STORAGE_FORMAT, $value, new \DateTimeZone(DateTimeItemInterface::STORAGE_TIMEZONE));
  }
  catch (\Exception $exception) {
    return NULL;
  }
}

/**
 * Resolves objective key for an incoming node using report objective filters.
 */
function kemke_reports_get_objective_key_for_incoming(NodeInterface $node): string {
  $incoming_type_name = '';
  if ($node->hasField('field_incoming_type') && !$node->get('field_incoming_type')->isEmpty()) {
    $type_tid = (int) ($node->get('field_incoming_type')->target_id ?? 0);
    if ($type_tid > 0) {
      $term = \Drupal::entityTypeManager()->getStorage('taxonomy_term')->load($type_tid);
      $incoming_type_name = $term ? trim((string) $term->label()) : '';
    }
  }

  $subtype_tid = (int) ($node->get('field_incoming_subtype')->target_id ?? 0);

  if (in_array($incoming_type_name, ['Άποψη', 'Γνωμοδότηση'], TRUE) && $subtype_tid === 60) {
    return 'objective_2';
  }

  if (in_array($incoming_type_name, ['Γνωστοποίηση', 'Κοινοποίηση'], TRUE)) {
    return 'objective_3';
  }

  return 'objective_1';
}

/**
 * Returns default deadline days from matched objective, fallback objective_1.
 */
function kemke_reports_get_deadline_days_default_for_incoming(NodeInterface $node): int {
  $config = \Drupal::config('kemke_reports.settings');
  $objective_key = kemke_reports_get_objective_key_for_incoming($node);
  $objective_days = (int) ($config->get($objective_key . '.deadline_days_default') ?? 0);

  if ($objective_days > 0) {
    return $objective_days;
  }

  $fallback_days = (int) ($config->get('objective_1.deadline_days_default') ?? 20);
  return $fallback_days > 0 ? $fallback_days : 20;
}

/**
 * Calculates seminar attendance stats for users in a given year.
 */
function kemke_reports_get_seminar_users_for_year(int $year, array $excluded_roles = ['kemke_admin', 'amke_user']): array {
  $user_storage = \Drupal::entityTypeManager()->getStorage('user');
  $uids = $user_storage->getQuery()
    ->accessCheck(FALSE)
    ->condition('uid', 0, '>')
    ->execute();

  if (empty($uids)) {
    return [
      'total' => 0,
      'with_seminar' => 0,
      'with_seminar_uids' => [],
    ];
  }

  $year_start = new DrupalDateTime("$year-01-01 00:00:00", new \DateTimeZone(DateTimeItemInterface::STORAGE_TIMEZONE));
  $year_end = clone $year_start;
  $year_end->modify('+1 year');
  $year_start_ts = $year_start->getTimestamp();
  $year_end_ts = $year_end->getTimestamp();

  $total = 0;
  $with_seminar = 0;
  $with_seminar_uids = [];

  foreach ($user_storage->loadMultiple($uids) as $user) {
    if (!$user instanceof UserInterface) {
      continue;
    }

    if (array_intersect($excluded_roles, $user->getRoles())) {
      continue;
    }

    if ($user->hasField('field_temporary_disabled') && !$user->get('field_temporary_disabled')->isEmpty()) {
      $temporarily_disabled = (string) $user->get('field_temporary_disabled')->value;
      if ($temporarily_disabled === '1') {
        continue;
      }
    }

    $total++;

    if (!$user->hasField('field_absenses_ref') || $user->get('field_absenses_ref')->isEmpty()) {
      continue;
    }

    $found = FALSE;
    foreach ($user->get('field_absenses_ref')->referencedEntities() as $paragraph) {
      if (!$paragraph instanceof ParagraphInterface) {
        continue;
      }

      $type_value = $paragraph->get('field_type')->value ?? NULL;
      if ($type_value !== 'seminar') {
        continue;
      }

      if (!$paragraph->hasField('field_dates') || $paragraph->get('field_dates')->isEmpty()) {
        continue;
      }

      foreach ($paragraph->get('field_dates') as $date_item) {
        $values = $date_item->getValue();
        $start_value = $values['value'] ?? NULL;
        $end_value = $values['end_value'] ?? NULL;

        if (!$start_value) {
          continue;
        }

        $start_date = DrupalDateTime::createFromFormat(DateTimeItemInterface::DATE_STORAGE_FORMAT, $start_value, new \DateTimeZone(DateTimeItemInterface::STORAGE_TIMEZONE));
        if (!$start_date) {
          continue;
        }

        $end_date = NULL;
        if ($end_value) {
          $end_date = DrupalDateTime::createFromFormat(DateTimeItemInterface::DATE_STORAGE_FORMAT, $end_value, new \DateTimeZone(DateTimeItemInterface::STORAGE_TIMEZONE));
        }

        $start_ts = $start_date->getTimestamp();
        $end_ts = $end_date ? $end_date->getTimestamp() : $start_ts;

        if ($start_ts < $year_end_ts && $end_ts >= $year_start_ts) {
          $found = TRUE;
          break;
        }
      }

      if ($found) {
        break;
      }
    }

    if ($found) {
      $with_seminar++;
      $with_seminar_uids[] = (int) $user->id();
    }
  }

  $with_seminar_uids = array_values(array_unique($with_seminar_uids));
  sort($with_seminar_uids);

  return [
    'total' => $total,
    'with_seminar' => $with_seminar,
    'with_seminar_uids' => $with_seminar_uids,
  ];
}

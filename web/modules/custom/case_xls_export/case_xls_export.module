<?php

/**
 * @file
 * Hooks for the Case XLS export module.
 */

use Drupal\views\ViewExecutable;

/**
 * Implements hook_views_data_alter().
 */
function case_xls_export_views_data_alter(array &$data): void {
  $data['taxonomy_term_field_data']['case_parent_chain'] = [
    'title' => t('Case parent chain'),
    'help' => t('Shows the full case path for each parent branch.'),
    'field' => [
      'id' => 'case_parent_chain',
    ],
  ];
}

/**
 * Implements hook_views_pre_render().
 */
function case_xls_export_views_pre_render(ViewExecutable $view): void {
  if ($view->id() !== 'cases') {
    return;
  }

  if (!str_starts_with((string) $view->current_display, 'data_export')) {
    return;
  }

  if (!isset($view->field['field_ref_id'])) {
    return;
  }

  $view->field['field_ref_id']->options['label'] = 'Case ID';
}

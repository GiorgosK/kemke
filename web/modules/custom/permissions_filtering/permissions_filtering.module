<?php

use Drupal\Core\Form\FormStateInterface;
use Drupal\user\Entity\Role;

/**
 * Implements hook_form_FORM_ID_alter() for user_admin_permissions.
 */
function permissions_filtering_form_user_admin_permissions_alter(array &$form, FormStateInterface $form_state, string $form_id): void {
  $current_user = \Drupal::currentUser();
  if (in_array('administrator', $current_user->getRoles(), TRUE)) {
    return;
  }

  // Users with this permission see full sets, but still respect hidden columns/rows.
  $skip_filtered_sets = $current_user->hasPermission('see all permission sets');

  $permission_handler = \Drupal::service('user.permissions');
  $module_handler = \Drupal::moduleHandler();
  $module_extension_list = \Drupal::service('extension.list.module');

  // Custom labels for permission groupings (display only, no t() translations).
  $permission_group_label_overrides = [
    'Taxonomy' => 'Κατηγορίες',
    'Activities' => 'Ιστορικό χρηστών',
    'Activities Mods' => 'Ιστορικό',
    'Content Moderation' => 'Καταστάσεις και ματαβάσεις καταστάσεων εγγράφων',
    'Incoming change state' => 'Αλλαγή κατάστασης εγγράφου',
    'Kemke Reports' => 'Αναφορές ΚΕΜΚΕ',
    'Node' => 'Εγγραφα',
    'User' => 'Χρήστες',
  ];

  // Custom labels for individual permissions (display only, no t() translations).
  $permission_label_overrides = [
    // Provider machine name => permission machine name => label.
    'content_moderation' => [
      'use incoming_processing transition completed' => 'Χρήση Ολοκληρωμένο',
      'use incoming_processing transition for_signature' => 'Χρήση Εγκεκριμένο – Αποστολή στο ΣΗΔΕ προς υπογραφή',
      'use incoming_processing transition fullness_approved' => 'Χρήση Ολοκλήρωση πληρότητας φακέλου',
      'use incoming_processing transition fullness_check' => 'Χρήση Χρέωση',
      'use incoming_processing transition issues_to_check' => 'Χρήση Προς ΚΕΜΚΕ',
      'use incoming_processing transition pending_issues' => 'Χρήση Αποστολή προς ΑΜΚΕ',
      'use incoming_processing transition stay_draft' => 'Χρήση Αποθήκευσης σε κατάσταση Προς χρέωση.',
      'use incoming_processing transition stay_for_signature' => 'Χρήση Αποθήκευσης σε κατάσταση Εγκεκριμένο – Αποστολή στο ΣΗΔΕ προς υπογραφή.',
      'use incoming_processing transition stay_fullness_check' => 'Χρήση Αποθήκευσης σε κατάσταση Έλεγχος πληρότητας.',
      'use incoming_processing transition stay_pending_issues' => 'Χρήση Αποθήκευσης σε κατάσταση Με εκκρεμότητες.',
      'use incoming_processing transition stay_published' => 'Χρήση Αποθήκευσης σε κατάσταση Ολοκληρωμένο.',
      'use incoming_processing transition stay_under_processing' => 'Χρήση Αποθήκευσης σε κατάσταση Υπό επεξεργασία.',
    ],
  ];

  // remove permission sets
  $filtered_permission_sets = [
    //'Activities',
    'Block',
    'Block Content',
    'Configuration Manager',
    'Contextual Links',
    'Custom permissions access',
    'Entity Browser',
    'Entity Reference Revisions',
    'Field Permissions',
    'Field UI',
    'File',
    'Filter',
    'Greek Holidays',
    'Image',
    'Incoming API',
    'Interface Translation',
    'Language',
    'Node view permissions',
    'Opinion Reference ID Tweaks',
    'Paragraphs',
    'Password Policy',
    'Path',
    'Permissions filtering',
    'Read-only Admin Simulator',
    'RESTful Web Services',
    'Role Delegation',
    'Search',
    'Serialization (Excel)',
    'Shortcut',
    'System',
    'Toolbar',
    'Views UI',
    'Views Bulk Edit',
    'Workflows',
  ];
  
  // remove
  $filtered_permissions = [
    // Provider machine name => permission machine names.
    'activities' => [
      'purge activities',
      'administer users activity',
    ],
    'user' => [
      'access user profiles',
      'administer account settings',
      'select account cancellation method',
      'administer permissions',
      // 'administer users',
      'cancel account',
      'change own username',
      'view user email addresses',
    ],
    // Content Moderation (plus dynamic transition permissions from workflows).
    'content_moderation' => [
      'view any unpublished content',
      'view latest version',
      // 'use incoming_processing transition completed',
      // 'use incoming_processing transition for_signature',
      // 'use incoming_processing transition fullness_approved',
      // 'use incoming_processing transition fullness_check',
      // 'use incoming_processing transition issues_to_check',
      // 'use incoming_processing transition pending_issues',
      // 'use incoming_processing transition stay_draft',
      // 'use incoming_processing transition stay_for_signature',
      // 'use incoming_processing transition stay_fullness_check',
      // 'use incoming_processing transition stay_pending_issues',
      'use incoming_processing transition stay_published',
      // 'use incoming_processing transition stay_under_processing',
    ],
    // Taxonomy (plus dynamic vocabulary permissions).
    'taxonomy' => [
      'administer taxonomy',
      // 'access taxonomy overview',
      'revert all taxonomy revisions',
      'delete all taxonomy revisions',
      'view all taxonomy revisions',
      'view vocabulary labels',
      // 'create terms in case',
      // 'create terms in incoming_subtype',
      // 'create terms in incoming_type',
      // 'create terms in legal_entity',
      // 'create terms in priority',
      // 'create terms in tags',
      'delete term revisions in case',
      'delete term revisions in incoming_subtype',
      'delete term revisions in incoming_type',
      'delete term revisions in legal_entity',
      'delete term revisions in priority',
      'delete term revisions in tags',
      'delete terms in case',
      'delete terms in incoming_subtype',
      'delete terms in incoming_type',
      'delete terms in legal_entity',
      'delete terms in priority',
      'delete terms in tags',
      // 'edit terms in case',
      // 'edit terms in incoming_subtype',
      // 'edit terms in incoming_type',
      // 'edit terms in legal_entity',
      // 'edit terms in priority',
      // 'edit terms in tags',
      'revert term revisions in case',
      'revert term revisions in incoming_subtype',
      'revert term revisions in incoming_type',
      'revert term revisions in legal_entity',
      'revert term revisions in priority',
      'revert term revisions in tags',
      'view term revisions in case',
      'view term revisions in incoming_subtype',
      'view term revisions in incoming_type',
      'view term revisions in legal_entity',
      'view term revisions in priority',
      'view term revisions in tags',
    ],
    // Node (plus dynamic content type permissions).
    'node' => [
      'access content',
      'bypass node access',
      'administer content types',
      'administer nodes',
      'access content overview',
      'view own unpublished content',
      // 'view all revisions',
      'revert all revisions',
      'delete all revisions',
      'create incoming content',
      'create page content',
      'delete any incoming content',
      'delete any page content',
      'delete incoming revisions',
      'delete own incoming content',
      'delete own page content',
      'delete page revisions',
      'edit any incoming content',
      'edit any page content',
      'edit own incoming content',
      'edit own page content',
      'revert incoming revisions',
      'revert page revisions',
      'view incoming revisions',
      'view page revisions',
    ],
    'node_view_permissions' => [
      // 'view any incoming content',
      'view any page content',
      // 'view own incoming content',
      'view own page content',
    ],
  ];

  // Group permissions by their provider to mirror core's rendering.
  $permissions = $permission_handler->getPermissions();
  $permissions_by_provider = [];
  foreach ($permissions as $permission_name => $definition) {
    $permissions_by_provider[$definition['provider']][$permission_name] = $definition;
  }

  $permission_label_overrides_flat = [];
  foreach ($permission_label_overrides as $provider_id => $permission_labels) {
    foreach ($permission_labels as $permission_name => $label) {
      $permission_label_overrides_flat[$permission_name] = $label;
    }
  }

  $provider_by_label = [];
  foreach (array_keys($permissions_by_provider) as $provider) {
    $provider_by_label[$module_extension_list->getName($provider)] = $provider;
  }

  // Keep provider grouping identical to the core form.
  if ($module_handler->moduleExists('node') && isset($permissions_by_provider['system']['access content'])) {
    $keys = array_keys($permissions_by_provider['node']);
    $offset = (int) array_search('view own unpublished content', $keys);
    $permissions_by_provider['node'] = array_merge(
      array_slice($permissions_by_provider['node'], 0, $offset),
      ['access content' => $permissions_by_provider['system']['access content']],
      array_slice($permissions_by_provider['node'], $offset)
    );
    unset($permissions_by_provider['system']['access content']);
  }

  if (!$skip_filtered_sets) {
    // Remove entire permission sections provided by filtered modules.
    foreach ($permissions_by_provider as $provider => $provider_permissions) {
      $provider_label = $module_extension_list->getName($provider);
      if (in_array($provider_label, $filtered_permission_sets, TRUE)) {
        $module_key = 'module_' . $provider;
        if (isset($form['permissions'][$module_key])) {
          unset($form['permissions'][$module_key]);
        }
        foreach ($provider_permissions as $permission_name => $definition) {
          if (isset($form['permissions'][$permission_name])) {
            unset($form['permissions'][$permission_name]);
          }
        }
      }
    }

    // Remove individual permissions by provider and machine name.
    foreach ($filtered_permissions as $provider_id => $permission_names) {
      if (empty($permissions_by_provider[$provider_id])) {
        continue;
      }
      foreach ($permission_names as $permission_name) {
        if (isset($form['permissions'][$permission_name])) {
          unset($form['permissions'][$permission_name]);
        }
      }
    }
  }

  // Replace permission group titles with custom labels when present.
  foreach ($permission_group_label_overrides as $provider_label => $replacement_label) {
    if (!isset($provider_by_label[$provider_label])) {
      continue;
    }
    $module_key = 'module_' . $provider_by_label[$provider_label];
    if (isset($form['permissions'][$module_key][0]['#markup'])) {
      $form['permissions'][$module_key][0]['#markup'] = $replacement_label;
    }
  }

  // Replace permission titles with custom labels when present.
  foreach ($permission_label_overrides_flat as $permission_name => $replacement_label) {
    if (!isset($form['permissions'][$permission_name]['description']['#context']['title'])) {
      continue;
    }
    $form['permissions'][$permission_name]['description']['#context']['title'] = $replacement_label;
  }

  // Always remove specific permission rows regardless of viewer.
  if (!empty($filtered_permissions['user'])) {
    foreach ($filtered_permissions['user'] as $permission_name) {
      if (isset($form['permissions'][$permission_name])) {
        unset($form['permissions'][$permission_name]);
      }
    }
  }

  // Hide permission checkboxes for administrator role(s).
  $roles_to_hide = ['administrator','kemke_admin_readonly','anonymous','api'];
  $role_labels = [];
  foreach ($roles_to_hide as $role_id) {
    $role = Role::load($role_id);
    if ($role) {
      $role_labels[$role_id] = $role->label();
    }
  }

  if (isset($form['permissions']) && is_array($form['permissions'])) {
    // Force compact mode on so descriptions stay hidden.
    user_cookie_save(['admin_compact_mode' => TRUE]);
    // Hide the compact toggle link.
    if (isset($form['system_compact_link'])) {
      $form['system_compact_link']['#access'] = FALSE;
    }
    if (isset($form['permissions']['#header']) && is_array($form['permissions']['#header'])) {
      foreach ($roles_to_hide as $role_id) {
        if (isset($form['permissions']['#header'][$role_id])) {
          unset($form['permissions']['#header'][$role_id]);
        }
      }
      foreach ($form['permissions']['#header'] as $header_key => $header_value) {
        if (is_array($header_value) && isset($header_value['data']) && in_array($header_value['data'], $role_labels, TRUE)) {
          unset($form['permissions']['#header'][$header_key]);
        }
      }
    }

    if (isset($form['permissions']['#roles']) && is_array($form['permissions']['#roles'])) {
      foreach ($roles_to_hide as $role_id) {
        unset($form['permissions']['#roles'][$role_id]);
      }
    }

    foreach ($form['permissions'] as $permission_name => &$permission_row) {
      if (!is_array($permission_row) || (is_string($permission_name) && str_starts_with($permission_name, '#'))) {
        continue;
      }
      if (isset($permission_row['description']['#context']['description'])) {
        unset($permission_row['description']['#context']['description']);
      }
      if (isset($permission_row['description']['#context']['warning'])) {
        unset($permission_row['description']['#context']['warning']);
      }
      foreach ($roles_to_hide as $role_id) {
        if (isset($permission_row[$role_id])) {
          unset($permission_row[$role_id]);
        }
      }
    }
    unset($permission_row);
  }
}

<?php

use Drupal\node\NodeInterface;
use Drupal\Core\Entity\EntityInterface;
use Drupal\paragraphs\ParagraphInterface;
use Drupal\taxonomy\TermInterface;
use Drupal\user\UserInterface;

/**
 * Implements hook_module_implements_alter().
 */
function incoming_notifications_module_implements_alter(array &$implementations, string $hook): void {
  if (!in_array($hook, ['node_update', 'node_insert'], TRUE)) {
    return;
  }

  if (isset($implementations['incoming_notifications'])) {
    $weight = $implementations['incoming_notifications'];
    unset($implementations['incoming_notifications']);
    $implementations['incoming_notifications'] = $weight;
  }
}

/**
 * Implements hook_entity_presave().
 *
 * Kept as a no-op to avoid cached hook listeners calling a missing function.
 */
function incoming_notifications_entity_presave(EntityInterface $entity): void {
  // Intentionally empty.
}

/**
 * Implements hook_ENTITY_TYPE_insert() for nodes.
 */
function incoming_notifications_node_insert(NodeInterface $node): void {
  if ($node->bundle() !== 'incoming') {
    return;
  }

  $original_state = NULL;
  incoming_notifications_handle_state_change($node, $original_state);
}

/**
 * Implements hook_ENTITY_TYPE_update() for nodes.
 */
function incoming_notifications_node_update(NodeInterface $node): void {
  if ($node->bundle() !== 'incoming') {
    return;
  }

  $original_state = NULL;
  if ($node->original instanceof NodeInterface && $node->original->hasField('moderation_state')) {
    $original_state = $node->original->get('moderation_state')->value;
  }

  incoming_notifications_handle_state_change($node, $original_state);
}

/**
 * Sends notifications for incoming moderation state transitions.
 */
function incoming_notifications_handle_state_change(NodeInterface $node, ?string $original_state): void {
  $memory = &drupal_static(__FUNCTION__, []);

  if (!$node->hasField('moderation_state') || $node->get('moderation_state')->isEmpty()) {
    return;
  }

  $new_state = $node->get('moderation_state')->value;

  if ((!$new_state) || ($new_state === $original_state && !in_array($new_state, ['pending_issues', 'issues_to_check'], TRUE))) {
    return;
  }

  $dedupe_key = $node->id() . ':' . $new_state;
  if (isset($memory[$dedupe_key])) {
    return;
  }
  $memory[$dedupe_key] = TRUE;

  if ($new_state === 'draft') {
    $recipients = _incoming_notifications_get_users_by_role('secretariat');
    $context = [
      // On initial creation, include initial values (same behavior as /activity).
      'changes_lines' => activities_mods_incoming_build_change_lines($node, NULL, NULL, 'full', TRUE),
    ];
    _incoming_notifications_send_notifications('draft', $node, $recipients, $context);
  }

  if ($new_state === 'to_be_assigned' && $node->hasField('field_supervisor')) {
    $target_id = $node->get('field_supervisor')->target_id;
    $user = $target_id ? \Drupal::entityTypeManager()->getStorage('user')->load($target_id) : NULL;
    if ($user instanceof UserInterface) {
      $context = [
        'changes_lines' => activities_mods_incoming_build_change_lines($node),
      ];
      _incoming_notifications_send_notifications('to_be_assigned', $node, [$user], $context);
    }
  }

  if ($new_state === 'fullness_check' && $node->hasField('field_basic_operator')) {
    $target_id = $node->get('field_basic_operator')->target_id;
    $user = $target_id ? \Drupal::entityTypeManager()->getStorage('user')->load($target_id) : NULL;
    if ($user instanceof UserInterface) {
      $context = [
        'changes_lines' => activities_mods_incoming_build_change_lines($node),
      ];
      _incoming_notifications_send_notifications('fullness_check', $node, [$user], $context);
    }
  }

  if (in_array($new_state, ['pending_issues', 'issues_to_check'], TRUE)) {
    // Pending issues rules are role-sensitive and only use remarks from this save.
    $account = \Drupal::currentUser();
    $current_uid = (int) $account->id();
    // Only consider a remark created in the current save by the current user.
    $remark = _incoming_notifications_get_current_save_remark($node, $current_uid);
    $is_amke_user = $account->hasRole('amke_user');
    $is_state_pair_transition = in_array((string) $original_state, ['pending_issues', 'issues_to_check'], TRUE)
      && $new_state !== (string) $original_state;
    $is_transition_into_issues_states = $new_state !== (string) $original_state;

    if ($is_amke_user) {
      // AMKE users notify basic operator on explicit state-pair transition or new remark.
      if (($remark || $is_state_pair_transition) && $node->hasField('field_basic_operator')) {
        $target_id = $node->get('field_basic_operator')->target_id;
        $user = $target_id ? \Drupal::entityTypeManager()->getStorage('user')->load($target_id) : NULL;
        if ($user instanceof UserInterface) {
          $context = [
            'remark_comment' => $remark ? _incoming_notifications_get_remark_comment($remark) : '',
            'changes_lines' => activities_mods_incoming_build_change_lines($node, NULL, $remark, 'full'),
            'change_remark' => $remark,
          ];
          _incoming_notifications_send_notifications('pending_issues', $node, [$user], $context);
        }
      }
      return;
    }

    // Non-AMKE users: use remark-targeting for new remarks.
    if ($remark) {
      $recipients = _incoming_notifications_get_users_by_legal_entity($remark);
      $context = [
        'remark_comment' => _incoming_notifications_get_remark_comment($remark),
        'changes_lines' => activities_mods_incoming_build_change_lines($node, NULL, $remark, 'full'),
        'change_remark' => $remark,
      ];
    }
    elseif ($is_transition_into_issues_states) {
      // No new remark: notify on explicit state transitions into issues states.
      $recipients = _incoming_notifications_get_users_by_legal_entity($node);
      $context = [
        'changes_lines' => activities_mods_incoming_build_change_lines($node),
      ];
    }
    else {
      // Same-state save without new remark: no notification.
      $recipients = [];
      $context = [];
    }

    _incoming_notifications_send_notifications('pending_issues', $node, $recipients, $context);
  }

  if ($new_state === 'published') {
    $recipients = _incoming_notifications_get_users_by_legal_entity($node);
    $context = [
      'changes_lines' => activities_mods_incoming_build_change_lines($node),
    ];
    _incoming_notifications_send_notifications('published', $node, $recipients, $context);
  }
}

/**
 * Sends notification email and notify_widget messages.
 *
 * @param string $key
 *   The mail key for hook_mail().
 * @param \Drupal\Core\Entity\EntityInterface $entity
 *   The incoming node being processed.
 * @param array $recipients
 *   Array of user entities.
 */
function _incoming_notifications_send_notifications(string $key, EntityInterface $entity, array $recipients, array $context = []): void {
  $recipients = array_filter($recipients);
  if (empty($recipients)) {
    return;
  }

  $mailManager = \Drupal::service('plugin.manager.mail');
  $langcode = $entity->language()->getId();
  $title = trim((string) $entity->label());
  if ($entity instanceof NodeInterface && function_exists('activities_mods_incoming_build_title')) {
    $title = activities_mods_incoming_build_title($entity);
  }
  if ($title === '') {
    $title = t('Χωρίς REF ID');
  }
  $subject_text = $title;
  if ($entity->hasField('field_subject') && !$entity->get('field_subject')->isEmpty()) {
    $raw_subject = trim(strip_tags((string) $entity->get('field_subject')->value));
    if ($raw_subject !== '') {
      $subject_text = $raw_subject;
    }
  }
  $subject_text = incoming_notifications_trim_with_ellipsis($subject_text, 50);
  $incoming_id = $entity->id() ? (string) $entity->id() : t('unassigned');
  $state = $entity->get('moderation_state')->value ?? '';
  $state_label = $state !== '' ? activities_mods_incoming_get_state_label($state, $langcode) : '';
  $remark_comment = isset($context['remark_comment']) ? trim((string) $context['remark_comment']) : '';
  $base_changes_lines = isset($context['changes_lines']) && is_array($context['changes_lines']) ? $context['changes_lines'] : [];
  $change_remark = isset($context['change_remark']) && $context['change_remark'] instanceof ParagraphInterface
    ? $context['change_remark']
    : NULL;

  $notify_service_id = 'notify_widget.api';
  $notify_api = \Drupal::hasService($notify_service_id) ? \Drupal::service($notify_service_id) : NULL;

  foreach ($recipients as $user) {
    if (!$user instanceof UserInterface) {
      continue;
    }

    $delivery = _incoming_notifications_get_user_notification_delivery($user);
    if (!$delivery['email'] && !$delivery['platform']) {
      continue;
    }

    $recipient_lines = $base_changes_lines;
    if ($entity instanceof NodeInterface) {
      try {
        if ($user->hasRole('amke_user')) {
          $recipient_lines = activities_mods_incoming_build_change_lines(
            $entity,
            NULL,
            $change_remark,
            'minimal',
            $key === 'draft'
          );
        }
        elseif (empty($recipient_lines)) {
          $recipient_lines = activities_mods_incoming_build_change_lines(
            $entity,
            NULL,
            $change_remark,
            'full',
            $key === 'draft'
          );
        }
      }
      catch (\Throwable $e) {
        \Drupal::logger('incoming_notifications')->warning('Failed to build changes summary for notification on incoming @nid: @message', [
          '@nid' => (string) $entity->id(),
          '@message' => $e->getMessage(),
        ]);
      }
    }
    $changes_summary_email = activities_mods_incoming_render_change_lines($recipient_lines, FALSE);
    $changes_summary_notify = activities_mods_incoming_render_change_lines($recipient_lines, TRUE);
    $recipient_link_absolute = '';
    $recipient_link_relative = '';
    if ($entity instanceof NodeInterface) {
      [$recipient_link_relative, $recipient_link_absolute] = _incoming_notifications_get_recipient_link($entity, $user);
    }
    else {
      $recipient_link_absolute = $entity->toUrl('edit-form', ['absolute' => TRUE])->toString();
      $recipient_link_relative = $entity->toUrl('edit-form')->toString();
    }

    $params = [
      'incoming_title' => $title,
      'incoming_subject' => $subject_text,
      'incoming_id' => $incoming_id,
      'state_label' => $state_label,
      'incoming_link' => $recipient_link_absolute,
      'remark_comment' => $remark_comment,
      'changes_summary_email' => $changes_summary_email,
      'changes_summary_notify' => $changes_summary_notify,
    ];
    if ($delivery['email'] && $user->getEmail()) {
      $mailManager->mail('incoming_notifications', $key, $user->getEmail(), $langcode, $params, NULL, TRUE);
    }

    if ($delivery['platform'] && $notify_api) {
      $subject = incoming_notifications_build_subject_notify($key, $params);
      $body = incoming_notifications_build_body_notify($key, $params);
      $notify_api->send(
        'incoming_notifications',
        'warning',
        $subject,
        $body,
        (int) $user->id(),
        $recipient_link_relative
      );
    }
  }
}

/**
 * Resolves the best destination URL for a recipient.
 *
 * @return array{0:string,1:string}
 *   Relative and absolute URLs.
 */
function _incoming_notifications_get_recipient_link(NodeInterface $node, UserInterface $user): array {
  $relative = '';
  $absolute = '';

  if ($node->access('update', $user)) {
    $relative = $node->toUrl('edit-form')->toString();
    $absolute = $node->toUrl('edit-form', ['absolute' => TRUE])->toString();
    return [$relative, $absolute];
  }

  if ($node->access('view', $user)) {
    $relative = $node->toUrl('canonical')->toString();
    $absolute = $node->toUrl('canonical', ['absolute' => TRUE])->toString();
    return [$relative, $absolute];
  }

  $relative = $node->toUrl('edit-form')->toString();
  $absolute = $node->toUrl('edit-form', ['absolute' => TRUE])->toString();
  return [$relative, $absolute];
}

/**
 * Resolves which notification channels are enabled for a user.
 *
 * @return array{email: bool, platform: bool}
 *   Enabled channels keyed by delivery type.
 */
function _incoming_notifications_get_user_notification_delivery(UserInterface $user): array {
  // Keep backward-compatible defaults for accounts without the field/value.
  $value = 'all_notifications';
  if ($user->hasField('field_notifications') && !$user->get('field_notifications')->isEmpty()) {
    $value = (string) $user->get('field_notifications')->value;
  }

  switch ($value) {
    case 'no_notifications':
      return ['email' => FALSE, 'platform' => FALSE];

    case 'email_notifications':
      return ['email' => TRUE, 'platform' => FALSE];

    case 'platform_notifications':
      return ['email' => FALSE, 'platform' => TRUE];

    case 'all_notifications':
    default:
      return ['email' => TRUE, 'platform' => TRUE];
  }
}

/**
 * Finds active users for a given role.
 *
 * @param string $role_id
 *   The machine name of the role.
 *
 * @return array
 *   User entities.
 */
function _incoming_notifications_get_users_by_role(string $role_id): array {
  $storage = \Drupal::entityTypeManager()->getStorage('user');
  $users = $storage->loadByProperties([
    'status' => 1,
    'roles' => $role_id,
  ]);

  $users_list = [];
  foreach ($users as $user) {
    if ($user instanceof UserInterface) {
      $users_list[] = $user;
    }
  }

  return $users_list;
}

/**
 * Returns the remark created in the current save by the current user.
 */
function _incoming_notifications_get_current_save_remark(NodeInterface $node, int $current_uid): ?ParagraphInterface {
  if (!$node->hasField('field_remarks') || $node->get('field_remarks')->isEmpty()) {
    return NULL;
  }

  // Capture existing remark IDs to detect only new additions on this save.
  $previous_ids = [];
  if (isset($node->original) && $node->original instanceof NodeInterface && $node->original->hasField('field_remarks')) {
    foreach ($node->original->get('field_remarks')->referencedEntities() as $previous) {
      if ($previous instanceof ParagraphInterface && $previous->id()) {
        $previous_ids[(int) $previous->id()] = TRUE;
      }
    }
  }

  // Among new remarks by the current user, choose the latest by timestamp.
  $latest = NULL;
  $latest_ts = NULL;
  $latest_index = -1;
  foreach ($node->get('field_remarks')->referencedEntities() as $index => $remark) {
    if (!$remark instanceof ParagraphInterface || $remark->bundle() !== 'remark') {
      continue;
    }
    $remark_id = $remark->id() ? (int) $remark->id() : NULL;
    if ($remark_id && isset($previous_ids[$remark_id])) {
      continue;
    }
    if (!$remark->hasField('field_user') || $remark->get('field_user')->isEmpty()) {
      continue;
    }
    $author_id = (int) $remark->get('field_user')->target_id;
    if ($author_id !== $current_uid) {
      continue;
    }

    $timestamp = NULL;
    if ($remark->hasField('field_datetime') && !$remark->get('field_datetime')->isEmpty()) {
      $timestamp = (int) $remark->get('field_datetime')->value;
    }
    elseif (method_exists($remark, 'getCreatedTime')) {
      $timestamp = (int) $remark->getCreatedTime();
    }

    if ($timestamp !== NULL) {
      if ($latest_ts === NULL || $timestamp > $latest_ts) {
        $latest = $remark;
        $latest_ts = $timestamp;
      }
      continue;
    }

    if ($index > $latest_index) {
      $latest = $remark;
      $latest_index = $index;
    }
  }

  return $latest;
}

/**
 * Returns a trimmed remark comment string (empty when missing).
 */
function _incoming_notifications_get_remark_comment(ParagraphInterface $remark): string {
  if (!$remark->hasField('field_comment') || $remark->get('field_comment')->isEmpty()) {
    return '';
  }

  $comment = trim(strip_tags((string) $remark->get('field_comment')->value));
  return incoming_notifications_trim_with_ellipsis($comment, 50);
}

/**
 * Checks whether the incoming node has any remark paragraphs.
 */
function _incoming_notifications_node_has_any_remarks(NodeInterface $node): bool {
  if (!$node->hasField('field_remarks') || $node->get('field_remarks')->isEmpty()) {
    return FALSE;
  }

  foreach ($node->get('field_remarks')->referencedEntities() as $remark) {
    if ($remark instanceof ParagraphInterface && $remark->bundle() === 'remark') {
      return TRUE;
    }
  }

  return FALSE;
}

/**
 * Trims a string to a max length and adds an ellipsis when needed.
 */
function incoming_notifications_trim_with_ellipsis(string $value, int $limit): string {
  $value = trim($value);
  if ($value === '' || $limit <= 0) {
    return $value;
  }

  if (function_exists('mb_strlen') && function_exists('mb_substr')) {
    if (mb_strlen($value) <= $limit) {
      return $value;
    }
    return rtrim(mb_substr($value, 0, $limit - 1)) . '…';
  }

  if (strlen($value) <= $limit) {
    return $value;
  }

  return rtrim(substr($value, 0, $limit - 3)) . '...';
}

/**
 * Finds active users matching the incoming node legal entity.
 *
 * @param \Drupal\Core\Entity\EntityInterface $entity
 *   The incoming node being processed.
 *
 * @return array
 *   User entities.
 */
function _incoming_notifications_get_users_by_legal_entity(EntityInterface $entity): array {
  if (!$entity->hasField('field_legal_entity')) {
    return [];
  }

  $target_ids = [];
  foreach ($entity->get('field_legal_entity')->getValue() as $item) {
    if (!empty($item['target_id'])) {
      $target_ids[] = (int) $item['target_id'];
    }
  }
  $target_ids = array_values(array_unique($target_ids));
  if (empty($target_ids)) {
    return [];
  }

  $term_storage = \Drupal::entityTypeManager()->getStorage('taxonomy_term');
  $terms = $term_storage->loadMultiple($target_ids);
  foreach ($terms as $term) {
    if (!$term instanceof TermInterface) {
      continue;
    }
    // If a parent term is selected, include all descendant terms so all child
    // AMKE users receive notifications.
    $children = $term_storage->loadTree($term->bundle(), $term->id(), NULL, FALSE);
    foreach ($children as $child) {
      if (!empty($child->tid)) {
        $target_ids[] = (int) $child->tid;
      }
    }
  }
  $target_ids = array_values(array_unique($target_ids));

  $storage = \Drupal::entityTypeManager()->getStorage('user');
  $query = $storage->getQuery()
    ->accessCheck(FALSE)
    ->condition('status', 1)
    ->condition('field_legal_entity', $target_ids, 'IN');
  $user_ids = $query->execute();
  if (empty($user_ids)) {
    return [];
  }

  $users = $storage->loadMultiple($user_ids);
  $users_list = [];
  foreach ($users as $user) {
    if ($user instanceof UserInterface) {
      $users_list[] = $user;
    }
  }

  return $users_list;
}

/**
 * Builds the email subject for a notification.
 */
function incoming_notifications_build_subject_email(string $key, array $params): string {
  $title = trim((string) ($params['incoming_title'] ?? ''));
  $subject = trim((string) ($params['incoming_subject'] ?? ''));
  return $title !== '' ? $title : $subject;
}

/**
 * Builds the notify_widget subject for a notification.
 */
function incoming_notifications_build_subject_notify(string $key, array $params): string {
  return (string) ($params['incoming_title'] ?? $params['incoming_subject'] ?? '');
}

/**
 * Builds the email body for a notification.
 */
function incoming_notifications_build_body_email(string $key, array $params): string {
  $changes_summary = trim((string) ($params['changes_summary_email'] ?? ''));
  if ($changes_summary !== '') {
    return $changes_summary;
  }

  $comment = trim((string) ($params['remark_comment'] ?? ''));
  if ($comment !== '') {
    return $comment;
  }

  return (string) ($params['state_label'] ?? '');
}

/**
 * Builds the notify_widget body for a notification.
 */
function incoming_notifications_build_body_notify(string $key, array $params): string {
  $changes_summary = trim((string) ($params['changes_summary_notify'] ?? ''));
  if ($changes_summary !== '') {
    return $changes_summary;
  }

  $comment = trim((string) ($params['remark_comment'] ?? ''));
  if ($comment !== '') {
    return $comment;
  }

  return (string) ($params['state_label'] ?? '');
}

/**
 * Implements hook_mail().
 */
function incoming_notifications_mail($key, &$message, $params) {
  $message['subject'] = incoming_notifications_build_subject_email($key, $params);
  $message['body'][] = incoming_notifications_build_body_email($key, $params);
}

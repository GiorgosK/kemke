<?php

use Drupal\Core\Entity\EntityInterface;
use Drupal\user\UserInterface;

/**
 * Implements hook_entity_presave().
 */
function incoming_notifications_entity_presave(EntityInterface $entity) {
  if ($entity->getEntityTypeId() !== 'node' || $entity->bundle() !== 'incoming') {
    return;
  }

  if (!$entity->hasField('moderation_state')) {
    return;
  }

  $new_state = $entity->get('moderation_state')->value;
  $original_state = NULL;
  if ($entity->original instanceof EntityInterface && $entity->original->hasField('moderation_state')) {
    $original_state = $entity->original->get('moderation_state')->value;
  }

  if ($new_state === $original_state || !$new_state) {
    return;
  }

  if ($new_state === 'draft') {
    $recipients = _incoming_notifications_get_users_by_role('secretariat');
    _incoming_notifications_send_mail('draft', $entity, $recipients);
  }

  if ($new_state === 'to_be_assigned' && $entity->hasField('field_supervisor')) {
    $target_id = $entity->get('field_supervisor')->target_id;
    $user = $target_id ? \Drupal::entityTypeManager()->getStorage('user')->load($target_id) : NULL;
    if ($user instanceof UserInterface) {
      _incoming_notifications_send_mail('to_be_assigned', $entity, [$user->getEmail()]);
    }
  }

  if ($new_state === 'fullness_check' && $entity->hasField('field_basic_operator')) {
    $target_id = $entity->get('field_basic_operator')->target_id;
    $user = $target_id ? \Drupal::entityTypeManager()->getStorage('user')->load($target_id) : NULL;
    if ($user instanceof UserInterface) {
      _incoming_notifications_send_mail('fullness_check', $entity, [$user->getEmail()]);
    }
  }
}

/**
 * Sends a notification email through Drupal mail manager.
 *
 * @param string $key
 *   The mail key for hook_mail().
 * @param \Drupal\Core\Entity\EntityInterface $entity
 *   The incoming node being processed.
 * @param array $recipients
 *   Array of email addresses.
 */
function _incoming_notifications_send_mail(string $key, EntityInterface $entity, array $recipients): void {
  $recipients = array_filter(array_unique($recipients));
  if (empty($recipients)) {
    return;
  }

  $mailManager = \Drupal::service('plugin.manager.mail');
  $langcode = $entity->language()->getId();

  foreach ($recipients as $to) {
    $params = [
      'incoming_title' => $entity->label(),
      'incoming_id' => $entity->id(),
      'state' => $entity->get('moderation_state')->value,
    ];
    $mailManager->mail('incoming_notifications', $key, $to, $langcode, $params, NULL, TRUE);
  }
}

/**
 * Finds active users for a given role and returns their email addresses.
 *
 * @param string $role_id
 *   The machine name of the role.
 *
 * @return array
 *   Email addresses.
 */
function _incoming_notifications_get_users_by_role(string $role_id): array {
  $storage = \Drupal::entityTypeManager()->getStorage('user');
  $users = $storage->loadByProperties([
    'status' => 1,
    'roles' => $role_id,
  ]);

  $emails = [];
  foreach ($users as $user) {
    if ($user instanceof UserInterface && $user->getEmail()) {
      $emails[] = $user->getEmail();
    }
  }

  return $emails;
}

/**
 * Implements hook_mail().
 */
function incoming_notifications_mail($key, &$message, $params) {
  $site_name = \Drupal::config('system.site')->get('name');
  switch ($key) {
    case 'draft':
      $message['subject'] = t('@site: Incoming "@title" needs attention', ['@site' => $site_name, '@title' => $params['incoming_title']]);
      $message['body'][] = t('Incoming "@title" (NO ID) "Εισερχόμενη". Please assign it.', [
        '@title' => $params['incoming_title'],
      ]);
      break;

    case 'to_be_assigned':
      $message['subject'] = t('@site: Incoming "@title" needs assignment', ['@site' => $site_name, '@title' => $params['incoming_title']]);
      $message['body'][] = t('Incoming "@title" (ID: @id) moved to "Προς χρέωση". Please assign it.', [
        '@title' => $params['incoming_title'],
        '@id' => $params['incoming_id'],
      ]);
      break;

    case 'fullness_check':
      $message['subject'] = t('@site: Incoming "@title" in fullness check', ['@site' => $site_name, '@title' => $params['incoming_title']]);
      $message['body'][] = t('Incoming "@title" (ID: @id) moved to "Έλεγχος πληρότητας". You are listed as the operator.', [
        '@title' => $params['incoming_title'],
        '@id' => $params['incoming_id'],
      ]);
      break;
  }
}

<?php

use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Access\AccessResult;
use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Render\Element;
use Drupal\Core\Url;
use Drupal\views\ViewExecutable;

/**
 * @file
 * Incoming edit tweaks.
 */

/**
 * Implements hook_views_pre_render().
 */
function incoming_edit_tweaks_views_pre_render(ViewExecutable $view): void {
  if (!incoming_edit_tweaks_is_target_view($view)) {
    return;
  }

  $GLOBALS['incoming_edit_tweaks_active_view'] = $view->id();

  if (isset($view->field['operations']) && isset($view->field['operations']->options)) {
    $view->field['operations']->options['destination'] = FALSE;
  }
}

/**
 * Implements hook_views_post_execute().
 */
function incoming_edit_tweaks_views_post_execute(ViewExecutable $view): void {
  if (!incoming_edit_tweaks_is_target_view($view)) {
    return;
  }

  unset($GLOBALS['incoming_edit_tweaks_active_view']);
}

/**
 * Implements hook_entity_operation_alter().
 */
function incoming_edit_tweaks_entity_operation_alter(array &$operations, EntityInterface $entity): void {
  if (empty($GLOBALS['incoming_edit_tweaks_active_view'])) {
    return;
  }

  if ($entity->getEntityTypeId() !== 'node' || $entity->bundle() !== 'incoming') {
    return;
  }

  $moderation_state = NULL;
  if ($entity->hasField('moderation_state')) {
    $moderation_state = $entity->get('moderation_state')->value;
  }

  if ($moderation_state === 'published') {
    unset($operations['edit']);
    if (!isset($operations['view']) && $entity->access('view') && $entity->hasLinkTemplate('canonical')) {
      $operations['view'] = [
        'title' => t('View'),
        'weight' => 5,
        'url' => $entity->toUrl('canonical'),
      ];
    }
    return;
  }

  if (!isset($operations['edit']['url'])) {
    return;
  }

  $url = $operations['edit']['url'];
  $options = $url->getOptions();
  $query = $options['query'] ?? [];
  unset($query['destination']);
  $url->setOption('query', $query);

  if (isset($operations['edit']['query'])) {
    unset($operations['edit']['query']['destination']);
  }
}

/**
 * Check if the view should be altered by this module.
 */
function incoming_edit_tweaks_is_target_view(ViewExecutable $view): bool {
  return in_array($view->id(), ['incoming', 'incoming_amke'], TRUE);
}

/**
 * Implements hook_entity_access().
 */
function incoming_edit_tweaks_entity_access(EntityInterface $entity, $operation, \Drupal\Core\Session\AccountInterface $account): AccessResult {
  if ($entity->getEntityTypeId() !== 'node' || $entity->bundle() !== 'incoming') {
    return AccessResult::neutral();
  }

  if ($operation !== 'update') {
    return AccessResult::neutral();
  }

  if (!$entity->hasField('moderation_state')) {
    return AccessResult::neutral();
  }

  if ($entity->get('moderation_state')->value === 'published') {
    if ($account->hasRole('administrator')) {
      return AccessResult::neutral()->addCacheContexts(['user.roles']);
    }
    return AccessResult::forbidden()
      ->addCacheableDependency($entity)
      ->addCacheContexts(['user.roles']);
  }

  return AccessResult::neutral();
}

/**
 * Implements hook_form_FORM_ID_alter() for incoming edit form.
 */
function incoming_edit_tweaks_form_node_incoming_edit_form_alter(array &$form, FormStateInterface $form_state): void {
  incoming_edit_tweaks_prepare_incoming_form($form, $form_state);
}

/**
 * Implements hook_form_FORM_ID_alter() for incoming add form.
 */
function incoming_edit_tweaks_form_node_incoming_form_alter(array &$form, FormStateInterface $form_state): void {
  incoming_edit_tweaks_prepare_incoming_form($form, $form_state);
}

/**
 * Prepare incoming add/edit forms with shared tweaks.
 */
function incoming_edit_tweaks_prepare_incoming_form(array &$form, FormStateInterface $form_state): void {
  incoming_edit_tweaks_attach_submit_redirect_handler($form, 'incoming_edit_tweaks_redirect_back_to_edit_submit');
  $form['incoming_edit_tweaks_active_tab'] = [
    '#type' => 'hidden',
    '#default_value' => '',
  ];
  $form['#attached']['library'][] = 'incoming_edit_tweaks/tab_restore';
  $form['#after_build'][] = 'incoming_edit_tweaks_hide_plan_signed_remove_button_after_build';
  incoming_edit_tweaks_add_status_display($form, $form_state);
}

/**
 * Ensure the redirect submit handler is wired for all submit buttons.
 */
function incoming_edit_tweaks_attach_submit_redirect_handler(array &$form, string $handler): void {
  if (!isset($form['#submit']) || !is_array($form['#submit'])) {
    $form['#submit'] = isset($form['#submit']) ? [$form['#submit']] : [];
  }
  incoming_edit_tweaks_append_submit_handler($form['#submit'], $handler);
  if (isset($form['actions']) && is_array($form['actions'])) {
    incoming_edit_tweaks_attach_submit_handler_recursive($form['actions'], $handler);
  }
}

/**
 * Recursively appends a submit handler to submit elements.
 */
function incoming_edit_tweaks_attach_submit_handler_recursive(array &$element, string $handler): void {
  if (($element['#type'] ?? NULL) === 'submit') {
    if (!isset($element['#submit']) || !is_array($element['#submit'])) {
      $element['#submit'] = isset($element['#submit']) ? [$element['#submit']] : [];
    }
    incoming_edit_tweaks_append_submit_handler($element['#submit'], $handler);
  }

  foreach (Element::children($element) as $child_key) {
    if (isset($element[$child_key]) && is_array($element[$child_key])) {
      incoming_edit_tweaks_attach_submit_handler_recursive($element[$child_key], $handler);
    }
  }
}

/**
 * Appends a submit handler once.
 */
function incoming_edit_tweaks_append_submit_handler(&$handlers, string $handler): void {
  if (!isset($handlers)) {
    $handlers = [];
  }
  elseif (!is_array($handlers)) {
    $handlers = [$handlers];
  }

  if (!in_array($handler, $handlers, TRUE)) {
    $handlers[] = $handler;
  }
}

/**
 * After-build callback to hide the remove button for the signed plan field.
 */
function incoming_edit_tweaks_hide_plan_signed_remove_button_after_build(array $form, FormStateInterface $form_state): array {
  $target_name = 'field_plan_signed_0_remove_button';
  $target_id = 'edit-field-plan-signed-0-remove-button';
  if (!\Drupal::currentUser()->hasRole('administrator')) {
    incoming_edit_tweaks_hide_element_by_name_or_id($form, $target_name, $target_id);
  }
  return $form;
}

/**
 * Recursively hide elements by matching name or id.
 */
function incoming_edit_tweaks_hide_element_by_name_or_id(array &$element, string $name, string $id): void {
  if (isset($element['#name']) && $element['#name'] === $name) {
    $element['#access'] = FALSE;
  }

  if (isset($element['#id']) && $element['#id'] === $id) {
    $element['#access'] = FALSE;
  }

  foreach (\Drupal\Core\Render\Element::children($element) as $key) {
    incoming_edit_tweaks_hide_element_by_name_or_id($element[$key], $name, $id);
  }
}

/**
 * Add moderation status display above the save buttons.
 */
function incoming_edit_tweaks_add_status_display(array &$form, FormStateInterface $form_state): void {
  $account = \Drupal::currentUser();
  if ($account->hasRole('amke_user')) {
    return;
  }

  $form_object = $form_state->getFormObject();
  if (!method_exists($form_object, 'getEntity')) {
    return;
  }

  $entity = $form_object->getEntity();
  if (!$entity instanceof EntityInterface || $entity->getEntityTypeId() !== 'node' || $entity->bundle() !== 'incoming') {
    return;
  }

  $config = \Drupal::config('workflows.workflow.incoming_processing');
  $states = $config->get('type_settings.states') ?? [];
  $default_state = $config->get('type_settings.default_moderation_state');

  $state_id = $default_state;
  if ($entity->hasField('moderation_state') && !$entity->get('moderation_state')->isEmpty()) {
    $state_id = $entity->get('moderation_state')->value;
  }

  if (!$state_id) {
    return;
  }

  $label = $states[$state_id]['label'] ?? $state_id;

  $actions_weight = $form['actions']['#weight'] ?? 100;
  $form['incoming_moderation_status'] = [
    '#type' => 'item',
    '#markup' => t('Εγγραφο σε Κατάσταση') . ': ' . $label,
    '#weight' => $actions_weight - 1,
    '#attributes' => [
      'class' => ['incoming-moderation-status'],
    ],
    '#wrapper_attributes' => [
      'doc-status' => $state_id,
    ],
  ];
}

/**
 * Submit handler to redirect back to the edit form after save.
 */
function incoming_edit_tweaks_redirect_back_to_edit_submit(array &$form, FormStateInterface $form_state): void {
  $form_object = $form_state->getFormObject();
  if (!method_exists($form_object, 'getEntity')) {
    return;
  }

  $entity = $form_object->getEntity();
  if (!$entity instanceof EntityInterface || $entity->getEntityTypeId() !== 'node') {
    return;
  }

  $node_id = $entity->id();
  if (!$node_id) {
    return;
  }

  $entity_storage = \Drupal::entityTypeManager()->getStorage('node');
  $reloaded_entity = $entity_storage->load($node_id);
  if ($reloaded_entity instanceof EntityInterface) {
    $entity = $reloaded_entity;
  }

  $account = \Drupal::currentUser();
  $edit_url = $entity->toUrl('edit-form');
  $active_tab = incoming_edit_tweaks_normalize_tab_alias((string) $form_state->getValue('incoming_edit_tweaks_active_tab', ''));
  $redirect_options = $active_tab !== '' ? ['query' => ['tab' => $active_tab]] : [];
  if ($edit_url->access($account)) {
    $form_state->setRedirect('entity.node.edit_form', ['node' => $node_id], $redirect_options);
    return;
  }

  if ($account->hasRole('amke_user')) {
    $form_state->setRedirectUrl(Url::fromUserInput('/amke'));
    return;
  }

  if ($account->hasRole('operator')) {
    $form_state->setRedirectUrl(Url::fromUserInput('/incoming'));
    return;
  }

  $kemke_roles = ['director_supervisor', 'department_supervisor', 'secretariat'];
  foreach ($kemke_roles as $role) {
    if ($account->hasRole($role)) {
      $form_state->setRedirectUrl(Url::fromUserInput('/incoming'));
      return;
    }
  }
}

/**
 * Normalize and sanitize the tab alias before adding it to redirect options.
 */
function incoming_edit_tweaks_normalize_tab_alias(string $tab_id): string {
  $tab_id = strtolower(ltrim(trim($tab_id), '#'));
  if (str_starts_with($tab_id, 'edit-group-')) {
    $tab_id = substr($tab_id, strlen('edit-group-'));
  }

  if ($tab_id === '') {
    return '';
  }

  return preg_match('/^[A-Za-z0-9_-]+$/', $tab_id) ? $tab_id : '';
}

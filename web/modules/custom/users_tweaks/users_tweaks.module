<?php

declare(strict_types=1);

use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Entity\Display\EntityViewDisplayInterface;
use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Routing\RouteMatchInterface;
use Drupal\Core\Site\Settings;
use Drupal\Core\Url;
use Drupal\user\UserInterface;

/**
 * Implements hook_entity_presave().
 */
function users_tweaks_entity_presave(EntityInterface $entity): void {
  if (!$entity instanceof UserInterface) {
    return;
  }

  users_tweaks_track_access_change($entity);

  users_tweaks_populate_docutracks_fields($entity);
}

/**
 * Populate Docutracks fields for a user based on Docutracks username.
 */
function users_tweaks_populate_docutracks_fields(UserInterface $account): void {
  if (
    !$account->hasField('field_docutracks_username') ||
    !$account->hasField('field_docutracks_json') ||
    !$account->hasField('field_docutracks_email') ||
    !$account->hasField('field_docutracks_id')
  ) {
    return;
  }

  $username = trim((string) $account->get('field_docutracks_username')->value);
  if ($username === '') {
    return;
  }

  $username_new_or_changed = users_tweaks_docutracks_username_new_or_changed($account, $username);
  if (!users_tweaks_docutracks_lookup_needed($account, $username_new_or_changed)) {
    return;
  }

  try {
    /** @var \Drupal\side_api\DocutracksClient $client */
    $client = \Drupal::service('side_api.docutracks_client');
    $payload = $client->fetchUserByUsername($username);
    $encoded = users_tweaks_json_encode($payload);
    $account->set('field_docutracks_json', $encoded);

    $email = $client->extractValueByPath($payload, 'User.Email');
    if (is_string($email) && $email !== '') {
      $account->set('field_docutracks_email', $email);
    }

    $docutracks_id = $client->extractValueByPath($payload, 'User.Id');
    if ((is_int($docutracks_id) || is_string($docutracks_id)) && (string) $docutracks_id !== '') {
      $account->set('field_docutracks_id', (string) $docutracks_id);
    }

    if ($username_new_or_changed) {
      $config_result = users_tweaks_reconcile_docutracks_config($account, $payload);
      if ($config_result !== NULL) {
        \Drupal::messenger()->addStatus($config_result['message']);
        \Drupal::logger('users_tweaks')->info('Docutracks config @action for @username: @details', [
          '@action' => $config_result['action'],
          '@username' => $username,
          '@details' => users_tweaks_json_encode($config_result['details']),
        ]);
      }
    }
  }
  catch (\Throwable $throwable) {
    \Drupal::logger('users_tweaks')->error('Docutracks user lookup failed for @username: @message', [
      '@username' => $username,
      '@message' => $throwable->getMessage(),
    ]);
  }
}

/**
 * Decide if the Docutracks username is new or changed on this save.
 */
function users_tweaks_docutracks_username_new_or_changed(UserInterface $account, string $username): bool {
  $original = $account->original ?? NULL;
  if (!$original instanceof UserInterface || !$original->hasField('field_docutracks_username')) {
    return TRUE;
  }

  $original_username = trim((string) $original->get('field_docutracks_username')->value);
  return $original_username !== $username;
}

/**
 * Decide if a user save should refresh the Docutracks lookup.
 */
function users_tweaks_docutracks_lookup_needed(UserInterface $account, bool $username_new_or_changed): bool {
  if ($username_new_or_changed) {
    return TRUE;
  }

  foreach (['field_docutracks_id', 'field_docutracks_email', 'field_docutracks_json'] as $field_name) {
    if ($account->get($field_name)->isEmpty()) {
      return TRUE;
    }
  }

  return FALSE;
}

/**
 * Create or correct field_dt_config for the current SIDE environment.
 *
 * @return array{action:string,message:\Drupal\Core\StringTranslation\TranslatableMarkup,details:array}|null
 */
function users_tweaks_reconcile_docutracks_config(UserInterface $account, array $payload): ?array {
  if (!$account->hasField('field_dt_config')) {
    return NULL;
  }

  $relation_groups = users_tweaks_extract_docutracks_relation_groups($payload);
  if ($relation_groups === []) {
    \Drupal::logger('users_tweaks')->warning('Docutracks config was not updated for @username because the lookup response did not include User.Relations.Group.Id.', [
      '@username' => (string) $account->get('field_docutracks_username')->value,
    ]);
    return NULL;
  }

  $environment_key = users_tweaks_side_api_environment_key();
  $raw_config = trim((string) $account->get('field_dt_config')->value);
  $field_config_created = $raw_config === '';
  $config = $raw_config === '' ? [] : json_decode($raw_config, TRUE);
  if (!is_array($config)) {
    $config = [];
    $field_config_created = TRUE;
  }

  if (!isset($config['department']) || !is_array($config['department'])) {
    $config['department'] = [];
  }

  $department = $config['department'][$environment_key] ?? NULL;
  $configured_group = is_array($department) ? users_tweaks_effective_department_group_id($department) : '';
  $relation_ids = array_column($relation_groups, 'id');
  if ($configured_group !== '' && in_array($configured_group, $relation_ids, TRUE)) {
    return NULL;
  }

  $suggestion = reset($relation_groups);
  if (!is_array($suggestion) || (string) ($suggestion['id'] ?? '') === '') {
    return NULL;
  }

  $previous_group = $configured_group;
  $group_id = (string) $suggestion['id'];
  $department_config = [
    'name' => (string) ($suggestion['label'] ?? ''),
    'id' => users_tweaks_normalize_docutracks_id($group_id),
    'groupid' => users_tweaks_normalize_docutracks_id($group_id),
  ];
  $populated_environments = [$environment_key];
  $config['department'][$environment_key] = $department_config;

  if ($field_config_created && $environment_key === 'test') {
    $config['department']['live'] = $department_config;
    $populated_environments[] = 'live';
  }

  $account->set('field_dt_config', users_tweaks_json_encode($config));

  $created = $raw_config === '' || !is_array($department);
  $action = $created ? 'created' : 'corrected';
  if ($created && $field_config_created && $environment_key === 'test') {
    $message = t('Docutracks config created for test and live with group @group.', ['@group' => $group_id]);
  }
  elseif ($created) {
    $message = t('Docutracks config created for @env with group @group.', ['@env' => $environment_key, '@group' => $group_id]);
  }
  else {
    $message = t('Docutracks config corrected for @env from @old to @new.', [
      '@env' => $environment_key,
      '@old' => $previous_group !== '' ? $previous_group : '-',
      '@new' => $group_id,
    ]);
  }

  return [
    'action' => $action,
    'message' => $message,
    'details' => [
      'environment_key' => $environment_key,
      'previous_groupid' => $previous_group !== '' ? $previous_group : NULL,
      'new_groupid' => $group_id,
      'populated_environments' => $populated_environments,
      'suggested_group_name' => (string) ($suggestion['label'] ?? ''),
      'all_relation_groups' => $relation_groups,
    ],
  ];
}

/**
 * Resolve side_api field_dt_config environment key for the current host.
 */
function users_tweaks_side_api_environment_key(): string {
  $host = $_SERVER['HTTP_HOST'] ?? '';
  $settings = Settings::get('side_api', []);

  if (
    $host !== ''
    && is_array($settings)
    && isset($settings['host_overrides'][$host])
    && is_array($settings['host_overrides'][$host])
  ) {
    $override_environment = $settings['host_overrides'][$host]['environment_key'] ?? NULL;
    if (is_string($override_environment) && in_array($override_environment, ['test', 'live'], TRUE)) {
      return $override_environment;
    }
  }

  $dev_hosts = ['kemke.webx2.com', 'kemke.ddev.site'];
  if (is_array($settings) && isset($settings['dev_hosts']) && is_array($settings['dev_hosts'])) {
    $dev_hosts = array_values(array_filter($settings['dev_hosts'], static fn($value) => is_string($value) && $value !== ''));
  }

  return in_array($host, $dev_hosts, TRUE) ? 'test' : 'live';
}

/**
 * Extract unique group IDs and names from a Docutracks user lookup response.
 *
 * @return array<int, array{id:string,label:string}>
 */
function users_tweaks_extract_docutracks_relation_groups(array $payload): array {
  $relations = $payload['User']['Relations'] ?? NULL;
  if (!is_array($relations)) {
    return [];
  }

  $groups = [];
  $seen = [];
  foreach ($relations as $relation) {
    if (!is_array($relation)) {
      continue;
    }
    $group = $relation['Group'] ?? NULL;
    if (!is_array($group)) {
      continue;
    }
    $group_id = $group['Id'] ?? NULL;
    if (!is_scalar($group_id) || trim((string) $group_id) === '') {
      continue;
    }
    $id = trim((string) $group_id);
    if (isset($seen[$id])) {
      continue;
    }
    $seen[$id] = TRUE;
    $groups[] = [
      'id' => $id,
      'label' => users_tweaks_extract_docutracks_group_label($group),
    ];
  }

  return $groups;
}

/**
 * Extract a readable group label from a Docutracks group object.
 */
function users_tweaks_extract_docutracks_group_label(array $group): string {
  foreach (['Name', 'DisplayName', 'Title', 'Description', 'Code', 'GroupCode'] as $key) {
    if (isset($group[$key]) && is_scalar($group[$key]) && trim((string) $group[$key]) !== '') {
      return trim((string) $group[$key]);
    }
  }

  return '';
}

/**
 * Return the groupid that will actually be used for signing.
 */
function users_tweaks_effective_department_group_id(array $department): string {
  foreach (['groupid', 'id'] as $key) {
    if (isset($department[$key]) && is_scalar($department[$key]) && trim((string) $department[$key]) !== '') {
      return trim((string) $department[$key]);
    }
  }

  return '';
}

/**
 * Store numeric Docutracks IDs as numbers while preserving non-numeric IDs.
 */
function users_tweaks_normalize_docutracks_id(string $id): int|string {
  return ctype_digit($id) ? (int) $id : $id;
}

/**
 * Encode JSON for fields and logs with readable Greek text.
 */
function users_tweaks_json_encode(mixed $data): string {
  return json_encode($data, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES | JSON_PRETTY_PRINT | JSON_THROW_ON_ERROR);
}

/**
 * Track user block/unblock changes and store a log on the user entity.
 */
function users_tweaks_track_access_change(UserInterface $account): void {
  if (
    !$account->hasField('field_access_change_log') ||
    !$account->hasField('field_last_access_change')
  ) {
    return;
  }

  $original = $account->original ?? NULL;
  if (!$original instanceof UserInterface) {
    return;
  }

  $was_blocked = $original->isBlocked();
  $is_blocked = $account->isBlocked();
  if ($was_blocked === $is_blocked) {
    return;
  }

  $request_time = \Drupal::time()->getRequestTime();
  $date = \Drupal::service('date.formatter')->format($request_time, 'custom', 'j/n/Y');
  $storage_date = \Drupal::service('date.formatter')->format($request_time, 'custom', 'Y-m-d');
  $status_label = $is_blocked ? 'Ανενεργός' : 'Ενεργός';
  $entry = $date . ' ' . $status_label;

  $current_log = trim((string) $account->get('field_access_change_log')->value);
  $new_log = $current_log === '' ? $entry : $entry . "\n" . $current_log;

  $account->set('field_last_access_change', $storage_date);
  $account->set('field_access_change_log', $new_log);
}

/**
 * Extract a Docutracks JSON value from a user field by dot path.
 */
function users_tweaks_get_docutracks_value(UserInterface $account, string $path): mixed {
  if (!$account->hasField('field_docutracks_json') || $account->get('field_docutracks_json')->isEmpty()) {
    return NULL;
  }

  $decoded = json_decode((string) $account->get('field_docutracks_json')->value, TRUE);
  if (!is_array($decoded)) {
    return NULL;
  }

  /** @var \Drupal\side_api\DocutracksClient $client */
  $client = \Drupal::service('side_api.docutracks_client');
  return $client->extractValueByPath($decoded, $path);
}

/**
 * Get all Kemke user role IDs.
 */
function users_tweaks_get_kemke_user_roles(string $include = 'admin'): array {
  $roles = [
    'director_supervisor',
    'department_supervisor',
    'secretariat',
    'operator',
  ];

  if ($include === 'admin') {
    $roles[] = 'kemke_admin';
  }

  return $roles;
}

/**
 * Implements hook_form_FORM_ID_alter() for user login form.
 */
function users_tweaks_form_user_login_form_alter(array &$form, FormStateInterface $form_state, string $form_id): void {
  $form['#submit'][] = 'users_tweaks_login_redirect_submit';
}

/**
 * Implements hook_form_FORM_ID_alter() for user login block form.
 */
function users_tweaks_form_user_login_block_alter(array &$form, FormStateInterface $form_state, string $form_id): void {
  $form['#submit'][] = 'users_tweaks_login_redirect_submit';
}

/**
 * Implements hook_form_FORM_ID_alter() for user creation form.
 */
function users_tweaks_form_user_register_form_alter(array &$form, FormStateInterface $form_state, string $form_id): void {
  $current_user = \Drupal::currentUser();

  users_tweaks_adjust_user_account_groups($form);

  if (!users_tweaks_current_user_can_access_integration_tabs()) {
    users_tweaks_hide_integration_groups($form);
  }

  if (isset($form['account']['pass'])) {
    $form['account']['pass']['#required'] = FALSE;
    if (!$current_user->hasRole('administrator')) {
      $form['account']['pass']['#access'] = FALSE;
    }
  }

  if (!isset($form['actions']['submit']['#submit']) || !is_array($form['actions']['submit']['#submit'])) {
    $form['actions']['submit']['#submit'] = [];
  }

  $submit_handler = 'users_tweaks_user_register_generate_password_submit';
  if (in_array($submit_handler, $form['actions']['submit']['#submit'], TRUE)) {
    return;
  }

  $submit_handlers = [];
  $inserted = FALSE;
  foreach ($form['actions']['submit']['#submit'] as $handler) {
    if (!$inserted && $handler === '::submitForm') {
      $submit_handlers[] = $submit_handler;
      $inserted = TRUE;
    }
    $submit_handlers[] = $handler;
  }
  if (!$inserted) {
    array_unshift($submit_handlers, $submit_handler);
  }
  $form['actions']['submit']['#submit'] = $submit_handlers;
}

/**
 * Redirect users immediately after a successful login.
 */
function users_tweaks_login_redirect_submit(array &$form, FormStateInterface $form_state): void {
  $current_user = \Drupal::currentUser();
  if (!$current_user->isAuthenticated()) {
    return;
  }

  $account = \Drupal::entityTypeManager()->getStorage('user')->load($current_user->id());
  if (!$account instanceof UserInterface) {
    return;
  }

  if (function_exists('user_pending_role_notice_get_redirect_url')) {
    $pending_redirect = user_pending_role_notice_get_redirect_url($account);
    if ($pending_redirect instanceof Url) {
      $form_state->setRedirectUrl($pending_redirect);
      return;
    }
  }

  $destination = $account->hasRole('amke_user') ? '/amke' : '/incoming';
  $form_state->setRedirectUrl(Url::fromUserInput($destination));
}

/**
 * Generates a password for non-admin user creation submissions.
 */
function users_tweaks_user_register_generate_password_submit(array &$form, FormStateInterface $form_state): void {
  if (!$form_state->isValueEmpty('pass')) {
    return;
  }

  $password = \Drupal::service('password_generator')->generate();
  $form_state->setValue('pass', $password);
  $form_state->setValue(['account', 'pass'], $password);
}

/**
 * Implements hook_form_FORM_ID_alter() for user_edit form.
 */
function users_tweaks_form_user_form_alter(array &$form, FormStateInterface $form_state, string $form_id): void {
  $route_match = \Drupal::routeMatch();
  $account = $route_match->getParameter('user');
  if ($account instanceof UserInterface) {
    $non_kemke_user = $account->hasRole('api') ||
      $account->hasRole('administrator') ||
      $account->hasRole('amke_user') ||
      $account->hasRole('kemke_admin');
    $form['#title'] = users_tweaks_build_user_title($account);

    if (!$account->hasRole('amke_user')) {
      if (isset($form['field_legal_entity'])) {
        $form['field_legal_entity']['#access'] = FALSE;
      }
      if (isset($form['account']['field_legal_entity'])) {
        $form['account']['field_legal_entity']['#access'] = FALSE;
      }
    }

  }

  $current_user = \Drupal::currentUser();
  users_tweaks_adjust_user_account_groups($form);

  if (!users_tweaks_current_user_can_access_integration_tabs()) {
    users_tweaks_hide_integration_groups($form);
  }

  if ($current_user->hasRole('amke_user')) {
    users_tweaks_hide_absenses_group($form);
  }

  if (
    $account instanceof UserInterface &&
    $current_user->id() === $account->id() &&
    isset($form['account']['pass']) &&
    !\Drupal::request()->query->has('pass-reset-token')
  ) {
    // Keep profile updates independent from password reset validation.
    $form['account']['pass']['#required'] = FALSE;
  }

  if ($current_user->hasRole('administrator')) {
    return;
  }

  if (isset($form['account']['name'])) {
    $form['account']['name']['#required'] = FALSE;
    $form['account']['name']['#access'] = FALSE;
  }

  if (isset($form['account']['pass'])) {
    $form['account']['pass']['#required'] = FALSE;
    $form['account']['pass']['#access'] = FALSE;
  }

  $form['#entity_builders']['users_tweaks_hidden_account_defaults'] = 'users_tweaks_user_form_entity_builder';

  if (isset($form['actions']['delete'])) {
    unset($form['actions']['delete']);
  }

  if (isset($form['roles']['#options']['administrator'])) {
    unset($form['roles']['#options']['administrator']);
  }

  if (isset($form['account']['roles']['#options']['administrator'])) {
    unset($form['account']['roles']['#options']['administrator']);
  }
}

/**
 * Fill hidden account fields for non-admin user form submissions.
 */
function users_tweaks_user_form_entity_builder(string $entity_type_id, UserInterface $account, array &$form, FormStateInterface &$form_state): void {
  $current_user = \Drupal::currentUser();
  if ($entity_type_id !== 'user' || $current_user->hasRole('administrator')) {
    return;
  }

  if (trim((string) $account->getAccountName()) === '') {
    $account->setUsername(users_tweaks_generate_username($account, $form_state));
  }

  $submitted_password = trim((string) ($form_state->getValue(['account', 'pass', 'pass1']) ?? ''));
  if ($account->isNew() && $submitted_password === '') {
    $account->setPassword(bin2hex(random_bytes(16)));
  }
}

/**
 * Generate a unique username for hidden non-admin user form submissions.
 */
function users_tweaks_generate_username(UserInterface $account, FormStateInterface $form_state): string {
  $generated = $form_state->get('users_tweaks_generated_username');
  if (is_string($generated) && $generated !== '') {
    return $generated;
  }

  $submitted_mail = trim((string) ($form_state->getValue(['account', 'mail']) ?? ''));
  $mail = $submitted_mail !== '' ? $submitted_mail : trim((string) $account->getEmail());
  $base = '';
  if ($mail !== '') {
    $base = strtolower(strtok($mail, '@') ?: '');
  }

  $base = preg_replace('/[^a-z0-9_.-]+/', '_', $base ?? '') ?: 'user';
  $candidate = $base;
  $storage = \Drupal::entityTypeManager()->getStorage('user');
  $counter = 1;

  while (TRUE) {
    $matches = $storage->loadByProperties(['name' => $candidate]);
    $conflict = FALSE;
    foreach ($matches as $match) {
      if (!$match instanceof UserInterface) {
        continue;
      }
      if ($account->id() !== NULL && (int) $match->id() === (int) $account->id()) {
        continue;
      }
      $conflict = TRUE;
      break;
    }

    if (!$conflict) {
      $form_state->set('users_tweaks_generated_username', $candidate);
      return $candidate;
    }

    $counter++;
    $candidate = $base . '_' . $counter;
  }
}

/**
 * Implements hook_form_FORM_ID_alter() for user cancel form.
 */
function users_tweaks_form_user_cancel_form_alter(array &$form, FormStateInterface $form_state, string $form_id): void {
  $current_user = \Drupal::currentUser();
  if ($current_user->hasRole('administrator')) {
    return;
  }

  if (!isset($form['user_cancel_method'])) {
    return;
  }

  $form['user_cancel_method']['#options'] = [
    'user_cancel_block' => 'αποκλεισμός χρήστη',
  ];
  $form['user_cancel_method']['#default_value'] = 'user_cancel_block';

  if (isset($form['user_cancel_method']['#title'])) {
    $form['user_cancel_method']['#title'] = '';
  }
  if (isset($form['user_cancel_confirm'])) {
    unset($form['user_cancel_confirm']);
  }

  $route_match = \Drupal::routeMatch();
  $account = $route_match->getParameter('user');
  if ($account instanceof UserInterface) {
    $form['#title'] = users_tweaks_build_cancel_title($account);
  }
}

/**
 * Implements hook_page_title_alter().
 */
function users_tweaks_page_title_alter(&$title, RouteMatchInterface $route_match): void {
  if ($route_match->getRouteName() !== 'entity.user.canonical' && $route_match->getRouteName() !== 'entity.user.cancel_form') {
    return;
  }

  $current_user = \Drupal::currentUser();
  if ($current_user->hasRole('administrator')) {
    return;
  }

  $account = $route_match->getParameter('user');
  if (!$account instanceof UserInterface) {
    return;
  }

  if ($route_match->getRouteName() === 'entity.user.cancel_form') {
    $title = users_tweaks_build_cancel_title($account);
    return;
  }

  $title = users_tweaks_build_user_title($account);
}

/**
 * Implements hook_entity_view_alter().
 */
function users_tweaks_entity_view_alter(array &$build, EntityInterface $entity, EntityViewDisplayInterface $display): void {
  if (!$entity instanceof UserInterface) {
    return;
  }

  if (!users_tweaks_current_user_can_access_integration_tabs()) {
    users_tweaks_hide_integration_groups($build);
  }

  $route_match = \Drupal::routeMatch();
  if ($route_match->getRouteName() !== 'entity.user.canonical') {
    return;
  }

  if (\Drupal::currentUser()->hasRole('amke_user')) {
    users_tweaks_hide_absenses_group($build);
  }

  $build['#title'] = users_tweaks_build_user_title($entity);
  users_tweaks_add_roles_to_user_view($build, $entity);
}

/**
 * Hide absenses tab group for users who should not see it.
 */
function users_tweaks_hide_absenses_group(array &$build): void {
  if (isset($build['group_absenses'])) {
    $build['group_absenses']['#access'] = FALSE;
  }

  if (isset($build['field_absenses_ref'])) {
    $build['field_absenses_ref']['#access'] = FALSE;
  }

  if (isset($build['account']['field_absenses_ref'])) {
    $build['account']['field_absenses_ref']['#access'] = FALSE;
  }
}

/**
 * Checks whether the current user may access user integration tabs.
 */
function users_tweaks_current_user_can_access_integration_tabs(): bool {
  $current_user = \Drupal::currentUser();
  return $current_user->hasRole('administrator') || $current_user->hasRole('kemke_admin');
}

/**
 * Hide Docutracks and GGPS tab groups and child fields.
 */
function users_tweaks_hide_integration_groups(array &$build): void {
  foreach (['group_docutracks', 'group_ggps'] as $group_name) {
    if (isset($build[$group_name])) {
      $build[$group_name]['#access'] = FALSE;
    }
  }

  foreach ([
    'field_docutracks_username',
    'field_docutracks_id',
    'field_docutracks_email',
    'field_docutracks_json',
    'field_dt_config',
    'field_gsis_afm',
    'field_gsis_userid',
    'field_gsis_info',
  ] as $field_name) {
    if (isset($build[$field_name])) {
      $build[$field_name]['#access'] = FALSE;
    }
    if (isset($build['account'][$field_name])) {
      $build['account'][$field_name]['#access'] = FALSE;
    }
  }

  $build['#cache']['contexts'][] = 'user.roles';
}

/**
 * Move email to General and restrict the account/roles tab.
 */
function users_tweaks_adjust_user_account_groups(array &$form): void {
  if (isset($form['account']['mail'])) {
    $form['mail'] = $form['account']['mail'];
    $form['mail']['#group'] = 'group_general';
    $form['mail']['#weight'] = -10;
    unset($form['account']['mail']);

    $form['#group_children'] = $form['#group_children'] ?? [];
    $form['#group_children']['mail'] = 'group_general';
  }

  $pre_render = ['Drupal\users_tweaks\Render\UserMailToGeneralPreRender', 'preRender'];
  if (!isset($form['#pre_render']) || !is_array($form['#pre_render'])) {
    $form['#pre_render'] = [];
  }
  if (!in_array($pre_render, $form['#pre_render'], TRUE)) {
    $form['#pre_render'][] = $pre_render;
  }

  if (!\Drupal::currentUser()->hasPermission('administer users')) {
    if (isset($form['group_other'])) {
      $form['group_other']['#access'] = FALSE;
    }
    if (isset($form['account'])) {
      $form['account']['#access'] = FALSE;
    }
  }
}

/**
 * Implements hook_field_group_form_process_build_alter().
 */
function users_tweaks_field_group_form_process_build_alter(array &$element, FormStateInterface $form_state, &$complete_form): void {
  if (($element['#form_id'] ?? '') !== 'user_form' && ($element['#form_id'] ?? '') !== 'user_register_form') {
    return;
  }

  if (isset($element['mail'])) {
    $element['mail']['#group'] = 'group_general';
    $element['#group_children'] = $element['#group_children'] ?? [];
    $element['#group_children']['mail'] = 'group_general';

    if (isset($element['#fieldgroups']['group_general']) && is_object($element['#fieldgroups']['group_general'])) {
      $children = $element['#fieldgroups']['group_general']->children ?? [];
      if (!in_array('mail', $children, TRUE)) {
        array_unshift($children, 'mail');
        $element['#fieldgroups']['group_general']->children = $children;
      }
    }
  }
}

/**
 * Add user role labels to the user view display.
 */
function users_tweaks_add_roles_to_user_view(array &$build, UserInterface $account): void {
  $role_ids = array_values(array_diff($account->getRoles(), ['authenticated']));
  if ($role_ids === []) {
    return;
  }

  $roles = \Drupal::entityTypeManager()
    ->getStorage('user_role')
    ->loadMultiple($role_ids);

  $labels = [];
  foreach ($role_ids as $role_id) {
    if (isset($roles[$role_id])) {
      $labels[] = $roles[$role_id]->label();
    }
  }

  if ($labels === []) {
    return;
  }

  $build['users_tweaks_roles'] = [
    '#type' => 'item',
    '#title' => t('Role'),
    '#plain_text' => implode(', ', $labels),
    '#weight' => 4,
  ];

  $build['#group_children'] = $build['#group_children'] ?? [];
  $build['#group_children']['users_tweaks_roles'] = 'group_general';
}

/**
 * Implements hook_toolbar_alter().
 */
function users_tweaks_toolbar_alter(array &$items): void {
  if (!isset($items['user']['tab'])) {
    return;
  }

  $current_user = \Drupal::currentUser();
  if (!$current_user->isAuthenticated()) {
    return;
  }

  $account = \Drupal::entityTypeManager()->getStorage('user')->load($current_user->id());
  if (!$account instanceof UserInterface) {
    return;
  }

  $base_title = users_tweaks_build_user_title($account);
  $title = $base_title;
  $role_label = users_tweaks_get_primary_role_label($account);
  $full_role_label = $role_label;
  if ($account->hasRole('amke_user') && $account->hasField('field_legal_entity')) {
    $legal_entity = $account->get('field_legal_entity')->entity;
    if ($legal_entity) {
      $full_role_label = $legal_entity->label();
    }
  }
  if ($role_label !== NULL) {
    $title .= ' (' . $role_label . ')';
  }

  $items['user']['tab']['#title'] = $title;
  if ($full_role_label !== NULL) {
    $tooltip = $base_title . ' (' . $full_role_label . ')';
    $items['user']['tab']['#attributes']['title'] = $tooltip;
    $items['user']['tab']['#attributes']['data-full-title'] = $tooltip;
  }

  // Replace the lazy-builder title with a plain server-rendered string so the
  // final anchor markup remains stable.
  unset($items['user']['tab']['#lazy_builder'], $items['user']['tab']['#create_placeholder'], $items['user']['tab']['#lazy_builder_preview']);
  $items['user']['#attached']['library'][] = 'users_tweaks/toolbar-title';
  $cacheable_metadata = \Drupal\Core\Cache\CacheableMetadata::createFromRenderArray($items['user']['tab'])
    ->addCacheableDependency($account)
    ->addCacheContexts(['user', 'user.roles']);

  if ($account->hasRole('amke_user') && $account->hasField('field_legal_entity')) {
    $legal_entity = $account->get('field_legal_entity')->entity;
    if ($legal_entity) {
      $cacheable_metadata->addCacheableDependency($legal_entity);
    }
  }

  $cacheable_metadata->applyTo($items['user']['tab']);
}

/**
 * Implements hook_preprocess_toolbar().
 */
function users_tweaks_preprocess_toolbar(array &$variables): void {
  if (empty($variables['tabs']['user']['link']) || !is_array($variables['tabs']['user']['link'])) {
    return;
  }

  $current_user = \Drupal::currentUser();
  if (!$current_user->isAuthenticated()) {
    return;
  }

  $account = \Drupal::entityTypeManager()->getStorage('user')->load($current_user->id());
  if (!$account instanceof UserInterface) {
    return;
  }

  $base_title = users_tweaks_build_user_title($account);
  $role_label = users_tweaks_get_primary_role_label($account);
  $full_role_label = $role_label;
  if ($account->hasRole('amke_user') && $account->hasField('field_legal_entity')) {
    $legal_entity = $account->get('field_legal_entity')->entity;
    if ($legal_entity) {
      $full_role_label = $legal_entity->label();
    }
  }

  $title = $base_title;
  if ($role_label !== NULL) {
    $title .= ' (' . $role_label . ')';
  }

  $variables['tabs']['user']['link']['#title'] = $title;
  if ($full_role_label !== NULL) {
    $tooltip = $base_title . ' (' . $full_role_label . ')';
    $variables['tabs']['user']['link']['#attributes']['title'] = $tooltip;
    $variables['tabs']['user']['link']['#attributes']['data-full-title'] = $tooltip;
  }
}

/**
 * Get the first non-authenticated role label for a user.
 */
function users_tweaks_get_primary_role_label(UserInterface $account): ?string {
  if ($account->hasRole('amke_user') && $account->hasField('field_legal_entity')) {
    $legal_entity = $account->get('field_legal_entity')->entity;
    if ($legal_entity) {
      return users_tweaks_build_toolbar_legal_entity_label($legal_entity->label());
    }
  }

  $role_ids = array_values(array_diff($account->getRoles(), ['authenticated']));
  if ($role_ids === []) {
    return NULL;
  }

  $roles = \Drupal::entityTypeManager()
    ->getStorage('user_role')
    ->loadMultiple($role_ids);

  foreach ($role_ids as $role_id) {
    if (isset($roles[$role_id])) {
      return $roles[$role_id]->label();
    }
  }

  return NULL;
}

/**
 * Build a compact toolbar label for long legal entity names.
 */
function users_tweaks_build_toolbar_legal_entity_label(string $label): string {
  $label = trim($label);
  if ($label === '') {
    return $label;
  }

  $parts = preg_split('/\s*[-–—]\s*/u', $label, 2);
  $short = trim((string) ($parts[0] ?? ''));
  if ($short === '' || $short === $label) {
    return $label;
  }

  return $short . ' ...';
}

/**
 * Build the user title based on name fields or username fallback.
 */
function users_tweaks_build_user_title(UserInterface $account): string {
  $first_name = $account->hasField('field_first_name')
    ? trim((string) $account->get('field_first_name')->value)
    : '';
  $last_name = $account->hasField('field_last_name')
    ? trim((string) $account->get('field_last_name')->value)
    : '';
  $full_name = trim($first_name . ' ' . $last_name);

  return $full_name !== '' ? $full_name : $account->getAccountName();
}

/**
 * Build the cancel page title based on name fields or username fallback.
 */
function users_tweaks_build_cancel_title(UserInterface $account): string {
  $last_name = $account->hasField('field_last_name')
    ? trim((string) $account->get('field_last_name')->value)
    : '';
  $first_name = $account->hasField('field_first_name')
    ? trim((string) $account->get('field_first_name')->value)
    : '';
  $full_name = trim($last_name . ' ' . $first_name);

  $target = $full_name !== '' ? $full_name : $account->getAccountName();
  return trim('αποκλεισμός χρήστη ' . $target);
}

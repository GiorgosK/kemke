<?php

declare(strict_types=1);

use Drupal\Component\Serialization\Json;
use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Entity\Display\EntityViewDisplayInterface;
use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Routing\RouteMatchInterface;
use Drupal\user\UserInterface;

/**
 * Implements hook_entity_presave().
 */
function users_tweaks_entity_presave(EntityInterface $entity): void {
  if (!$entity instanceof UserInterface) {
    return;
  }

  users_tweaks_track_access_change($entity);

  if (
    !$entity->hasField('field_docutracks_username') ||
    !$entity->hasField('field_docutracks_json') ||
    !$entity->hasField('field_docutracks_email')
  ) {
    return;
  }

  $username = trim((string) $entity->get('field_docutracks_username')->value);
  if ($username === '') {
    return;
  }

  if (!$entity->get('field_docutracks_json')->isEmpty()) {
    return;
  }

  try {
    /** @var \Drupal\side_api\DocutracksClient $client */
    $client = \Drupal::service('side_api.docutracks_client');
    $payload = $client->fetchUserByUsername($username);
    $encoded = Json::encode($payload, JSON_UNESCAPED_UNICODE | JSON_PRETTY_PRINT);
    $entity->set('field_docutracks_json', $encoded);

    $email = $client->extractValueByPath($payload, 'User.Email');
    if (is_string($email) && $email !== '') {
      $entity->set('field_docutracks_email', $email);
    }
  }
  catch (\Throwable $throwable) {
    \Drupal::logger('users_tweaks')->error('Docutracks user lookup failed for @username: @message', [
      '@username' => $username,
      '@message' => $throwable->getMessage(),
    ]);
  }
}

/**
 * Track user block/unblock changes and store a log on the user entity.
 */
function users_tweaks_track_access_change(UserInterface $account): void {
  if (
    !$account->hasField('field_access_change_log') ||
    !$account->hasField('field_last_access_change')
  ) {
    return;
  }

  $original = $account->original ?? NULL;
  if (!$original instanceof UserInterface) {
    return;
  }

  $was_blocked = $original->isBlocked();
  $is_blocked = $account->isBlocked();
  if ($was_blocked === $is_blocked) {
    return;
  }

  $request_time = \Drupal::time()->getRequestTime();
  $date = \Drupal::service('date.formatter')->format($request_time, 'custom', 'j/n/Y');
  $storage_date = \Drupal::service('date.formatter')->format($request_time, 'custom', 'Y-m-d');
  $status_label = $is_blocked ? 'Ανενεργός' : 'Ενεργός';
  $entry = $date . ' ' . $status_label;

  $current_log = trim((string) $account->get('field_access_change_log')->value);
  $new_log = $current_log === '' ? $entry : $entry . "\n" . $current_log;

  $account->set('field_last_access_change', $storage_date);
  $account->set('field_access_change_log', $new_log);
}

/**
 * Extract a Docutracks JSON value from a user field by dot path.
 */
function users_tweaks_get_docutracks_value(UserInterface $account, string $path): mixed {
  if (!$account->hasField('field_docutracks_json') || $account->get('field_docutracks_json')->isEmpty()) {
    return NULL;
  }

  $decoded = json_decode((string) $account->get('field_docutracks_json')->value, TRUE);
  if (!is_array($decoded)) {
    return NULL;
  }

  /** @var \Drupal\side_api\DocutracksClient $client */
  $client = \Drupal::service('side_api.docutracks_client');
  return $client->extractValueByPath($decoded, $path);
}

/**
 * Implements hook_form_FORM_ID_alter() for user_edit form.
 */
function users_tweaks_form_user_form_alter(array &$form, FormStateInterface $form_state, string $form_id): void {
  $route_match = \Drupal::routeMatch();
  $account = $route_match->getParameter('user');
  if ($account instanceof UserInterface) {
    $non_kemke_user = $account->hasRole('api') ||
      $account->hasRole('administrator') ||
      $account->hasRole('amke_user') ||
      $account->hasRole('kemke_admin');
    $form['#title'] = users_tweaks_build_user_title($account);

    if (!$account->hasRole('amke_user')) {
      if (isset($form['field_legal_entity'])) {
        $form['field_legal_entity']['#access'] = FALSE;
      }
      if (isset($form['account']['field_legal_entity'])) {
        $form['account']['field_legal_entity']['#access'] = FALSE;
      }
    }

  }

  $current_user = \Drupal::currentUser();
  if (
    $account instanceof UserInterface &&
    $current_user->id() === $account->id() &&
    isset($form['account']['pass']) &&
    !\Drupal::request()->query->has('pass-reset-token')
  ) {
    // Keep profile updates independent from password reset validation.
    $form['account']['pass']['#required'] = FALSE;
  }

  if ($current_user->hasRole('administrator')) {
    return;
  }

  if (isset($form['actions']['delete'])) {
    unset($form['actions']['delete']);
  }

  if (isset($form['roles']['#options']['administrator'])) {
    unset($form['roles']['#options']['administrator']);
  }

  if (isset($form['account']['roles']['#options']['administrator'])) {
    unset($form['account']['roles']['#options']['administrator']);
  }
}

/**
 * Implements hook_form_FORM_ID_alter() for user cancel form.
 */
function users_tweaks_form_user_cancel_form_alter(array &$form, FormStateInterface $form_state, string $form_id): void {
  $current_user = \Drupal::currentUser();
  if ($current_user->hasRole('administrator')) {
    return;
  }

  if (!isset($form['user_cancel_method'])) {
    return;
  }

  $form['user_cancel_method']['#options'] = [
    'user_cancel_block' => 'αποκλεισμός χρήστη',
  ];
  $form['user_cancel_method']['#default_value'] = 'user_cancel_block';

  if (isset($form['user_cancel_method']['#title'])) {
    $form['user_cancel_method']['#title'] = '';
  }
  if (isset($form['user_cancel_confirm'])) {
    unset($form['user_cancel_confirm']);
  }

  $route_match = \Drupal::routeMatch();
  $account = $route_match->getParameter('user');
  if ($account instanceof UserInterface) {
    $form['#title'] = users_tweaks_build_cancel_title($account);
  }
}

/**
 * Implements hook_page_title_alter().
 */
function users_tweaks_page_title_alter(&$title, RouteMatchInterface $route_match): void {
  if ($route_match->getRouteName() !== 'entity.user.canonical' && $route_match->getRouteName() !== 'entity.user.cancel_form') {
    return;
  }

  $current_user = \Drupal::currentUser();
  if ($current_user->hasRole('administrator')) {
    return;
  }

  $account = $route_match->getParameter('user');
  if (!$account instanceof UserInterface) {
    return;
  }

  if ($route_match->getRouteName() === 'entity.user.cancel_form') {
    $title = users_tweaks_build_cancel_title($account);
    return;
  }

  $title = users_tweaks_build_user_title($account);
}

/**
 * Implements hook_entity_view_alter().
 */
function users_tweaks_entity_view_alter(array &$build, EntityInterface $entity, EntityViewDisplayInterface $display): void {
  if (!$entity instanceof UserInterface) {
    return;
  }

  $route_match = \Drupal::routeMatch();
  if ($route_match->getRouteName() !== 'entity.user.canonical') {
    return;
  }

  $build['#title'] = users_tweaks_build_user_title($entity);
  users_tweaks_add_roles_to_user_view($build, $entity);
}

/**
 * Add user role labels to the user view display.
 */
function users_tweaks_add_roles_to_user_view(array &$build, UserInterface $account): void {
  $role_ids = array_values(array_diff($account->getRoles(), ['authenticated']));
  if ($role_ids === []) {
    return;
  }

  $roles = \Drupal::entityTypeManager()
    ->getStorage('user_role')
    ->loadMultiple($role_ids);

  $labels = [];
  foreach ($role_ids as $role_id) {
    if (isset($roles[$role_id])) {
      $labels[] = $roles[$role_id]->label();
    }
  }

  if ($labels === []) {
    return;
  }

  $build['users_tweaks_roles'] = [
    '#type' => 'item',
    '#title' => t('Role'),
    '#plain_text' => implode(', ', $labels),
    '#weight' => 4,
  ];

  $build['#group_children'] = $build['#group_children'] ?? [];
  $build['#group_children']['users_tweaks_roles'] = 'group_general';
}

/**
 * Implements hook_toolbar_alter().
 */
function users_tweaks_toolbar_alter(array &$items): void {
  if (!isset($items['user']['tab'])) {
    return;
  }

  $current_user = \Drupal::currentUser();
  if (!$current_user->isAuthenticated()) {
    return;
  }

  $account = \Drupal::entityTypeManager()->getStorage('user')->load($current_user->id());
  if (!$account instanceof UserInterface) {
    return;
  }

  $title = users_tweaks_build_user_title($account);
  $role_label = users_tweaks_get_primary_role_label($account);
  if ($role_label !== NULL) {
    $title .= ' (' . $role_label . ')';
  }

  $items['user']['tab']['#title'] = $title;
  $cacheable_metadata = \Drupal\Core\Cache\CacheableMetadata::createFromRenderArray($items['user']['tab'])
    ->addCacheableDependency($account)
    ->addCacheContexts(['user', 'user.roles']);

  if ($account->hasRole('amke_user') && $account->hasField('field_legal_entity')) {
    $legal_entity = $account->get('field_legal_entity')->entity;
    if ($legal_entity) {
      $cacheable_metadata->addCacheableDependency($legal_entity);
    }
  }

  $cacheable_metadata->applyTo($items['user']['tab']);
}

/**
 * Get the first non-authenticated role label for a user.
 */
function users_tweaks_get_primary_role_label(UserInterface $account): ?string {
  if ($account->hasRole('amke_user') && $account->hasField('field_legal_entity')) {
    $legal_entity = $account->get('field_legal_entity')->entity;
    if ($legal_entity) {
      return $legal_entity->label();
    }
  }

  $role_ids = array_values(array_diff($account->getRoles(), ['authenticated']));
  if ($role_ids === []) {
    return NULL;
  }

  $roles = \Drupal::entityTypeManager()
    ->getStorage('user_role')
    ->loadMultiple($role_ids);

  foreach ($role_ids as $role_id) {
    if (isset($roles[$role_id])) {
      return $roles[$role_id]->label();
    }
  }

  return NULL;
}

/**
 * Build the user title based on name fields or username fallback.
 */
function users_tweaks_build_user_title(UserInterface $account): string {
  $first_name = $account->hasField('field_first_name')
    ? trim((string) $account->get('field_first_name')->value)
    : '';
  $last_name = $account->hasField('field_last_name')
    ? trim((string) $account->get('field_last_name')->value)
    : '';
  $full_name = trim($first_name . ' ' . $last_name);

  return $full_name !== '' ? $full_name : $account->getAccountName();
}

/**
 * Build the cancel page title based on name fields or username fallback.
 */
function users_tweaks_build_cancel_title(UserInterface $account): string {
  $last_name = $account->hasField('field_last_name')
    ? trim((string) $account->get('field_last_name')->value)
    : '';
  $first_name = $account->hasField('field_first_name')
    ? trim((string) $account->get('field_first_name')->value)
    : '';
  $full_name = trim($last_name . ' ' . $first_name);

  $target = $full_name !== '' ? $full_name : $account->getAccountName();
  return trim('αποκλεισμός χρήστη ' . $target);
}

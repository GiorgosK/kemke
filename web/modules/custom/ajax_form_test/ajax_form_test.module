<?php

/**
 * @file
 * Provides theme hooks for the Ajax Form Test module.
 */

/**
 * Implements hook_theme().
 */
function ajax_form_test_theme($existing, $type, $theme, $path) {
  return [
    'ajax_form_test_form' => [
      'render element' => 'form',
      'path' => $path . '/templates',
      'template' => 'ajax-form-test-form',
    ],
  ];
}

<?php

use Drupal\views\Plugin\views\query\Sql;
use Drupal\views\ViewExecutable;

/**
 * Implements hook_views_pre_view().
 */
function incoming_views_tweaks_views_pre_view(ViewExecutable $view, string $display_id, array &$args): void {
  if ($view->id() !== 'incoming') {
    return;
  }

  $request = \Drupal::request();
  $path = '/' . ltrim((string) $request->getPathInfo(), '/');
  if ($path !== '/incoming/all') {
    return;
  }

  $has_type_3 = incoming_views_tweaks_request_has_type_3($request->query->get('type'));

  if ($has_type_3) {
    incoming_views_tweaks_hide_view_field($view, 'field_incoming_type');
    incoming_views_tweaks_hide_view_field($view, 'field_incoming_type_1');
    return;
  }

  incoming_views_tweaks_hide_view_field($view, 'field_opinion_ref_id');
}

/**
 * Checks whether the exposed "type" filter contains the value 3.
 *
 * @param mixed $type_param
 *   Raw query value from ?type=...
 */
function incoming_views_tweaks_request_has_type_3($type_param): bool {
  if ($type_param === NULL || $type_param === '') {
    return FALSE;
  }

  if (is_array($type_param)) {
    foreach ($type_param as $value) {
      if ((string) $value === '3') {
        return TRUE;
      }
    }
    return FALSE;
  }

  foreach (explode(',', (string) $type_param) as $value) {
    if (trim($value) === '3') {
      return TRUE;
    }
  }

  return FALSE;
}

/**
 * Removes a field handler from the current Views display.
 */
function incoming_views_tweaks_hide_view_field(ViewExecutable $view, string $field_id): void {
  if (isset($view->display_handler->options['fields'][$field_id])) {
    unset($view->display_handler->options['fields'][$field_id]);
  }
  if (isset($view->field[$field_id])) {
    unset($view->field[$field_id]);
  }
}

/**
 * Implements hook_views_query_alter().
 */
function incoming_views_tweaks_views_query_alter(ViewExecutable $view, Sql $query): void {
  if ($view->id() !== 'incoming') {
    return;
  }

  $request = \Drupal::request();
  $path = '/' . ltrim((string) $request->getPathInfo(), '/');

  $is_incoming_scope_page = in_array($path, ['/incoming', '/incoming/all'], TRUE);
  $is_export = ($view->display_handler && $view->display_handler->getPluginId() === 'data_export');
  $is_completed_export = $request->query->getBoolean('from_completed');

  // Apply operator scoping only on /incoming and /incoming/all pages,
  // and for exports unless they are explicitly triggered from /incoming/completed.
  if (!$is_incoming_scope_page && !($is_export && !$is_completed_export)) {
    return;
  }

  $current_user = \Drupal::currentUser();
  $roles = $current_user->getRoles();
  $is_kemke_admin = in_array('kemke_admin', $roles, TRUE);
  $is_secretariat = in_array('secretariat', $roles, TRUE);
  $is_department_supervisor = in_array('department_supervisor', $roles, TRUE);
  $is_director_supervisor = in_array('director_supervisor', $roles, TRUE);
  $is_operator = in_array('operator', $roles, TRUE);

  // Admin, director supervisor and $is_secretariat should see all results.
  if ($is_kemke_admin || $is_director_supervisor || $is_secretariat) {
    return;
  }

  if (!$is_department_supervisor && !$is_operator) {
    return;
  }

  $uid = (int) $current_user->id();
  if ($uid <= 0) {
    return;
  }

  $base_alias = $query->ensureTable('node_field_data');
  if (!$base_alias) {
    return;
  }

  if ($is_department_supervisor) {
    $query->addWhereExpression(
      0,
      "EXISTS (
        SELECT 1
        FROM {node__field_supervisor} nfs
        WHERE nfs.entity_id = $base_alias.nid
          AND nfs.deleted = 0
          AND nfs.field_supervisor_target_id = :incoming_views_tweaks_uid
      )",
      [':incoming_views_tweaks_uid' => $uid]
    );
    return;
  }

  if ($is_operator) {
    $query->addWhereExpression(
      0,
      "(
        EXISTS (
          SELECT 1
          FROM {node__field_operators} nfo
          WHERE nfo.entity_id = $base_alias.nid
            AND nfo.deleted = 0
            AND nfo.field_operators_target_id = :incoming_views_tweaks_uid
        )
        OR EXISTS (
          SELECT 1
          FROM {node__field_basic_operator} nfbo
          WHERE nfbo.entity_id = $base_alias.nid
            AND nfbo.deleted = 0
            AND nfbo.field_basic_operator_target_id = :incoming_views_tweaks_uid
        )
      )",
      [':incoming_views_tweaks_uid' => $uid]
    );
  }
}

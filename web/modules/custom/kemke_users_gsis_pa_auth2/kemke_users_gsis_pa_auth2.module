  $data['kemke_gsis_pa_auth_audit']['table'] = [
    'group' => t('Ιστορικό συνδέσεων ΓΓΠΣ ΚΔΔ'),
    'base' => [
      'field' => 'id',
      'title' => t('Ιστορικό συνδέσεων ΓΓΠΣ ΚΔΔ'),
      'help' => t('Καταγραφές σύνδεσης και αποσύνδεσης μέσω GSIS PA.'),

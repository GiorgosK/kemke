<?php

use Drupal\Core\Datetime\DrupalDateTime;
use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Form\FormStateInterface;
use Drupal\taxonomy\TermInterface;

/**
 * Implements hook_entity_presave().
 */
function case_tweaks_entity_presave(EntityInterface $entity): void {
  if (!$entity instanceof TermInterface) {
    return;
  }

  if (!$entity->hasField('field_ref_id')) {
    return;
  }

  case_tweaks_populate_field_ref_id($entity);
  case_tweaks_store_original_name($entity);
  case_tweaks_refresh_name_from_fields($entity);
}

/**
 * Implements hook_entity_predelete().
 */
function case_tweaks_entity_predelete(EntityInterface $entity): void {
  if (!$entity instanceof TermInterface) {
    return;
  }

  if (!$entity->hasField('field_ref_id')) {
    return;
  }

  $parent_id = case_tweaks_parent_id($entity);
  if ($parent_id) {
    return;
  }

  case_tweaks_maybe_decrement_root_counter_on_delete($entity);
}

/**
 * Populates field_ref_id when empty or when parent changed.
 */
function case_tweaks_populate_field_ref_id(TermInterface $term): bool {
  if (!$term->get('field_ref_id')->isEmpty() && !case_tweaks_parent_changed($term)) {
    return FALSE;
  }

  if (case_tweaks_parent_changed_to_child($term)) {
    case_tweaks_maybe_decrement_root_counter($term);
  }
  elseif (case_tweaks_parent_changed_between_parents($term)) {
    case_tweaks_maybe_decrement_child_counter($term);
  }

  $term->set('field_ref_id', case_tweaks_generate_reference_id($term));
  return TRUE;
}

/**
 * Captures the user-provided name into field_name_typed when empty.
 */
function case_tweaks_store_original_name(TermInterface $term): void {
  if (!$term->hasField('field_name_typed')) {
    return;
  }

  $typed_name = trim((string) $term->get('field_name_typed')->value);
  if ($typed_name !== '') {
    return;
  }

  $name = trim((string) $term->getName());
  if ($name === '') {
    return;
  }

  $term->set('field_name_typed', $name);
}

/**
 * Recreates the term name as "field_name_typed - field_ref_id".
 */
function case_tweaks_refresh_name_from_fields(TermInterface $term): void {
  if ($term->get('field_ref_id')->isEmpty()) {
    return;
  }

  if (!$term->hasField('field_name_typed')) {
    return;
  }

  $parent_names = case_tweaks_parent_typed_names($term);
  $typed_name = trim((string) $term->get('field_name_typed')->value);
  if ($typed_name === '') {
    $typed_name = trim((string) $term->getName());
  }

  $ref_id = (string) $term->get('field_ref_id')->value;

  $parts = array_filter([
    ...$parent_names,
    $typed_name,
    $ref_id,
  ], static fn($part) => $part !== '');

  $term->setName(implode(' - ', $parts));
}

/**
 * Generates the CASE-#### identifier.
 */
function case_tweaks_generate_reference_id(TermInterface $term): string {
  $parent_id = case_tweaks_parent_id($term);
  if ($parent_id) {
    $parent = $term->get('parent')->entity;
    if (!$parent instanceof TermInterface) {
      $parent = \Drupal::entityTypeManager()->getStorage('taxonomy_term')->load($parent_id);
    }

    $parent_ref_id = '';
    if ($parent instanceof TermInterface && $parent->hasField('field_ref_id')) {
      $parent_ref_id = trim((string) $parent->get('field_ref_id')->value);
    }

    if ($parent_ref_id !== '') {
      $sequence = case_tweaks_next_child_sequence($parent, $parent_ref_id);
      return sprintf('%s-%d', $parent_ref_id, $sequence);
    }
  }

  $now = new DrupalDateTime('now');
  $year = (int) $now->format('Y');
  $sequence = case_tweaks_next_reference_sequence($year);

  return sprintf('CASE-%d-%d', $year, $sequence);
}

/**
 * Retrieves and increments the per-year reference ID counter.
 */
function case_tweaks_next_reference_sequence(int $year): int {
  $state = \Drupal::state();
  $lock = \Drupal::lock();
  $lock_name = "case_tweaks.ref_counter.$year";
  $counter_key = "case_tweaks.ref_counter.$year";

  $acquired = $lock->acquire($lock_name, 5.0);
  if (!$acquired) {
    \Drupal::logger('case_tweaks')->warning('Unable to acquire reference counter lock for @year, falling back to non-locked increment.', ['@year' => $year]);
  }

  $current = (int) $state->get($counter_key, 0);
  $next = max(1, $current + 1);
  $state->set($counter_key, $next);

  if ($acquired) {
    $lock->release($lock_name);
  }

  return $next;
}

/**
 * Retrieves and increments the per-parent child reference counter.
 */
function case_tweaks_next_child_sequence(TermInterface $parent, string $parent_ref_id): int {
  $state = \Drupal::state();
  $lock = \Drupal::lock();
  $parent_id = (int) $parent->id();
  $lock_name = "case_tweaks.child_counter.$parent_id";
  $counter_key = "case_tweaks.child_counter.$parent_id";

  $acquired = $lock->acquire($lock_name, 5.0);
  if (!$acquired) {
    \Drupal::logger('case_tweaks')->warning('Unable to acquire child counter lock for parent @parent, falling back to non-locked increment.', ['@parent' => $parent_id]);
  }

  $max_existing = case_tweaks_max_child_sequence($parent, $parent_ref_id);
  $next = max($max_existing + 1, 1);
  $state->set($counter_key, $next);

  if ($acquired) {
    $lock->release($lock_name);
  }

  return $next;
}

/**
 * Calculates the max child suffix currently in use for a parent ref id.
 */
function case_tweaks_max_child_sequence(TermInterface $parent, string $parent_ref_id): int {
  $storage = \Drupal::entityTypeManager()->getStorage('taxonomy_term');
  $children = $storage->loadTree($parent->bundle(), $parent->id(), 1, TRUE);
  if (empty($children)) {
    return 0;
  }

  $pattern = '/^' . preg_quote($parent_ref_id, '/') . '-([0-9]+)$/';
  $max = 0;
  foreach ($children as $child) {
    if (!$child->hasField('field_ref_id')) {
      continue;
    }
    $ref_id = trim((string) $child->get('field_ref_id')->value);
    if ($ref_id === '') {
      continue;
    }
    if (preg_match($pattern, $ref_id, $matches)) {
      $max = max($max, (int) $matches[1]);
    }
  }

  return $max;
}

/**
 * Returns the direct parent ID or NULL when the term is a root.
 */
function case_tweaks_parent_id(TermInterface $term): ?int {
  $parents = $term->get('parent')->getValue();
  $parent_id = $parents[0]['target_id'] ?? NULL;
  if (!$parent_id) {
    return NULL;
  }

  return (int) $parent_id;
}

/**
 * Determines whether the parent changed between saves.
 */
function case_tweaks_parent_changed(TermInterface $term): bool {
  if (!$term->get('field_ref_id')->isEmpty() && empty($term->original)) {
    return FALSE;
  }

  if (!$term->original instanceof TermInterface) {
    return FALSE;
  }

  $original_parent_id = case_tweaks_parent_id($term->original);
  $current_parent_id = case_tweaks_parent_id($term);

  return $original_parent_id !== $current_parent_id;
}

/**
 * Determines whether the term moved from root to child.
 */
function case_tweaks_parent_changed_to_child(TermInterface $term): bool {
  if (!$term->original instanceof TermInterface) {
    return FALSE;
  }

  $original_parent_id = case_tweaks_parent_id($term->original);
  $current_parent_id = case_tweaks_parent_id($term);

  return !$original_parent_id && (bool) $current_parent_id;
}

/**
 * Determines whether the term moved between two parents.
 */
function case_tweaks_parent_changed_between_parents(TermInterface $term): bool {
  if (!$term->original instanceof TermInterface) {
    return FALSE;
  }

  $original_parent_id = case_tweaks_parent_id($term->original);
  $current_parent_id = case_tweaks_parent_id($term);

  return $original_parent_id && $current_parent_id && $original_parent_id !== $current_parent_id;
}

/**
 * Decrements the global counter if the moved root was the latest sequence.
 */
function case_tweaks_maybe_decrement_root_counter(TermInterface $term): void {
  if (!$term->original instanceof TermInterface) {
    return;
  }

  if (!$term->original->hasField('field_ref_id')) {
    return;
  }

  $original_ref_id = trim((string) $term->original->get('field_ref_id')->value);
  if ($original_ref_id === '') {
    return;
  }

  if (!preg_match('/^CASE-(\d{4})-(\d+)$/', $original_ref_id, $matches)) {
    return;
  }

  $year = (int) $matches[1];
  $sequence = (int) $matches[2];

  $state = \Drupal::state();
  $counter_key = "case_tweaks.ref_counter.$year";
  $current = (int) $state->get($counter_key, 0);
  if ($current === $sequence && $current > 0) {
    $state->set($counter_key, $current - 1);
  }
}

/**
 * Decrements the global counter if a deleted root was the latest sequence.
 */
function case_tweaks_maybe_decrement_root_counter_on_delete(TermInterface $term): void {
  if (!$term->hasField('field_ref_id')) {
    return;
  }

  $ref_id = trim((string) $term->get('field_ref_id')->value);
  if ($ref_id === '') {
    return;
  }

  if (!preg_match('/^CASE-(\d{4})-(\d+)$/', $ref_id, $matches)) {
    return;
  }

  $year = (int) $matches[1];
  $sequence = (int) $matches[2];

  $state = \Drupal::state();
  $counter_key = "case_tweaks.ref_counter.$year";
  $current = (int) $state->get($counter_key, 0);
  if ($current === $sequence && $current > 0) {
    $state->set($counter_key, $current - 1);
  }
}

/**
 * Decrements the old parent counter if the moved child was the latest.
 */
function case_tweaks_maybe_decrement_child_counter(TermInterface $term): void {
  if (!$term->original instanceof TermInterface) {
    return;
  }

  $original_parent_id = case_tweaks_parent_id($term->original);
  if (!$original_parent_id) {
    return;
  }

  $storage = \Drupal::entityTypeManager()->getStorage('taxonomy_term');
  $original_parent = $storage->load($original_parent_id);
  if (!$original_parent instanceof TermInterface || !$original_parent->hasField('field_ref_id')) {
    return;
  }

  $original_parent_ref = trim((string) $original_parent->get('field_ref_id')->value);
  if ($original_parent_ref === '') {
    return;
  }

  if (!$term->original->hasField('field_ref_id')) {
    return;
  }

  $original_ref_id = trim((string) $term->original->get('field_ref_id')->value);
  if ($original_ref_id === '') {
    return;
  }

  $pattern = '/^' . preg_quote($original_parent_ref, '/') . '-([0-9]+)$/';
  if (!preg_match($pattern, $original_ref_id, $matches)) {
    return;
  }

  $sequence = (int) $matches[1];
  $state = \Drupal::state();
  $counter_key = 'case_tweaks.child_counter.' . (int) $original_parent_id;
  $current = (int) $state->get($counter_key, 0);
  if ($current === $sequence && $current > 0) {
    $state->set($counter_key, $current - 1);
  }
}

/**
 * Retrieves parent field_name_typed values from root to direct parent.
 */
function case_tweaks_parent_typed_names(TermInterface $term): array {
  $storage = \Drupal::entityTypeManager()->getStorage('taxonomy_term');

  $parents = $term->get('parent')->getValue();
  $parent_id = $parents[0]['target_id'] ?? NULL;
  if (!$parent_id) {
    return [];
  }

  $ancestors = $storage->loadAllParents($parent_id);
  if (empty($ancestors)) {
    return [];
  }

  // loadAllParents() returns the chain starting with the given term ID.
  // Reverse it to get root -> direct parent.
  $ancestors = array_reverse($ancestors, TRUE);

  $names = [];
  foreach ($ancestors as $ancestor) {
    $name = '';
    if ($ancestor->hasField('field_name_typed')) {
      $name = trim((string) $ancestor->get('field_name_typed')->value);
    }
    if ($name === '') {
      $name = trim((string) $ancestor->getName());
    }
    if ($name !== '') {
      $names[] = $name;
    }
  }

  return $names;
}

/**
 * Hides the typed name field and seeds it with a dummy value on creation.
 */
function case_tweaks_form_taxonomy_term_form_alter(array &$form, FormStateInterface $form_state, string $form_id): void {
  $term = $form_state->getFormObject()->getEntity();
  if (!$term instanceof TermInterface) {
    return;
  }

  // Only adjust the Case vocabulary on the add form.
  if ($term->bundle() !== 'case' || !$term->isNew()) {
    return;
  }

  if (!isset($form['name'])) {
    return;
  }

  // Make the name uneditable but pre-filled; the final name is computed later.
  if (isset($form['name'][0]['value'])) {
    $element = &$form['name'][0]['value'];
  }
  elseif (isset($form['name']['widget'][0]['value'])) {
    $element = &$form['name']['widget'][0]['value'];
  }
  else {
    return;
  }

  $element['#required'] = FALSE;
  $element['#value'] = 'AUTOCREATED';
  $element['#default_value'] = 'AUTOCREATED';
  $element['#attributes']['readonly'] = TRUE;
  $element['#description'] = t('Name is auto-generated.');

  // Seed user input so the form shows the value immediately.
  $input = $form_state->getUserInput();
  $input_name = $input['name'] ?? NULL;
  if (is_array($input_name)) {
    if (isset($input_name['value'])) {
      $input_name_value = $input_name['value'];
    }
    elseif (isset($input_name[0]['value'])) {
      $input_name_value = $input_name[0]['value'];
    }
    else {
      $input_name_value = reset($input_name);
    }
  }
  else {
    $input_name_value = $input_name;
  }

  if (trim((string) $input_name_value) === '') {
    $input['name'] = [['value' => 'AUTOCREATED']];
    $form_state->setUserInput($input);
  }

  // Ensure validation sees a value for name even though it's locked; run first.
  $form['#validate'] = array_merge(
    ['case_tweaks_taxonomy_term_form_prevalidate_name'],
    $form['#validate'] ?? []
  );
}

/**
 * Ensures the name field has a value before required validation runs.
 */
function case_tweaks_taxonomy_term_form_prevalidate_name(array &$form, FormStateInterface $form_state): void {
  if ($form_state->getFormObject()->getEntity()->bundle() !== 'case') {
    return;
  }

  $name_value = $form_state->getValue('name');

  // Flatten potential array values into a string for validation.
  if (is_array($name_value)) {
    if (isset($name_value['value'])) {
      $name_value = $name_value['value'];
    }
    elseif (isset($name_value[0]['value'])) {
      $name_value = $name_value[0]['value'];
    }
    else {
      $name_value = reset($name_value);
    }
  }

  $name = trim((string) $name_value);
  if ($name === '') {
    $auto_value = [['value' => 'AUTOCREATED']];
    $form_state->setValue('name', $auto_value);
    // Keep user input in sync so later processing sees the value.
    $input = $form_state->getUserInput();
    $input['name'] = $auto_value;
    $form_state->setUserInput($input);
  }
}

<?php

use Drupal\Core\Datetime\DrupalDateTime;
use Drupal\Core\Entity\EntityInterface;
use Drupal\taxonomy\TermInterface;

/**
 * Implements hook_entity_presave().
 */
function case_tweaks_entity_presave(EntityInterface $entity): void {
  if (!$entity instanceof TermInterface) {
    return;
  }

  if (!$entity->hasField('field_ref_id')) {
    return;
  }

  case_tweaks_populate_field_ref_id($entity);
  case_tweaks_append_ref_id_to_name($entity);
}

/**
 * Populates field_ref_id when empty.
 */
function case_tweaks_populate_field_ref_id(TermInterface $term): bool {
  if (!$term->get('field_ref_id')->isEmpty()) {
    return FALSE;
  }

  $term->set('field_ref_id', case_tweaks_generate_reference_id($term));
  return TRUE;
}

/**
 * Adds the ref ID to the term name when missing.
 */
function case_tweaks_append_ref_id_to_name(TermInterface $term): void {
  if ($term->get('field_ref_id')->isEmpty()) {
    return;
  }

  $ref_id = (string) $term->get('field_ref_id')->value;
  $name = trim((string) $term->getName());

  if ($name !== '' && str_ends_with($name, $ref_id)) {
    return;
  }

  $term->setName($name === '' ? $ref_id : "{$name} {$ref_id}");
}

/**
 * Generates the CASE-#### identifier.
 */
function case_tweaks_generate_reference_id(TermInterface $term): string {
  $now = new DrupalDateTime('now');
  $year = (int) $now->format('Y');
  $sequence = case_tweaks_next_reference_sequence($year);

  return sprintf('CASE-%d-%06d', $year, $sequence);
}

/**
 * Retrieves and increments the per-year reference ID counter.
 */
function case_tweaks_next_reference_sequence(int $year): int {
  $state = \Drupal::state();
  $lock = \Drupal::lock();
  $lock_name = "case_tweaks.ref_counter.$year";
  $counter_key = "case_tweaks.ref_counter.$year";

  $acquired = $lock->acquire($lock_name, 5.0);
  if (!$acquired) {
    \Drupal::logger('case_tweaks')->warning('Unable to acquire reference counter lock for @year, falling back to non-locked increment.', ['@year' => $year]);
  }

  $current = (int) $state->get($counter_key, 0);
  $next = max(1, $current + 1);
  $state->set($counter_key, $next);

  if ($acquired) {
    $lock->release($lock_name);
  }

  return $next;
}

<?php

use Drupal\Core\Datetime\DrupalDateTime;
use Drupal\Core\Entity\EntityInterface;
use Drupal\taxonomy\TermInterface;

/**
 * Implements hook_entity_presave().
 */
function case_tweaks_entity_presave(EntityInterface $entity): void {
  if (!$entity instanceof TermInterface) {
    return;
  }

  if (!$entity->hasField('field_ref_id')) {
    return;
  }

  case_tweaks_populate_field_ref_id($entity);
  case_tweaks_store_original_name($entity);
  case_tweaks_refresh_name_from_fields($entity);
}

/**
 * Populates field_ref_id when empty.
 */
function case_tweaks_populate_field_ref_id(TermInterface $term): bool {
  if (!$term->get('field_ref_id')->isEmpty()) {
    return FALSE;
  }

  $term->set('field_ref_id', case_tweaks_generate_reference_id($term));
  return TRUE;
}

/**
 * Captures the user-provided name into field_name_typed when empty.
 */
function case_tweaks_store_original_name(TermInterface $term): void {
  if (!$term->hasField('field_name_typed')) {
    return;
  }

  $typed_name = trim((string) $term->get('field_name_typed')->value);
  if ($typed_name !== '') {
    return;
  }

  $name = trim((string) $term->getName());
  if ($name === '') {
    return;
  }

  $term->set('field_name_typed', $name);
}

/**
 * Recreates the term name as "field_name_typed - field_ref_id".
 */
function case_tweaks_refresh_name_from_fields(TermInterface $term): void {
  if ($term->get('field_ref_id')->isEmpty()) {
    return;
  }

  if (!$term->hasField('field_name_typed')) {
    return;
  }

  $parent_names = case_tweaks_parent_typed_names($term);
  $typed_name = trim((string) $term->get('field_name_typed')->value);
  if ($typed_name === '') {
    $typed_name = trim((string) $term->getName());
  }

  $ref_id = (string) $term->get('field_ref_id')->value;

  $parts = array_filter([
    ...$parent_names,
    $typed_name,
    $ref_id,
  ], static fn($part) => $part !== '');

  $term->setName(implode(' - ', $parts));
}

/**
 * Generates the CASE-#### identifier.
 */
function case_tweaks_generate_reference_id(TermInterface $term): string {
  $now = new DrupalDateTime('now');
  $year = (int) $now->format('Y');
  $sequence = case_tweaks_next_reference_sequence($year);

  return sprintf('CASE-%d-%06d', $year, $sequence);
}

/**
 * Retrieves and increments the per-year reference ID counter.
 */
function case_tweaks_next_reference_sequence(int $year): int {
  $state = \Drupal::state();
  $lock = \Drupal::lock();
  $lock_name = "case_tweaks.ref_counter.$year";
  $counter_key = "case_tweaks.ref_counter.$year";

  $acquired = $lock->acquire($lock_name, 5.0);
  if (!$acquired) {
    \Drupal::logger('case_tweaks')->warning('Unable to acquire reference counter lock for @year, falling back to non-locked increment.', ['@year' => $year]);
  }

  $current = (int) $state->get($counter_key, 0);
  $next = max(1, $current + 1);
  $state->set($counter_key, $next);

  if ($acquired) {
    $lock->release($lock_name);
  }

  return $next;
}

/**
 * Retrieves parent field_name_typed values from root to direct parent.
 */
function case_tweaks_parent_typed_names(TermInterface $term): array {
  $storage = \Drupal::entityTypeManager()->getStorage('taxonomy_term');

  $parents = $term->get('parent')->getValue();
  $parent_id = $parents[0]['target_id'] ?? NULL;
  if (!$parent_id) {
    return [];
  }

  $ancestors = $storage->loadAllParents($parent_id);
  if (empty($ancestors)) {
    return [];
  }

  // loadAllParents() returns the chain starting with the given term ID.
  // Reverse it to get root -> direct parent.
  $ancestors = array_reverse($ancestors, TRUE);

  $names = [];
  foreach ($ancestors as $ancestor) {
    $name = '';
    if ($ancestor->hasField('field_name_typed')) {
      $name = trim((string) $ancestor->get('field_name_typed')->value);
    }
    if ($name === '') {
      $name = trim((string) $ancestor->getName());
    }
    if ($name !== '') {
      $names[] = $name;
    }
  }

  return $names;
}

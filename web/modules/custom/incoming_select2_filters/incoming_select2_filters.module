<?php

use Drupal\Core\Form\FormStateInterface;
use Drupal\views\ViewExecutable;

/**
 * Implements hook_form_FORM_ID_alter() for Views exposed forms.
 */
function incoming_select2_filters_form_views_exposed_form_alter(array &$form, FormStateInterface $form_state): void {
  $view = $form_state->get('view');
  if (!$view instanceof ViewExecutable) {
    return;
  }

  // Target the "incoming" view only. Adjust $allowed_displays or $filters if
  // you add more displays or filters later.
  if ($view->id() !== 'incoming') {
    return;
  }

  $allowed_displays = ['page_1', 'default', 'page'];
  if (!in_array($view->current_display, $allowed_displays, TRUE)) {
    return;
  }

  // Filter machine names to convert to Select2.
  $filters = [
    'field_case_result_target_id',
    'case', // Fallback if filter machine name differs.
  ];

  foreach ($filters as $filter_key) {
    if (empty($form[$filter_key]) || !is_array($form[$filter_key])) {
      continue;
    }

    $element = &$form[$filter_key];

    // Only act on select-like elements with options.
    if (empty($element['#options']) || !is_array($element['#options'])) {
      continue;
    }

    // Switch to select2 element type.
    $element['#type'] = 'select2';
    $element['#attributes']['class'][] = 'select2-widget';

    // Improve UX: allow clearing and set placeholder from the empty option.
    $element['#select2']['allowClear'] = TRUE;
    if (!empty($element['#empty_option'])) {
      $element['#select2']['placeholder'] = $element['#empty_option'];
    }
  }
}

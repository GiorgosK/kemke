<?php

use Drupal\Core\Datetime\DrupalDateTime;
use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Form\FormStateInterface;
use Drupal\datetime\Plugin\Field\FieldType\DateTimeItemInterface;
use Drupal\node\NodeInterface;

/**
 * Implements hook_form_BASE_FORM_ID_alter() for node forms.
 */
function incoming_tweaks_form_node_form_alter(array &$form, FormStateInterface $form_state, $form_id): void {
  $current_user = \Drupal::currentUser();

  if (!$current_user->hasPermission('administer nodes') && isset($form['revision_information'])) {
    // Remove revision tab entirely for non-admin users.
    $form['revision_information']['#access'] = FALSE;
  }
}

/**
 * Implements hook_entity_presave().
 */
function incoming_tweaks_entity_presave(EntityInterface $entity): void {
  if (!$entity instanceof NodeInterface || $entity->bundle() !== 'incoming') {
    return;
  }

  $is_new = $entity->isNew();

  incoming_tweaks_skip_director_gate_for_director($entity);
  $baseline = incoming_tweaks_ensure_entry_date($entity);
  incoming_tweaks_set_initial_legal_deadline($entity, $baseline);
  incoming_tweaks_recalculate_deadline_on_state_transition($entity);
  incoming_tweaks_set_completion_date_on_publish($entity);

  incoming_tweaks_remove_primary_from_newly_related($entity);

  if ($is_new) {
    incoming_tweaks_set_primary_flag($entity);
    incoming_tweaks_add_self_related_incoming($entity);
  }
  else {
    incoming_tweaks_populate_field_ref_id($entity);
  }
}

/**
 * Ensures field_entry_date is set and returns the normalized baseline date.
 */
function incoming_tweaks_ensure_entry_date(NodeInterface $node): DrupalDateTime {
  $baseline = NULL;

  if ($node->get('field_entry_date')->isEmpty()) {
    $entry_date = new DrupalDateTime('now');
    $entry_date->setTime(0, 0, 0);
    $node->set('field_entry_date', [
      'value' => $entry_date->format(DateTimeItemInterface::DATE_STORAGE_FORMAT),
    ]);
    $baseline = clone $entry_date;
  }
  else {
    $entry_item = $node->get('field_entry_date')->first();
    if ($entry_item) {
      $value = $entry_item->getValue()['value'] ?? NULL;
      if ($value) {
        try {
          $baseline = DrupalDateTime::createFromFormat(DateTimeItemInterface::DATE_STORAGE_FORMAT, $value, new \DateTimeZone(DateTimeItemInterface::STORAGE_TIMEZONE));
        }
        catch (\Exception $exception) {
          // Fall through to the default baseline when parsing fails.
        }
      }
    }
  }

  $baseline = $baseline ?: new DrupalDateTime('now');
  $baseline->setTime(0, 0, 0);

  return $baseline;
}

/**
 * Calculates field_legal_deadline when a new attachment is initiated.
 */
function incoming_tweaks_set_initial_legal_deadline(NodeInterface $node, DrupalDateTime $baseline): void {
  if ($node->get('field_legal_deadline')->isEmpty()) {
    $deadline = incoming_tweaks_calculate_workday_deadline(20, $baseline);
    $node->set('field_legal_deadline', [
      'value' => $deadline->format(DateTimeItemInterface::DATE_STORAGE_FORMAT),
    ]);
  }
}

/**
 * Recalculates field_legal_deadline when moving from pending_issues to fullness_check.
 */
function incoming_tweaks_recalculate_deadline_on_state_transition(NodeInterface $node): void {
  if (
    $node->isNew() ||
    !$node->hasField('moderation_state') ||
    !$node->original instanceof EntityInterface ||
    $node->get('moderation_state')->isEmpty()
  ) {
    return;
  }

  $previous_state = $node->original->get('moderation_state')->isEmpty() ? NULL : $node->original->get('moderation_state')->value;
  $current_state = $node->get('moderation_state')->value;

  if ($previous_state === 'pending_issues' && $current_state === 'fullness_check') {
    $deadline_baseline = new DrupalDateTime('now');
    $deadline_baseline->setTime(0, 0, 0);
    $deadline = incoming_tweaks_calculate_workday_deadline(20, $deadline_baseline);
    $node->set('field_legal_deadline', [
      'value' => $deadline->format(DateTimeItemInterface::DATE_STORAGE_FORMAT),
    ]);
  }
}

/**
 * Skips director approval when the change is made by a director.
 */
function incoming_tweaks_skip_director_gate_for_director(NodeInterface $node): void {
  if (
    $node->isNew() ||
    !$node->hasField('moderation_state') ||
    !$node->original instanceof EntityInterface ||
    $node->get('moderation_state')->isEmpty()
  ) {
    return;
  }

  $previous_state = $node->original->get('moderation_state')->isEmpty() ? NULL : $node->original->get('moderation_state')->value;
  $current_state = $node->get('moderation_state')->value;
  $account = \Drupal::currentUser();

  // If a director is moving from supervisor approval to director approval,
  // complete the approval immediately.
  $director_roles = ['director_supervisor'];
  $is_director = (bool) array_intersect($director_roles, $account->getRoles());

  if ($is_director && $previous_state === 'for_supervisor_approval' && $current_state === 'for_director_approval') {
    $node->set('moderation_state', 'approved');
  }
}

/**
 * Sets field_completion_date when the moderation state moves to published.
 */
function incoming_tweaks_set_completion_date_on_publish(NodeInterface $node): void {
  if (
    !$node->hasField('moderation_state') ||
    $node->get('moderation_state')->isEmpty() ||
    !$node->hasField('field_completion_date') ||
    !$node->get('field_completion_date')->isEmpty()
  ) {
    return;
  }

  $current_state = $node->get('moderation_state')->value;
  if ($current_state !== 'published') {
    return;
  }

  $previous_state = NULL;
  if (!$node->isNew() && $node->original instanceof EntityInterface && !$node->original->get('moderation_state')->isEmpty()) {
    $previous_state = $node->original->get('moderation_state')->value;
  }

  // Only set completion date when entering the published state.
  if ($previous_state !== 'published') {
    $completion_date = new DrupalDateTime('now');
    $completion_date->setTime(0, 0, 0);
    $node->set('field_completion_date', [
      'value' => $completion_date->format(DateTimeItemInterface::DATE_STORAGE_FORMAT),
    ]);
  }
}

/**
 * Ensures field_primary is set to on for new incoming nodes.
 */
function incoming_tweaks_set_primary_flag(NodeInterface $node): void {
  if ($node->hasField('field_primary')) {
  $node->set('field_primary', 1);
  }
}

/**
 * Marks newly-related incoming nodes as non-primary.
 */
function incoming_tweaks_remove_primary_from_newly_related(NodeInterface $node): void {
  if (!$node->hasField('field_related_incoming') || !$node->original instanceof EntityInterface) {
    return;
  }

  $current_ids = [];
  foreach ($node->get('field_related_incoming') as $item) {
    if (!empty($item->target_id)) {
      $current_ids[] = (int) $item->target_id;
    }
  }

  $original_ids = [];
  foreach ($node->original->get('field_related_incoming') as $item) {
    if (!empty($item->target_id)) {
      $original_ids[] = (int) $item->target_id;
    }
  }

  $new_ids = array_diff($current_ids, $original_ids);
  if (!$new_ids) {
    return;
  }

  /** @var \Drupal\node\NodeStorageInterface $storage */
  $storage = \Drupal::entityTypeManager()->getStorage('node');
  $related_nodes = $storage->loadMultiple($new_ids);

  foreach ($related_nodes as $related) {
    if (!$related instanceof NodeInterface || !$related->hasField('field_primary')) {
      continue;
    }

    $related->set('field_primary', 0);
    $related->setNewRevision(FALSE);
    $related->save();
  }
}

/**
 * Adds a self-reference to field_related_incoming when available.
 */
function incoming_tweaks_add_self_related_incoming(NodeInterface $node): void {
  if (!$node->hasField('field_related_incoming')) {
    return;
  }

  $target_id = $node->id();
  if (!$target_id) {
    // No ID yet (e.g., first presave on new entity), nothing to link.
    return;
  }

  $related_field = $node->get('field_related_incoming');
  foreach ($related_field as $item) {
    if ((int) $item->target_id === (int) $target_id) {
      return;
    }
  }

  $related_field->appendItem(['target_id' => $target_id]);
}

/**
 * Implements hook_ENTITY_TYPE_insert() for nodes.
 */
function incoming_tweaks_node_insert(NodeInterface $node): void {
  if ($node->bundle() !== 'incoming') {
    return;
  }

  incoming_tweaks_add_self_related_incoming($node);
  incoming_tweaks_assign_reference_id($node);
}

/**
 * Calculates a date N working days from today.
 */
function incoming_tweaks_calculate_workday_deadline(int $work_days, ?DrupalDateTime $start_date = NULL): DrupalDateTime {
  $deadline = $start_date ? clone $start_date : new DrupalDateTime('now');
  $deadline->setTime(0, 0, 0);
  $added_days = 0;
  $holiday_cache = [];

  while ($added_days < $work_days) {
    $deadline->modify('+1 day');
    // Skip Saturdays (6) and Sundays (7).
    if (in_array((int) $deadline->format('N'), [6, 7], TRUE)) {
      continue;
    }

    $year = (int) $deadline->format('Y');
    if (!isset($holiday_cache[$year])) {
      $holiday_cache[$year] = array_flip(incoming_tweaks_fetch_greek_public_holidays($year));
    }

    if (isset($holiday_cache[$year][$deadline->format('Y-m-d')])) {
      continue;
    }

    $added_days++;
  }

  return $deadline;
}

/**
 * Returns the list of Greek public holidays for the provided year.
 */
function incoming_tweaks_fetch_greek_public_holidays(int $year): array {
  static $holidays = [];
  if (isset($holidays[$year])) {
    return $holidays[$year];
  }

  $cid = "incoming_tweaks:holidays:$year";
  $cache = \Drupal::cache()->get($cid);
  if ($cache) {
    return $holidays[$year] = $cache->data;
  }

  $holiday_dates = [];

  try {
    $client = \Drupal::httpClient();
    $response = $client->get("https://date.nager.at/api/v3/PublicHolidays/{$year}/GR", ['timeout' => 5]);

    if ($response->getStatusCode() === 200) {
      $data = json_decode((string) $response->getBody(), TRUE) ?: [];
      foreach ($data as $holiday) {
        if (!empty($holiday['date'])) {
          $holiday_dates[] = $holiday['date'];
        }
      }
      \Drupal::logger('incoming_tweaks')->info('Fetched @count Greek holiday dates for @year: @dates.', [
        '@count' => count($holiday_dates),
        '@year' => $year,
        '@dates' => implode(', ', $holiday_dates),
      ]);
    }
  }
  catch (\Exception $exception) {
    \Drupal::logger('incoming_tweaks')->warning('Unable to fetch holidays for @year: @message', [
      '@year' => $year,
      '@message' => $exception->getMessage(),
    ]);
  }

  \Drupal::cache()->set($cid, $holiday_dates, time() + 86400);
  return $holidays[$year] = $holiday_dates;
}

/**
 * Ensures an auto-generated reference ID exists for the incoming node.
 */
function incoming_tweaks_assign_reference_id(NodeInterface $node): void {
  $updated = incoming_tweaks_populate_field_ref_id($node);

  if ($updated) {
    $reference = (string) $node->get('field_ref_id')->value;
    if ($reference !== '' && $node->label() !== $reference) {
      $node->setTitle($reference);
    }
  }

  // Avoid creating a revision just for the auto-generated values.
  $node->setNewRevision(FALSE);
  $node->save();
}

/**
 * Populates the reference ID field on existing nodes when empty.
 */
function incoming_tweaks_populate_field_ref_id(NodeInterface $node): bool {
  if (!$node->hasField('field_ref_id') || !$node->get('field_ref_id')->isEmpty()) {
    return FALSE;
  }

  $node->set('field_ref_id', incoming_tweaks_generate_reference_id($node));
  return TRUE;
}

/**
 * Generates the INC-#### identifier.
 */
function incoming_tweaks_generate_reference_id(NodeInterface $node): string {
  $now = new DrupalDateTime('now');
  $year = (int) $now->format('Y');
  $sequence = incoming_tweaks_next_reference_sequence($year);

  return sprintf('INC-%d-%06d', $year, $sequence);
}

/**
 * Retrieves and increments the per-year reference ID counter.
 */
function incoming_tweaks_next_reference_sequence(int $year): int {
  $state = \Drupal::state();
  $lock = \Drupal::lock();
  $lock_name = "incoming_tweaks.ref_counter.$year";
  $counter_key = "incoming_tweaks.ref_counter.$year";

  // Guard against concurrent increments to keep the counter consistent.
  $acquired = $lock->acquire($lock_name, 5.0);
  if (!$acquired) {
    \Drupal::logger('incoming_tweaks')->warning('Unable to acquire reference counter lock for @year, falling back to non-locked increment.', ['@year' => $year]);
  }

  $current = (int) $state->get($counter_key, 0);
  $next = max(1, $current + 1);
  $state->set($counter_key, $next);

  if ($acquired) {
    $lock->release($lock_name);
  }

  return $next;
}

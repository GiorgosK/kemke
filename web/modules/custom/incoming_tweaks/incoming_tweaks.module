<?php

use Drupal\Core\Datetime\DrupalDateTime;
use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Link;
use Drupal\Core\Url;
use Drupal\Core\Render\Markup;
use Drupal\Component\Serialization\Json;
use Drupal\Core\Messenger\MessengerInterface;
use Drupal\Core\Render\Element;
use Drupal\Component\Utility\Unicode;
use Drupal\datetime\Plugin\Field\FieldType\DateTimeItemInterface;
use Drupal\file\Entity\File;
use Drupal\node\NodeInterface;

/**
 * Implements hook_form_BASE_FORM_ID_alter() for node forms.
 */
function incoming_tweaks_form_node_form_alter(array &$form, FormStateInterface $form_state, $form_id): void {
  $current_user = \Drupal::currentUser();
  $entity = $form_state->getFormObject()->getEntity();
  $is_incoming_form = $entity instanceof NodeInterface && $entity->bundle() === 'incoming';

  if ($is_incoming_form) {
    $form['#after_build'][] = 'incoming_tweaks_after_build_set_remarks_add_more_label';
    incoming_tweaks_set_remarks_add_more_label($form);
  }

  // Skip tweaks during paragraphs add-more AJAX rebuilds to avoid breaking subforms.
  if (incoming_tweaks_is_remarks_add_more($form_state)) {
    return;
  }

  if (!$current_user->hasPermission('administer nodes') && isset($form['revision_information'])) {
    // Remove revision tab entirely for non-admin users.
    $form['revision_information']['#access'] = FALSE;
  }

  if (!in_array('administrator', $current_user->getRoles(), TRUE)) {
    // Hide "Εμπρόθεσμο" fieldset/tab and its fields for non-admin users.
    foreach (['group_on_time', 'edit_group_on_time'] as $group_key) {
      if (isset($form[$group_key]) && is_array($form[$group_key])) {
        $form[$group_key]['#access'] = FALSE;
      }
    }

    foreach (['field_on_time_obj1', 'field_on_time_obj2', 'field_on_time_obj3', 'field_on_time_obj5'] as $field_key) {
      if (isset($form[$field_key]) && is_array($form[$field_key])) {
        $form[$field_key]['#access'] = FALSE;
      }
    }
  }

  // Post-submit cleanup: if Docutracks failed, remove core status messages.
  if (isset($form['actions']['submit']['#submit']) && is_array($form['actions']['submit']['#submit'])) {
    $form['actions']['submit']['#submit'][] = 'incoming_tweaks_clear_status_on_docutracks_failure';
  }
  else {
    $form['#submit'][] = 'incoming_tweaks_clear_status_on_docutracks_failure';
  }

  if (isset($form['field_related_incoming']['widget']) && is_array($form['field_related_incoming']['widget'])) {
    $form['field_related_incoming']['widget']['#after_build'][] = 'incoming_tweaks_mark_new_related_rows_after_build';
  }

  if (
    $entity instanceof NodeInterface &&
    $entity->bundle() === 'incoming' &&
    isset($form['field_plan']['widget']) &&
    is_array($form['field_plan']['widget'])
  ) {
    $form['field_plan']['widget']['#after_build'][] = 'incoming_tweaks_limit_plan_widget';
  }

  if ($is_incoming_form) {
    $is_new_incoming = $entity->isNew();
    if ($is_new_incoming) {
      $form['#validate'][] = 'incoming_tweaks_validate_sender_protocol_unique_current_year';
    }

    incoming_tweaks_apply_legal_entity_hierarchy($form);

    if (isset($form['actions']['submit'])) {
      $submit_handlers = $form['actions']['submit']['#submit'] ?? [];
      if (!is_array($submit_handlers)) {
        $submit_handlers = [$submit_handlers];
      }
      $form['actions']['#prefix'] = '<div id="incoming-tweaks-actions-wrapper">';
      $form['actions']['#suffix'] = '</div>';
      $conflict_visible = (bool) $form_state->get('incoming_tweaks_protocol_conflict_visible');
      $form['actions']['override_submit'] = [
        '#type' => 'submit',
        '#value' => t('@label (παράκαψμη ελέγχου Α.Π. Αποστολέα)', [
          '@label' => (string) ($form['actions']['submit']['#value'] ?? t('Αποθήκευση')),
        ]),
        '#weight' => 5,
        '#button_type' => 'secondary',
        '#name' => 'override_submit',
        '#access' => $is_new_incoming && $conflict_visible,
        '#submit' => array_merge(['incoming_tweaks_override_protocol_conflict_submit'], $submit_handlers),
      ];
    }

    if ($is_new_incoming && isset($form['field_protocol_number_sender']['widget'][0]['value'])) {
      $form['field_protocol_number_sender']['widget'][0]['value']['#ajax'] = [
        'callback' => 'incoming_tweaks_protocol_sender_ajax_refresh_actions',
        'event' => 'change',
        'wrapper' => 'incoming-tweaks-actions-wrapper',
      ];
    }
  }
}

/**
 * Normalizes the remarks add-more button label on incoming forms.
 */
function incoming_tweaks_set_remarks_add_more_label(array &$form): void {
  incoming_tweaks_set_remarks_add_more_label_recursive($form);
}

/**
 * Recursively updates the remarks add-more button label.
 */
function incoming_tweaks_set_remarks_add_more_label_recursive(array &$element): void {
  $is_target = (($element['#name'] ?? NULL) === 'field_remarks_remark_add_more')
    || (($element['#id'] ?? NULL) === 'field-remarks-remark-add-more');

  if ($is_target) {
    $element['#value'] = t('Προσθήκη Παρατήρησης');
  }

  foreach (Element::children($element) as $child) {
    if (isset($element[$child]) && is_array($element[$child])) {
      incoming_tweaks_set_remarks_add_more_label_recursive($element[$child]);
    }
  }
}

/**
 * After-build guard to keep the remarks add-more label normalized.
 */
function incoming_tweaks_after_build_set_remarks_add_more_label(array $form, FormStateInterface $form_state): array {
  incoming_tweaks_set_remarks_add_more_label($form);
  return $form;
}

/**
 * Ensure legal entity options preserve hierarchy in incoming forms.
 */
function incoming_tweaks_apply_legal_entity_hierarchy(array &$form): void {
  if (empty($form['field_legal_entity']) || !is_array($form['field_legal_entity'])) {
    return;
  }

  $options = incoming_tweaks_build_legal_entity_hierarchy_options();
  if ($options === []) {
    return;
  }

  if (
    isset($form['field_legal_entity']['widget'])
    && is_array($form['field_legal_entity']['widget'])
    && isset($form['field_legal_entity']['widget']['#options'])
    && is_array($form['field_legal_entity']['widget']['#options'])
  ) {
    $empty = $form['field_legal_entity']['widget']['#empty_option'] ?? ($form['field_legal_entity']['widget']['#options'][''] ?? NULL);
    $form['field_legal_entity']['widget']['#options'] = $options;
    if ($empty !== NULL) {
      $form['field_legal_entity']['widget']['#options'] = ['' => $empty] + $options;
    }
    return;
  }

  if (
    isset($form['field_legal_entity']['widget'][0]['target_id'])
    && is_array($form['field_legal_entity']['widget'][0]['target_id'])
    && isset($form['field_legal_entity']['widget'][0]['target_id']['#options'])
    && is_array($form['field_legal_entity']['widget'][0]['target_id']['#options'])
  ) {
    $empty = $form['field_legal_entity']['widget'][0]['target_id']['#empty_option'] ?? ($form['field_legal_entity']['widget'][0]['target_id']['#options'][''] ?? NULL);
    $form['field_legal_entity']['widget'][0]['target_id']['#options'] = $options;
    if ($empty !== NULL) {
      $form['field_legal_entity']['widget'][0]['target_id']['#options'] = ['' => $empty] + $options;
    }
  }
}

/**
 * Build legal entity option labels with depth prefixes for Select2.
 */
function incoming_tweaks_build_legal_entity_hierarchy_options(): array {
  $storage = \Drupal::entityTypeManager()->getStorage('taxonomy_term');
  $tree = $storage->loadTree('legal_entity', 0, NULL, FALSE);
  if (!$tree) {
    return [];
  }

  $options = [];
  foreach ($tree as $term) {
    $depth = isset($term->depth) ? (int) $term->depth : 0;
    $prefix = $depth > 0 ? str_repeat('-', $depth) . ' ' : '';
    $options[(string) $term->tid] = $prefix . $term->name;
  }

  return $options;
}

/**
 * Limits the plan widget to a single attachment on incoming edit forms.
 */
function incoming_tweaks_limit_plan_widget(array $element, FormStateInterface $form_state): array {
  $form_object = $form_state->getFormObject();
  if (!$form_object || !method_exists($form_object, 'getEntity')) {
    return $element;
  }

  $entity = $form_object->getEntity();
  if (!$entity instanceof NodeInterface || $entity->bundle() !== 'incoming') {
    return $element;
  }

  $plan_count = $entity->get('field_plan')->count();
  if (isset($element['add_more'])) {
    $element['add_more']['#access'] = FALSE;
  }

  foreach (Element::children($element) as $delta) {
    if (is_numeric($delta) && (int) $delta >= 1) {
      $element[$delta]['#access'] = FALSE;
    }
  }

  if (isset($element['#description'])) {
    $element['#description'] = '';
  }

  return $element;
}

/**
 * Form-level validation for unique sender protocol per year.
 */
function incoming_tweaks_validate_sender_protocol_unique_current_year(array &$form, FormStateInterface $form_state): void {
  if (incoming_tweaks_is_remarks_add_more($form_state)) {
    return;
  }
  $form_object = $form_state->getFormObject();
  if (!$form_object || !method_exists($form_object, 'getEntity')) {
    return;
  }

  $entity = $form_object->getEntity();
  if (!$entity instanceof NodeInterface || $entity->bundle() !== 'incoming') {
    return;
  }
  if (!$entity->isNew()) {
    return;
  }
  if (!$entity->isNew()) {
    $form_state->set('incoming_tweaks_protocol_conflict_visible', FALSE);
    return;
  }

  $protocol_value = trim((string) $form_state->getValue(['field_protocol_number_sender', 0, 'value'], ''));
  if ($protocol_value === '') {
    return;
  }

  $trigger = $form_state->getTriggeringElement();
  if (($trigger['#name'] ?? '') === 'override_submit') {
    return;
  }

  $current_year = (int) (new \DateTimeImmutable('now'))->format('Y');

  $current_nid = (int) ($entity->id() ?? 0);
  $match = incoming_tweaks_find_protocol_conflict($protocol_value, $current_nid, $current_year);
  if (!$match instanceof NodeInterface) {
    $form_state->set('incoming_tweaks_protocol_conflict_visible', FALSE);
    return;
  }
  $form_state->set('incoming_tweaks_protocol_conflict_visible', TRUE);
  $form_state->setRebuild(TRUE);

  $match_entry_date = '';
  if ($match->hasField('field_entry_date') && !$match->get('field_entry_date')->isEmpty()) {
    $match_entry_date = (string) ($match->get('field_entry_date')->value ?? '');
  }

  $match_subject = '';
  if ($match->hasField('field_subject') && !$match->get('field_subject')->isEmpty()) {
    $match_subject = trim((string) ($match->get('field_subject')->value ?? ''));
  }
  if ($match_subject === '') {
    $match_subject = $match->label();
  }

  $match_label = $match->hasField('field_ref_id') && !$match->get('field_ref_id')->isEmpty()
    ? (string) ($match->get('field_ref_id')->value ?? $match->label())
    : $match->label();
  $date_label = $match_entry_date !== '' ? $match_entry_date : '-';
  $message = t('Το πρωτόκολλο αποστολέα "@protocol" υπάρχει ήδη για το έτος @year με το εγγραφο @ref - @date.<br>Αν θέλετε να το αποστείλετε ξανά, πατήστε το κουμπι παράκαμψης.', [
    '@protocol' => $protocol_value,
    '@year' => $current_year,
    '@ref' => $match_label,
    '@date' => $date_label,
  ]);
  $form_state->setErrorByName('field_protocol_number_sender', Markup::create($message));
}

/**
 * Finds a conflicting incoming by protocol number and year.
 */
function incoming_tweaks_find_protocol_conflict(string $protocol_value, int $current_nid, int $year): ?NodeInterface {
  if ($protocol_value === '') {
    return NULL;
  }

  $is_entry_datetime = incoming_tweaks_entry_date_is_datetime();
  $year_start = $is_entry_datetime
    ? sprintf('%d-01-01T00:00:00', $year)
    : sprintf('%d-01-01', $year);
  $year_end = $is_entry_datetime
    ? sprintf('%d-12-31T23:59:59', $year)
    : sprintf('%d-12-31', $year);

  $query = \Drupal::entityTypeManager()->getStorage('node')->getQuery()
    ->accessCheck(FALSE)
    ->condition('type', 'incoming')
    ->condition('field_protocol_number_sender', $protocol_value)
    ->condition('field_entry_date', $year_start, '>=')
    ->condition('field_entry_date', $year_end, '<=')
    ->range(0, 1);

  if ($current_nid > 0) {
    $query->condition('nid', $current_nid, '<>');
  }

  $match_ids = $query->execute();
  if (empty($match_ids)) {
    return NULL;
  }

  $match_id = (int) reset($match_ids);
  $match = \Drupal::entityTypeManager()->getStorage('node')->load($match_id);
  return $match instanceof NodeInterface ? $match : NULL;
}

/**
 * Submit handler for the override save button.
 */
function incoming_tweaks_override_protocol_conflict_submit(array &$form, FormStateInterface $form_state): void {
  $form_state->set('incoming_tweaks_protocol_conflict_visible', TRUE);
}

/**
 * AJAX callback to refresh the actions area.
 */
function incoming_tweaks_protocol_sender_ajax_refresh_actions(array &$form, FormStateInterface $form_state): array {
  if (incoming_tweaks_is_remarks_add_more($form_state)) {
    return $form['actions'];
  }
  $form_object = $form_state->getFormObject();
  if ($form_object && method_exists($form_object, 'getEntity')) {
    $entity = $form_object->getEntity();
    if ($entity instanceof NodeInterface && $entity->bundle() === 'incoming') {
      if (!$entity->isNew()) {
        $form_state->set('incoming_tweaks_protocol_conflict_visible', FALSE);
        return $form['actions'];
      }
      $protocol_value = trim((string) $form_state->getValue(['field_protocol_number_sender', 0, 'value'], ''));
      $current_year = (int) (new \DateTimeImmutable('now'))->format('Y');
      $current_nid = (int) ($entity->id() ?? 0);
      $match = incoming_tweaks_find_protocol_conflict($protocol_value, $current_nid, $current_year);
      $form_state->set('incoming_tweaks_protocol_conflict_visible', $match instanceof NodeInterface);
    }
  }

  return $form['actions'];
}

/**
 * Returns TRUE when the current request is a remarks add-more trigger.
 */
function incoming_tweaks_is_remarks_add_more(FormStateInterface $form_state): bool {
  $trigger = $form_state->getTriggeringElement();
  $trigger_name = $trigger['#name'] ?? '';
  if ($trigger_name === 'field_remarks_remark_add_more') {
    return TRUE;
  }

  $request = \Drupal::request();
  $request_trigger = (string) $request->request->get('_triggering_element_name', '');
  if ($request_trigger === 'field_remarks_remark_add_more') {
    return TRUE;
  }

  return FALSE;
}


/**
 * Implements hook_entity_presave().
 */
function incoming_tweaks_entity_presave(EntityInterface $entity): void {
  if (!$entity instanceof NodeInterface || $entity->bundle() !== 'incoming') {
    return;
  }

  $is_new = $entity->isNew();

  incoming_tweaks_ensure_title($entity);
  $baseline = incoming_tweaks_ensure_entry_date($entity);
  incoming_tweaks_set_initial_legal_deadline($entity, $baseline);
  incoming_tweaks_recalculate_deadline_on_state_transition($entity);
  incoming_tweaks_recalculate_deadline_on_type_change($entity);
  incoming_tweaks_set_completion_date_on_publish($entity);
  incoming_tweaks_set_transition_revision_log($entity);

  incoming_tweaks_remove_primary_from_newly_related($entity);
  incoming_tweaks_restore_primary_for_removed_related($entity);
  incoming_tweaks_sync_related_legal_entities($entity);

  if ($is_new) {
    if (incoming_tweaks_populate_field_ref_id($entity)) {
      $reference = (string) $entity->get('field_ref_id')->value;
      if ($reference !== '') {
        $entity->setTitle($reference);
      }
    }
    incoming_tweaks_set_primary_flag($entity);
    incoming_tweaks_add_self_related_incoming($entity);
  }
  else {
    incoming_tweaks_populate_field_ref_id($entity);
  }
}

/**
 * Ensures field_entry_date is set and returns the normalized baseline date.
 */
function incoming_tweaks_ensure_entry_date(NodeInterface $node): DrupalDateTime {
  $baseline = NULL;
  $is_entry_datetime = incoming_tweaks_entry_date_is_datetime();
  $entry_storage_format = $is_entry_datetime
    ? DateTimeItemInterface::DATETIME_STORAGE_FORMAT
    : DateTimeItemInterface::DATE_STORAGE_FORMAT;

  if ($node->get('field_entry_date')->isEmpty()) {
    $entry_date = new DrupalDateTime('now');
    if (!$is_entry_datetime) {
      $entry_date->setTime(0, 0, 0);
    }
    $node->set('field_entry_date', [
      'value' => $entry_date->format($entry_storage_format),
    ]);
    $baseline = clone $entry_date;
  }
  else {
    $entry_item = $node->get('field_entry_date')->first();
    if ($entry_item) {
      $value = $entry_item->getValue()['value'] ?? NULL;
      if ($value) {
        try {
          $baseline = DrupalDateTime::createFromFormat($entry_storage_format, $value, new \DateTimeZone(DateTimeItemInterface::STORAGE_TIMEZONE));
        }
        catch (\Exception $exception) {
          // Backward compatibility with previous date-only storage.
          try {
            $baseline = DrupalDateTime::createFromFormat(DateTimeItemInterface::DATE_STORAGE_FORMAT, $value, new \DateTimeZone(DateTimeItemInterface::STORAGE_TIMEZONE));
          }
          catch (\Exception $exception) {
            // Fall through to the default baseline when parsing fails.
          }
        }
      }
    }
  }

  $baseline = $baseline ?: new DrupalDateTime('now');
  $baseline->setTime(0, 0, 0);

  return $baseline;
}

/**
 * Checks whether field_entry_date stores a full datetime value.
 */
function incoming_tweaks_entry_date_is_datetime(): bool {
  $definitions = \Drupal::service('entity_field.manager')->getFieldDefinitions('node', 'incoming');
  if (empty($definitions['field_entry_date'])) {
    return FALSE;
  }
  $storage_definition = $definitions['field_entry_date']->getFieldStorageDefinition();
  return (string) ($storage_definition->getSetting('datetime_type') ?? 'date') === 'datetime';
}

/**
 * Calculates field_legal_deadline when a new incoming is initiated.
 */
function incoming_tweaks_set_initial_legal_deadline(NodeInterface $node, DrupalDateTime $baseline): void {
  if ($node->get('field_legal_deadline')->isEmpty()) {
    $baseline_formatted = $baseline->format(DateTimeItemInterface::DATE_STORAGE_FORMAT);
    $node->set('field_fullness_check_date', ['value' => $baseline_formatted]);

    $deadline_days = function_exists('kemke_reports_get_deadline_days_default_for_incoming')
      ? kemke_reports_get_deadline_days_default_for_incoming($node)
      : 20;
    $deadline = greek_holidays_calculate_date_after($baseline, $deadline_days);
    $deadline_formatted = $deadline->format(DateTimeItemInterface::DATE_STORAGE_FORMAT);
    $node->set('field_legal_deadline', ['value' => $deadline_formatted]);
    $node->set('field_legal_deadline_original', ['value' => $deadline_formatted]);
  }
}

/**
 * Recalculates field_fullness_check_date when moving from pending_issues to fullness_check.
 */
function incoming_tweaks_recalculate_deadline_on_state_transition(NodeInterface $node): void {
  if (
    $node->isNew() ||
    !$node->hasField('moderation_state') ||
    !$node->original instanceof EntityInterface ||
    $node->get('moderation_state')->isEmpty()
  ) {
    return;
  }

  $previous_state = $node->original->get('moderation_state')->isEmpty() ? NULL : $node->original->get('moderation_state')->value;
  $current_state = $node->get('moderation_state')->value;

  if ($previous_state === 'pending_issues' && $current_state === 'fullness_check') {
    $today = new DrupalDateTime('now');
    $today->setTime(0, 0, 0);
    $today_formatted = $today->format(DateTimeItemInterface::DATE_STORAGE_FORMAT);
    $deadline_days = function_exists('kemke_reports_get_deadline_days_default_for_incoming')
      ? kemke_reports_get_deadline_days_default_for_incoming($node)
      : 20;
    $deadline = greek_holidays_calculate_date_after($today, $deadline_days);
    $deadline_formatted = $deadline->format(DateTimeItemInterface::DATE_STORAGE_FORMAT);

    $node->set('field_fullness_check_date', ['value' => $today_formatted]);
    $node->set('field_legal_deadline', ['value' => $deadline_formatted]);
    $node->set('field_legal_deadline_ext', ['value' => $deadline_formatted]);
  }
}

/**
 * Recalculates deadlines when incoming type/subtype changes on existing nodes.
 */
function incoming_tweaks_recalculate_deadline_on_type_change(NodeInterface $node): void {
  if (
    $node->isNew() ||
    !$node->original instanceof EntityInterface ||
    !$node->hasField('field_incoming_type') ||
    !$node->hasField('field_incoming_subtype')
  ) {
    return;
  }

  $old_type = (int) ($node->original->get('field_incoming_type')->target_id ?? 0);
  $new_type = (int) ($node->get('field_incoming_type')->target_id ?? 0);
  $old_subtype = (int) ($node->original->get('field_incoming_subtype')->target_id ?? 0);
  $new_subtype = (int) ($node->get('field_incoming_subtype')->target_id ?? 0);

  if ($old_type === $new_type && $old_subtype === $new_subtype) {
    return;
  }

  $start = NULL;
  if ($node->hasField('field_fullness_check_date') && !$node->get('field_fullness_check_date')->isEmpty()) {
    $value = $node->get('field_fullness_check_date')->first()->getValue()['value'] ?? NULL;
    if ($value) {
      try {
        $start = DrupalDateTime::createFromFormat(DateTimeItemInterface::DATE_STORAGE_FORMAT, $value, new \DateTimeZone(DateTimeItemInterface::STORAGE_TIMEZONE));
      }
      catch (\Exception $exception) {
        $start = NULL;
      }
    }
  }
  if (!$start) {
    $start = new DrupalDateTime('now');
    $start->setTime(0, 0, 0);
  }

  $deadline_days = function_exists('kemke_reports_get_deadline_days_default_for_incoming')
    ? kemke_reports_get_deadline_days_default_for_incoming($node)
    : 20;
  $deadline = greek_holidays_calculate_date_after($start, $deadline_days)
    ->format(DateTimeItemInterface::DATE_STORAGE_FORMAT);

  $node->set('field_legal_deadline', ['value' => $deadline]);
  $node->set('field_legal_deadline_ext', ['value' => $deadline]);
}

/**
 * Sets field_completion_date when the moderation state moves to published.
 */
function incoming_tweaks_set_completion_date_on_publish(NodeInterface $node): void {
  if (
    !$node->hasField('moderation_state') ||
    $node->get('moderation_state')->isEmpty() ||
    !$node->hasField('field_completion_date') ||
    !$node->get('field_completion_date')->isEmpty()
  ) {
    return;
  }

  $current_state = $node->get('moderation_state')->value;
  if ($current_state !== 'published') {
    return;
  }

  $previous_state = NULL;
  if (!$node->isNew() && $node->original instanceof EntityInterface && !$node->original->get('moderation_state')->isEmpty()) {
    $previous_state = $node->original->get('moderation_state')->value;
  }

  // Only set completion date when entering the published state.
  if ($previous_state !== 'published') {
    $completion_date = new DrupalDateTime('now');
    $completion_date->setTime(0, 0, 0);
    $node->set('field_completion_date', [
      'value' => $completion_date->format(DateTimeItemInterface::DATE_STORAGE_FORMAT),
    ]);
  }
}

/**
 * Sets the revision log message to the transition label when state changes.
 */
function incoming_tweaks_set_transition_revision_log(NodeInterface $node): void {
  if (
    $node->isNew() ||
    !$node->hasField('moderation_state') ||
    !$node->original instanceof EntityInterface ||
    $node->get('moderation_state')->isEmpty()
  ) {
    return;
  }

  $previous_state = $node->original->get('moderation_state')->isEmpty() ? NULL : $node->original->get('moderation_state')->value;
  $current_state = $node->get('moderation_state')->value;
  if (!$previous_state || $previous_state === $current_state) {
    return;
  }

  $existing_log = trim((string) $node->getRevisionLogMessage());
  if ($existing_log !== '') {
    return;
  }

  $config = \Drupal::config('workflows.workflow.incoming_processing');
  $transitions = $config->get('type_settings.transitions') ?? [];
  $label = NULL;
  foreach ($transitions as $transition) {
    $from = $transition['from'] ?? [];
    $to = $transition['to'] ?? NULL;
    if (in_array($previous_state, $from, TRUE) && $to === $current_state) {
      $label = $transition['label'] ?? NULL;
      break;
    }
  }

  if ($label) {
    $node->setRevisionLogMessage(t('Μετάβαση: @label', ['@label' => $label]));
  }
}

/**
 * Ensures field_primary is set to on for new incoming nodes.
 */
function incoming_tweaks_set_primary_flag(NodeInterface $node): void {
  if ($node->hasField('field_primary')) {
    $node->set('field_primary', 1);
  }
}

/**
 * Ensures the node title is set to a non-empty value.
 */
function incoming_tweaks_ensure_title(NodeInterface $node): void {
  $title = trim((string) $node->label());
  if ($title === '') {
    $node->setTitle(t('Untitled incoming'));
  }
}

/**
 * Adds custom classes to inline entity form tables.
 */
function incoming_tweaks_preprocess_inline_entity_form_entity_table(array &$variables): void {
  if (\Drupal::currentUser()->hasRole('administrator')) {
    return;
  }

  // Keep IEF operations available on user add/edit forms.
  $route_name = \Drupal::routeMatch()->getRouteName();
  $is_user_form_route = in_array($route_name, [
    'entity.user.edit_form',
    'user.register',
    'user.admin_create',
  ], TRUE);
  if ($is_user_form_route) {
    return;
  }

  if (!isset($variables['table']['#attributes']['class'])) {
    $variables['table']['#attributes']['class'] = [];
  }

  $variables['table']['#attributes']['class'] = array_values(array_unique(array_merge(
    $variables['table']['#attributes']['class'],
    [
      'govgr-table-simple',
    ]
  )));

  // Outside user add/edit forms, hide IEF row edit/remove operations.
  foreach ($variables['table'] as &$row) {
    if (!is_array($row) || !isset($row['actions']) || !is_array($row['actions'])) {
      continue;
    }
    foreach (array_keys($row['actions']) as $key) {
      if (strpos($key, 'ief_entity_edit') === 0 || strpos($key, 'ief_entity_remove') === 0) {
        unset($row['actions'][$key]);
      }
    }
  }
  unset($row);
}

/**
 * Marks newly attached related incoming rows in the IEF widget.
 */
function incoming_tweaks_mark_new_related_rows_after_build(array $element, FormStateInterface $form_state): array {
  if (\Drupal::currentUser()->hasRole('administrator')) {
    return $element;
  }

  if (empty($element['entities']) || !is_array($element['entities'])) {
    return $element;
  }

  $entity = $form_state->getFormObject()->getEntity();
  $original_ids = [];
  if ($entity instanceof NodeInterface && !$entity->isNew()) {
    $original = $entity->original instanceof NodeInterface ? $entity->original : $entity;
    if ($original->hasField('field_related_incoming')) {
      foreach ($original->get('field_related_incoming') as $item) {
        if (!empty($item->target_id)) {
          $original_ids[] = (int) $item->target_id;
        }
      }
    }
  }

  foreach (Element::children($element['entities']) as $delta) {
    if (empty($element['entities'][$delta]['#entity']) || !$element['entities'][$delta]['#entity'] instanceof NodeInterface) {
      continue;
    }
    $row_entity = $element['entities'][$delta]['#entity'];
    $row_id = $row_entity->id();
    if ($row_entity->isNew() || ($row_id && !in_array((int) $row_id, $original_ids, TRUE))) {
      $element['entities'][$delta]['#incoming_related_is_new'] = TRUE;
    }
  }

  return $element;
}

/**
 * Marks newly-related incoming nodes as non-primary.
 */
function incoming_tweaks_remove_primary_from_newly_related(NodeInterface $node): void {
  if (!$node->hasField('field_related_incoming') || !$node->original instanceof NodeInterface) {
    return;
  }

  $current_ids = incoming_tweaks_collect_related_incoming_ids($node);
  $original_ids = incoming_tweaks_collect_related_incoming_ids($node->original);

  $new_ids = array_diff($current_ids, $original_ids);
  if (!$new_ids) {
    return;
  }

  /** @var \Drupal\node\NodeStorageInterface $storage */
  $storage = \Drupal::entityTypeManager()->getStorage('node');
  $related_nodes = $storage->loadMultiple($new_ids);

  foreach ($related_nodes as $related) {
    if (!$related instanceof NodeInterface || !$related->hasField('field_primary')) {
      continue;
    }

    $related->set('field_primary', 0);
    $related->setNewRevision(FALSE);
    $related->save();
  }
}

/**
 * Restores primary status for nodes removed from field_related_incoming.
 */
function incoming_tweaks_restore_primary_for_removed_related(NodeInterface $node): void {
  if (!$node->hasField('field_related_incoming') || !$node->original instanceof NodeInterface) {
    return;
  }

  $current_ids = incoming_tweaks_collect_related_incoming_ids($node);
  $original_ids = incoming_tweaks_collect_related_incoming_ids($node->original);
  $removed_ids = array_diff($original_ids, $current_ids);
  if (!$removed_ids) {
    return;
  }

  /** @var \Drupal\node\NodeStorageInterface $storage */
  $storage = \Drupal::entityTypeManager()->getStorage('node');
  $removed_nodes = $storage->loadMultiple($removed_ids);
  foreach ($removed_nodes as $removed) {
    if (!$removed instanceof NodeInterface || !$removed->hasField('field_primary')) {
      continue;
    }

    $removed->set('field_primary', 1);
    $removed->setNewRevision(FALSE);
    $removed->save();
  }
}

/**
 * Syncs related incoming legal entities with the current incoming.
 */
function incoming_tweaks_sync_related_legal_entities(NodeInterface $node): void {
  static $in_progress = FALSE;
  if ($in_progress) {
    return;
  }

  if (
    !$node->hasField('field_related_incoming') ||
    !$node->hasField('field_legal_entity') ||
    $node->get('field_legal_entity')->isEmpty()
  ) {
    return;
  }

  $related_ids = incoming_tweaks_collect_related_incoming_ids($node);
  if (!$related_ids) {
    return;
  }

  $legal_values = $node->get('field_legal_entity')->getValue();
  if (!$legal_values) {
    return;
  }

  /** @var \Drupal\node\NodeStorageInterface $storage */
  $storage = \Drupal::entityTypeManager()->getStorage('node');
  $related_nodes = $storage->loadMultiple($related_ids);
  $self_id = $node->id();

  $in_progress = TRUE;
  foreach ($related_nodes as $related) {
    if (
      !$related instanceof NodeInterface ||
      (int) $related->id() === (int) $self_id ||
      !$related->hasField('field_legal_entity')
    ) {
      continue;
    }

    if ($related->get('field_legal_entity')->getValue() == $legal_values) {
      continue;
    }

    $related->set('field_legal_entity', $legal_values);
    $related->setNewRevision(FALSE);
    $related->save();
  }
  $in_progress = FALSE;
}

/**
 * Collects related incoming IDs from field_related_incoming.
 *
 * @return int[]
 *   The list of related incoming node IDs.
 */
function incoming_tweaks_collect_related_incoming_ids(NodeInterface $node): array {
  if (!$node->hasField('field_related_incoming')) {
    return [];
  }

  $ids = [];
  foreach ($node->get('field_related_incoming') as $item) {
    if (!empty($item->target_id)) {
      $ids[] = (int) $item->target_id;
    }
  }

  return $ids;
}

/**
 * Adds a self-reference to field_related_incoming when available.
 */
function incoming_tweaks_add_self_related_incoming(NodeInterface $node): void {
  if (!$node->hasField('field_related_incoming')) {
    return;
  }

  $target_id = $node->id();
  if (!$target_id) {
    // No ID yet (e.g., first presave on new entity), nothing to link.
    return;
  }

  $related_field = $node->get('field_related_incoming');
  foreach ($related_field as $item) {
    if ((int) $item->target_id === (int) $target_id) {
      return;
    }
  }

  $related_field->appendItem(['target_id' => $target_id]);
}

/**
 * Implements hook_ENTITY_TYPE_insert() for nodes.
 */
function incoming_tweaks_node_insert(NodeInterface $node): void {
  if ($node->bundle() !== 'incoming') {
    return;
  }

  incoming_tweaks_add_self_related_incoming($node);
  incoming_tweaks_assign_reference_id($node);
}

/**
 * Implements hook_ENTITY_TYPE_update() for nodes.
 *
 * When an incoming moves from under_processing to for_signature, push it to
 * Docutracks via side_api and store the response on the node.
 */
function incoming_tweaks_node_update(NodeInterface $node): void {
  static $reverting = [];
  static $processing = [];
  static $processing_signed = [];

  if (incoming_tweaks_skip_docutracks_file_hooks()) {
    return;
  }

  incoming_tweaks_send_plan($node, $reverting, $processing);
  incoming_tweaks_get_plan_signed($node, $processing_signed);
}

/**
 * Returns TRUE when Docutracks file send/receive hooks should be skipped.
 */
function incoming_tweaks_skip_docutracks_file_hooks(): bool {
  return (bool) \Drupal::request()->attributes->get('incoming_change_state_skip_file_hooks', FALSE);
}

/**
 * Sends a plan to Docutracks when moving to for_signature state.
 */
function incoming_tweaks_send_plan(NodeInterface $node, array &$reverting, array &$processing): void {
  if (
    $node->bundle() !== 'incoming' ||
    !$node->hasField('moderation_state') ||
    $node->get('moderation_state')->isEmpty() ||
    !$node->original instanceof EntityInterface ||
    $node->original->getEntityTypeId() !== 'node'
  ) {
    return;
  }

  $previous_state = $node->original->get('moderation_state')->isEmpty() ? NULL : $node->original->get('moderation_state')->value;
  $current_state = $node->get('moderation_state')->value;

  if ($previous_state !== 'under_processing' || $current_state !== 'for_signature') {
    return;
  }

  $nid = $node->id();

  // Avoid re-entrancy when we revert the node within this hook.
  if (!empty($reverting[$nid])) {
    return;
  }

  // Avoid multiple sends within the same request for the same node.
  if (!empty($processing[$nid])) {
    return;
  }
  $processing[$nid] = TRUE;

  $current_tries = incoming_tweaks_get_plan_dt_tries($node);
  $attempt_number = $current_tries + 1;

  $main_file_path = incoming_tweaks_resolve_single_file_path($node, 'field_plan');
  if ($main_file_path === NULL) {
    incoming_tweaks_revert_to_under_processing($node, $reverting, 'Missing plan file.', NULL, $attempt_number);
    \Drupal::logger('incoming_tweaks')->error('Unable to send incoming @nid to Docutracks: missing plan file (attempt @attempt).', [
      '@nid' => $nid,
      '@attempt' => $attempt_number,
    ]);
    \Drupal::messenger()->deleteByType(MessengerInterface::TYPE_STATUS);
    unset($processing[$nid]);
    return;
  }

  $attachment_paths = incoming_tweaks_resolve_file_paths($node, 'field_attachments');
  $subject = '';
  if ($node->hasField('field_subject') && !$node->get('field_subject')->isEmpty()) {
    $subject = strip_tags((string) $node->get('field_subject')->value);
    $subject = trim($subject);
  }
  if (mb_strlen($subject) > 100) {
    $subject = Unicode::substr($subject, 0, 100) . '...';
  }

  $node_title = (string) $node->label();
  $title = $subject !== '' ? sprintf('%s - %s', $node_title, $subject) : $node_title;

  $doc_payload = ['Document' => ['Title' => $title]];

  // The first request after a long idle period can be slow; give login more time.
  $timeout = 60.0;

  try {
    /** @var \Drupal\side_api\DocutracksClient $client */
    $client = \Drupal::service('side_api.docutracks_client');
    $payload = $client->prepareRegisterPayload($doc_payload, $main_file_path, $attachment_paths, 'plan');
    $resolved_type = $client->extractValueByPath($payload, 'Document.Type.Id');
    $resolved_kind = $client->extractValueByPath($payload, 'Document.Kind.Id');
    $resolved_created_for = $client->extractValueByPath($payload, 'Document.CreatedForGroup.Id');
    \Drupal::logger('incoming_tweaks')->info('Docutracks plan payload resolved ids: @details', [
      '@details' => Json::encode([
        'nid' => $node->id(),
        'type_id' => $resolved_type,
        'kind_id' => $resolved_kind,
        'created_for_group' => $resolved_created_for,
      ], JSON_UNESCAPED_UNICODE | JSON_PRETTY_PRINT),
    ]);
    $sanitized_payload = incoming_tweaks_sanitize_docutracks_payload($payload);

    $log_details = [
      'nid' => $node->id(),
      'attempt' => $attempt_number,
      'base_url' => $client->resolveBaseUrl(),
      'timeout' => $timeout,
      'main_file' => $main_file_path,
      'attachments' => $attachment_paths,
      'title' => $title,
      'moderation_state' => $current_state,
      'payload' => $sanitized_payload,
    ];

    \Drupal::logger('incoming_tweaks')->info('Sending incoming to Docutracks: @details', [
      '@details' => Json::encode($log_details, JSON_UNESCAPED_UNICODE | JSON_PRETTY_PRINT),
    ]);

    $jar = $client->loginToDocutracks(baseUrl: NULL, adminUser: NULL, adminPass: NULL, appUser: NULL, appPass: NULL, timeout: $timeout);
    $response = $client->registerDocument($payload, $jar, NULL, $timeout);

    $is_success = is_array($response) && !empty($response['Success']);

    // Persist the API response on the node without creating an extra revision.
    if ($node->hasField('field_plan_dt_api_response')) {
      $encoded = Json::encode($response, JSON_UNESCAPED_UNICODE | JSON_PRETTY_PRINT);
      $document_id = $response['DocumentReference'] ?? NULL;
      $document_log = NULL;
      if ($document_id !== NULL) {
        if ($node->hasField('field_dt_docid')) {
          $node->set('field_dt_docid', $document_id);
        }
        $document_log = [
          'type' => 'plan',
          'Send' => [
            'purpose' => 'initial',
            'id' => 1,
            'dt_doc_id' => (int) $document_id,
            'tries' => $attempt_number,
          ],
          'Receive' => [
            'success' => FALSE,
            'error' => '',
            'tries' => 0,
          ],
        ];
      }
      incoming_tweaks_append_dt_response($node, $encoded, $document_log);
    }

    if ($is_success) {
      $node->setNewRevision(TRUE);
      $node->save();
      $document_id = $response['DocumentReference'] ?? NULL;
      if ($document_id) {
        /** @var \Drupal\side_polling\SidePollingManager $polling */
        $polling = \Drupal::service('side_polling.manager');
        $caller_info = $document_log ? \Drupal\side_api\DocutracksClient::formatDocumentLogLine($document_log) : '';
        $payload = $polling->buildJobPayload($node, (int) $document_id, $caller_info);
        $polling->registerJob('plan_initial', $payload);
      }

      \Drupal::logger('incoming_tweaks')->info('Docutracks push succeeded', [
        'nid' => $nid,
        'attempt' => $attempt_number,
        'main_file' => $main_file_path,
        'attachments' => $attachment_paths,
        'response' => $response,
      ]);

      // Add a success message to inform the editor.
      \Drupal::messenger()->addStatus(t('Plan was transfered to SIDE'));
    }
    else {
      incoming_tweaks_revert_to_under_processing($node, $reverting, 'Docutracks returned non-success response.', Json::encode($response, JSON_UNESCAPED_UNICODE), $attempt_number);
      \Drupal::logger('incoming_tweaks')->warning('Docutracks push returned non-success', [
        'nid' => $nid,
        'attempt' => $attempt_number,
        'main_file' => $main_file_path,
        'attachments' => $attachment_paths,
        'response' => $response,
      ]);
    }
  }
  catch (\Throwable $throwable) {
    incoming_tweaks_revert_to_under_processing($node, $reverting, $throwable->getMessage(), NULL, $attempt_number);
    \Drupal::logger('incoming_tweaks')->error('Docutracks push failed for incoming @nid (attempt @attempt): @message', [
      '@nid' => $nid,
      '@attempt' => $attempt_number,
      '@message' => $throwable->getMessage(),
    ]);
  }
  finally {
    unset($processing[$nid]);
  }
}

/**
 * Downloads the signed plan from Docutracks when the node is published.
 */
function incoming_tweaks_get_plan_signed(NodeInterface $node, array &$processing_signed): void {
  // The signed download (and publish transition) is owned by PlanInitialManager.
  $polling_job = incoming_tweaks_polling_job_exists($node);
  if (
    $node->bundle() !== 'incoming' ||
    !$node->hasField('moderation_state') ||
    $node->get('moderation_state')->isEmpty() ||
    !$node->original instanceof EntityInterface ||
    $node->original->getEntityTypeId() !== 'node'
  ) {
    return;
  }

  $previous_state = $node->original->get('moderation_state')->isEmpty() ? NULL : $node->original->get('moderation_state')->value;
  $current_state = $node->get('moderation_state')->value;

  if ($previous_state !== 'for_signature' || $current_state !== 'published') {
    return;
  }

  $nid = $node->id();

  if (!empty($processing_signed[$nid])) {
    return;
  }
  $processing_signed[$nid] = TRUE;

  $doc_id = NULL;
  $match = [];
  $manual = [
    'job_exists' => FALSE,
    'should_resume' => FALSE,
  ];

  try {
    $doc_id = incoming_tweaks_get_plan_doc_id_from_log($node);
    if (!$doc_id && incoming_tweaks_simulation_fetch_success()) {
      $doc_id = 1;
    }
    if ($polling_job && $doc_id) {
      /** @var \Drupal\side_polling\SidePollingManager $polling */
      $polling = \Drupal::service('side_polling.manager');
      $match = $polling->buildJobMatch($node, (int) $doc_id);
      $manual = $polling->pauseForManual('plan_initial', $match);
    }
    if (!$doc_id) {
      incoming_tweaks_log_signed_fetch_issue($nid, 'Missing Docutracks document id.');
      incoming_tweaks_revert_to_for_signature($node, t('Missing Docutracks document id.'));
      incoming_tweaks_append_plan_receive_log($node, FALSE, 'Missing Docutracks document id.');
      return;
    }

    /** @var \Drupal\incoming_tweaks\Service\PlanInitialManager $manager */
    $manager = \Drupal::service('incoming_tweaks.plan_initial_manager');
    $result = $manager->receiveSignedPlan($node, (int) $doc_id, TRUE);
    if (!empty($result['success']) && !empty($result['file'])) {
      \Drupal::logger('incoming_tweaks')->info('Downloaded signed plan for incoming @nid and attached file @fid.', [
        '@nid' => $nid,
        '@fid' => $result['file']->id(),
      ]);
      if ($polling_job && $doc_id) {
        $polling->finishManual('plan_initial', $match, TRUE, $manual['job_exists'], $manual['should_resume']);
      }
    }
    elseif (!empty($result['error'])) {
      incoming_tweaks_revert_to_for_signature($node, $result['error']);
      if ($polling_job && $doc_id) {
        $polling->finishManual('plan_initial', $match, FALSE, $manual['job_exists'], $manual['should_resume']);
      }
    }
  }
  catch (\Throwable $throwable) {
    \Drupal::logger('incoming_tweaks')->error('Failed to download signed plan for incoming @nid: @message', [
      '@nid' => $nid,
      '@message' => $throwable->getMessage(),
    ]);
    incoming_tweaks_revert_to_for_signature($node, $throwable->getMessage());
    incoming_tweaks_append_plan_receive_log($node, FALSE, $throwable->getMessage());
  }
  finally {
    if ($polling_job && $doc_id && !empty($manual['job_exists']) && !empty($manual['should_resume'])) {
      $polling->resumeJobs('plan_initial', $match, TRUE);
    }
    unset($processing_signed[$nid]);
  }
}

/**
 * Determines whether the signature status shows completion.
 */
function incoming_tweaks_is_signatures_status_complete(?string $status): bool {
  return \Drupal\side_api\DocutracksClient::isSignaturesStatusComplete($status);
}

/**
 * Ensures an auto-generated reference ID exists for the incoming node.
 */
function incoming_tweaks_assign_reference_id(NodeInterface $node): void {
  $updated = incoming_tweaks_populate_field_ref_id($node);

  if ($updated) {
    $reference = (string) $node->get('field_ref_id')->value;
    if ($reference !== '' && $node->label() !== $reference) {
      $node->setTitle($reference);
    }
  }

  // Avoid creating a revision just for the auto-generated values.
  $node->setNewRevision(FALSE);
  $node->save();
}

/**
 * Populates the reference ID field on existing nodes when empty.
 */
function incoming_tweaks_populate_field_ref_id(NodeInterface $node): bool {
  if (!$node->hasField('field_ref_id') || !$node->get('field_ref_id')->isEmpty()) {
    return FALSE;
  }

  $node->set('field_ref_id', incoming_tweaks_generate_reference_id($node));
 return TRUE;
}

/**
 * Generates the INC-#### identifier.
 */
function incoming_tweaks_generate_reference_id(NodeInterface $node): string {
  // Avoid incrementing the counter multiple times for the same node in a
  // single request (e.g., if generation is triggered twice during save).
  static $generated = [];
  $uuid = $node->uuid();
  if (isset($generated[$uuid])) {
    return $generated[$uuid];
  }

  $now = new DrupalDateTime('now');
  $year = (int) $now->format('Y');
  $sequence = incoming_tweaks_next_reference_sequence($year);

  return $generated[$uuid] = sprintf('INC-%d-%d', $year, $sequence);
}

/**
 * Retrieves and increments the per-year reference ID counter.
 */
function incoming_tweaks_next_reference_sequence(int $year): int {
  $state = \Drupal::state();
  $lock = \Drupal::lock();
  $lock_name = "incoming_tweaks.ref_counter.$year";
  $counter_key = "incoming_tweaks.ref_counter.$year";

  // Guard against concurrent increments to keep the counter consistent.
  $acquired = $lock->acquire($lock_name, 5.0);
  if (!$acquired) {
    \Drupal::logger('incoming_tweaks')->warning('Unable to acquire reference counter lock for @year, falling back to non-locked increment.', ['@year' => $year]);
  }

  $current = (int) $state->get($counter_key, 0);
  $next = max(1, $current + 1);
  $state->set($counter_key, $next);

  if ($acquired) {
    $lock->release($lock_name);
  }

  return $next;
}

/**
 * Returns the first readable file path for a file field.
 */
function incoming_tweaks_resolve_single_file_path(NodeInterface $node, string $field_name): ?string {
  $paths = incoming_tweaks_resolve_file_paths($node, $field_name);
  return $paths[0] ?? NULL;
}

/**
 * Returns all readable file paths for a file field.
 */
function incoming_tweaks_resolve_file_paths(NodeInterface $node, string $field_name): array {
  if (!$node->hasField($field_name)) {
    return [];
  }

  $paths = [];
  $file_system = \Drupal::service('file_system');

  foreach ($node->get($field_name) as $item) {
    $target_id = $item->target_id ?? NULL;
    if (!$target_id) {
      continue;
    }

    $file = File::load($target_id);
    if (!$file) {
      continue;
    }

    $uri = $file->getFileUri();
    $real_path = $file_system->realpath($uri);
    if ($real_path && is_readable($real_path)) {
      $paths[] = $real_path;
    }
  }

  return $paths;
}

/**
 * Remove Base64 contents before logging payloads.
 */
function incoming_tweaks_sanitize_docutracks_payload(array $payload): array {
  if (!isset($payload['Document']) || !is_array($payload['Document'])) {
    return $payload;
  }

  $document = $payload['Document'];

  if (isset($document['MainFile']) && is_array($document['MainFile'])) {
    unset($document['MainFile']['Base64File']);
  }

  if (isset($document['Attachments']) && is_array($document['Attachments'])) {
    foreach ($document['Attachments'] as &$attachment) {
      if (is_array($attachment)) {
        unset($attachment['Base64File']);
      }
    }
    unset($attachment);
  }

  $payload['Document'] = $document;
  return $payload;
}

/**
 * Get the persisted Docutracks attempt count for the node.
 */
function incoming_tweaks_get_plan_dt_tries(NodeInterface $node): int {
  $entry = incoming_tweaks_get_latest_plan_log_entry($node);
  if (!$entry) {
    return 0;
  }
  return (int) ($entry['Send']['tries'] ?? 0);
}

/**
 * Set node back to under_processing, flag failure, save, and show warning.
 */
function incoming_tweaks_revert_to_under_processing(NodeInterface $node, array &$reverting, string $reason, ?string $response = NULL, ?int $attempt_number = NULL): void {
  $nid = $node->id();
  $reverting[$nid] = TRUE;

  if ($node->hasField('moderation_state')) {
    $node->set('moderation_state', 'under_processing');
  }
  if ($node->hasField('field_plan_dt_api_response') && $response !== NULL) {
    incoming_tweaks_append_dt_response($node, $response);
  }

  // Clear any pending status messages before saving the reverted node.
  \Drupal::messenger()->deleteByType(MessengerInterface::TYPE_STATUS);

  $node->setNewRevision(FALSE);
  $node->save();

  // Remove any pre-existing status messages to avoid mixed success/failure.
  \Drupal::messenger()->deleteByType(MessengerInterface::TYPE_STATUS);

  \Drupal::messenger()->addError([
    '#type' => 'inline_template',
    '#template' => '{{ reason }}<br>{{ line2 }}',
    '#context' => [
      'reason' => t('@reason', ['@reason' => $reason]),
      'line2' => t('Document was returned to Under processing.'),
    ],
  ]);

  // Flag this request so form submit cleanup can remove any core success message.
  \Drupal::request()->attributes->set('incoming_tweaks_dt_failed', TRUE);

  unset($reverting[$nid]);
}

/**
 * Revert a published node back to for_signature when signed plan retrieval fails.
 */
function incoming_tweaks_revert_to_for_signature(NodeInterface $node, string $reason): void {
  $nid = $node->id();

  if ($node->hasField('moderation_state')) {
    $node->set('moderation_state', 'for_signature');
  }

  \Drupal::messenger()->deleteByType(MessengerInterface::TYPE_STATUS);

  // Save as a fresh default revision to avoid ER revisions conflicts.
  $node->setNewRevision(TRUE);
  $node->isDefaultRevision(TRUE);
  if ($node->hasField('revision_default')) {
    $node->set('revision_default', 1);
  }
  if ($node->hasField('revision_published')) {
    $node->set('revision_published', 0);
  }
  if (method_exists($node, 'setPublished')) {
    $node->setPublished(FALSE);
  }
  if (method_exists($node, 'setRevisionTranslationAffected')) {
    $node->setRevisionTranslationAffected(FALSE);
  }
  $node->save();

  // Remove any pre-existing status messages to avoid mixed success/failure.
  \Drupal::messenger()->deleteByType(MessengerInterface::TYPE_STATUS);

  \Drupal::messenger()->addError([
    '#type' => 'inline_template',
    '#template' => '{{ reason }}<br>{{ line2 }}',
    '#context' => [
      'reason' => t('@reason', ['@reason' => $reason]),
      'line2' => t('Document was returned to For signature.'),
    ],
  ]);

  // Flag this request so form submit cleanup can remove any core success message.
  \Drupal::request()->attributes->set('incoming_tweaks_dt_failed', TRUE);
}

/**
 * Read the side_api simulation settings array.
 *
 * @return array<string, mixed>
 */
function incoming_tweaks_simulation_settings(): array {
  $settings = \Drupal\Core\Site\Settings::get('side_api', []);
  return is_array($settings) ? $settings : [];
}

/**
 * Return TRUE when signed plan download should ignore signature status.
 */
function incoming_tweaks_get_plan_unsigned_enabled(): bool {
  return \Drupal\side_api\DocutracksClient::allowUnsignedPlanDownload();
}

/**
 * Return TRUE when simulation is enabled and fetchDocument is set to success.
 */
function incoming_tweaks_simulation_fetch_success(): bool {
  $settings = incoming_tweaks_simulation_settings();
  if (empty($settings['simulation'])) {
    return FALSE;
  }
  $return = $settings['fetchDocument']['return'] ?? '';
  return is_string($return) && strtolower($return) === 'success';
}

/**
 * Return TRUE when simulation allows missing GeneratedFile.Id.
 */
function incoming_tweaks_simulation_allow_missing_generated_file(): bool {
  $settings = incoming_tweaks_simulation_settings();
  if (empty($settings['simulation'])) {
    return FALSE;
  }
  if (!incoming_tweaks_simulation_fetch_success()) {
    return FALSE;
  }
  return !empty($settings['fetchDocument']['allow_missing_generated_file_id']);
}

/**
 * Log a signed-plan fetch issue with consistent formatting.
 *
 * @param array<string, mixed> $context
 */
function incoming_tweaks_log_signed_fetch_issue(int $nid, string $message, array $context = []): void {
  $context['@nid'] = $nid;
  $log_message = 'Unable to fetch signed plan for incoming @nid: @message';
  if (!empty($context['@doc'])) {
    $log_message .= ' (doc @doc)';
  }
  \Drupal::logger('incoming_tweaks')->warning($log_message, [
    '@nid' => $context['@nid'],
    '@message' => $message,
  ] + $context);
}

/**
 * Append a response string to the API response field, preserving history.
 */
function incoming_tweaks_append_dt_response(NodeInterface $node, string $response, ?array $document_log = NULL): void {
  if (!$node->hasField('field_plan_dt_api_response')) {
    return;
  }

  $existing = '';
  if (!$node->get('field_plan_dt_api_response')->isEmpty()) {
    $existing = (string) $node->get('field_plan_dt_api_response')->value;
  }

  $timestamp = date('Y-m-d H:i:s');
  $entry = sprintf("[%s]\n%s", $timestamp, $response);
  if ($document_log !== NULL) {
    $entry .= "\n" . \Drupal\side_api\DocutracksClient::formatDocumentLogLine($document_log);
  }

  $combined = $existing !== '' ? $existing . "\n\n" . $entry : $entry;
  $node->set('field_plan_dt_api_response', $combined);
}

/**
 * Extract the latest plan Document log entry.
 */
function incoming_tweaks_get_latest_plan_log_entry(NodeInterface $node): ?array {
  /** @var \Drupal\incoming_tweaks\Service\PlanInitialManager $manager */
  $manager = \Drupal::service('incoming_tweaks.plan_initial_manager');
  return $manager->getLatestPlanLog($node);
}

/**
 * Return the Docutracks document id for the latest plan log entry.
 */
function incoming_tweaks_get_plan_doc_id_from_log(NodeInterface $node): ?int {
  /** @var \Drupal\incoming_tweaks\Service\PlanInitialManager $manager */
  $manager = \Drupal::service('incoming_tweaks.plan_initial_manager');
  return $manager->getDocIdFromLog($node);
}

/**
 * Append a plan Receive log entry with updated tries.
 */
function incoming_tweaks_append_plan_receive_log(NodeInterface $node, bool $success, string $error): void {
  /** @var \Drupal\incoming_tweaks\Service\PlanInitialManager $manager */
  $manager = \Drupal::service('incoming_tweaks.plan_initial_manager');
  $entry = $manager->getLatestPlanLog($node);
  if (!$entry) {
    return;
  }

  $receive_tries = (int) ($entry['Receive']['tries'] ?? 0) + 1;
  $document_log = [
    'type' => 'plan',
    'Send' => [
      'purpose' => 'initial',
      'id' => 1,
      'dt_doc_id' => (int) ($entry['Send']['dt_doc_id'] ?? 0),
      'tries' => (int) ($entry['Send']['tries'] ?? 0),
    ],
    'Receive' => [
      'success' => $success,
      'error' => $error,
      'tries' => $receive_tries,
    ],
  ];

  $manager->appendDocumentLog($node, $document_log);
}

/**
 * Return TRUE when polling should handle signed plan receipt.
 */
function incoming_tweaks_is_polling_enabled(): bool {
  $settings = \Drupal\Core\Site\Settings::get('side_polling', []);
  if (!is_array($settings)) {
    return TRUE;
  }

  return array_key_exists('enabled', $settings) ? !empty($settings['enabled']) : TRUE;
}

/**
 * Return TRUE when a polling job exists for the node plan receive.
 */
function incoming_tweaks_polling_job_exists(NodeInterface $node): bool {
  $doc_id = incoming_tweaks_get_plan_doc_id_from_log($node);
  /** @var \Drupal\side_polling\SidePollingManager $polling */
  $polling = \Drupal::service('side_polling.manager');
  $match = [
    'node_id' => $node->id(),
  ];
  if ($doc_id) {
    $match['document_id'] = (int) $doc_id;
  }
  return $polling->hasJob('plan_initial', $match);
}

/**
 * Submit handler to clear status messages when Docutracks failed.
 */
function incoming_tweaks_clear_status_on_docutracks_failure(array &$form, FormStateInterface $form_state): void {
  if (\Drupal::request()->attributes->get('incoming_tweaks_dt_failed')) {
    \Drupal::messenger()->deleteByType(MessengerInterface::TYPE_STATUS);
  }
}

/**
 * Remove success messages on page build when Docutracks failed.
 */
function incoming_tweaks_page_alter(array &$page): void {
  if (\Drupal::request()->attributes->get('incoming_tweaks_dt_failed')) {
    \Drupal::messenger()->deleteByType(MessengerInterface::TYPE_STATUS);
  }
}

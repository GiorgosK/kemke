<?php

use Drupal\Core\Datetime\DrupalDateTime;
use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Form\FormStateInterface;
use Drupal\Component\Serialization\Json;
use Drupal\Core\Messenger\MessengerInterface;
use Drupal\Component\Utility\Unicode;
use Drupal\datetime\Plugin\Field\FieldType\DateTimeItemInterface;
use Drupal\file\Entity\File;
use Drupal\node\NodeInterface;

/**
 * Implements hook_form_BASE_FORM_ID_alter() for node forms.
 */
function incoming_tweaks_form_node_form_alter(array &$form, FormStateInterface $form_state, $form_id): void {
  $current_user = \Drupal::currentUser();

  if (!$current_user->hasPermission('administer nodes') && isset($form['revision_information'])) {
    // Remove revision tab entirely for non-admin users.
    $form['revision_information']['#access'] = FALSE;
  }

  // Post-submit cleanup: if Docutracks failed, remove core status messages.
  if (isset($form['actions']['submit']['#submit']) && is_array($form['actions']['submit']['#submit'])) {
    $form['actions']['submit']['#submit'][] = 'incoming_tweaks_clear_status_on_docutracks_failure';
  }
  else {
    $form['#submit'][] = 'incoming_tweaks_clear_status_on_docutracks_failure';
  }
}

/**
 * Implements hook_entity_presave().
 */
function incoming_tweaks_entity_presave(EntityInterface $entity): void {
  if (!$entity instanceof NodeInterface || $entity->bundle() !== 'incoming') {
    return;
  }

  $is_new = $entity->isNew();

  incoming_tweaks_ensure_title($entity);
  $baseline = incoming_tweaks_ensure_entry_date($entity);
  incoming_tweaks_set_initial_legal_deadline($entity, $baseline);
  incoming_tweaks_recalculate_deadline_on_state_transition($entity);
  incoming_tweaks_set_completion_date_on_publish($entity);

  incoming_tweaks_remove_primary_from_newly_related($entity);
  incoming_tweaks_restore_primary_for_removed_related($entity);

  if ($is_new) {
    incoming_tweaks_set_primary_flag($entity);
    incoming_tweaks_add_self_related_incoming($entity);
  }
  else {
    incoming_tweaks_populate_field_ref_id($entity);
  }
}

/**
 * Ensures field_entry_date is set and returns the normalized baseline date.
 */
function incoming_tweaks_ensure_entry_date(NodeInterface $node): DrupalDateTime {
  $baseline = NULL;

  if ($node->get('field_entry_date')->isEmpty()) {
    $entry_date = new DrupalDateTime('now');
    $entry_date->setTime(0, 0, 0);
    $node->set('field_entry_date', [
      'value' => $entry_date->format(DateTimeItemInterface::DATE_STORAGE_FORMAT),
    ]);
    $baseline = clone $entry_date;
  }
  else {
    $entry_item = $node->get('field_entry_date')->first();
    if ($entry_item) {
      $value = $entry_item->getValue()['value'] ?? NULL;
      if ($value) {
        try {
          $baseline = DrupalDateTime::createFromFormat(DateTimeItemInterface::DATE_STORAGE_FORMAT, $value, new \DateTimeZone(DateTimeItemInterface::STORAGE_TIMEZONE));
        }
        catch (\Exception $exception) {
          // Fall through to the default baseline when parsing fails.
        }
      }
    }
  }

  $baseline = $baseline ?: new DrupalDateTime('now');
  $baseline->setTime(0, 0, 0);

  return $baseline;
}

/**
 * Calculates field_legal_deadline when a new incoming is initiated.
 */
function incoming_tweaks_set_initial_legal_deadline(NodeInterface $node, DrupalDateTime $baseline): void {
  if ($node->get('field_legal_deadline')->isEmpty()) {
    $baseline_formatted = $baseline->format(DateTimeItemInterface::DATE_STORAGE_FORMAT);
    $node->set('field_fullness_check_date', ['value' => $baseline_formatted]);

    $deadline = greek_holidays_calculate_date_after($baseline, 20);
    $deadline_formatted = $deadline->format(DateTimeItemInterface::DATE_STORAGE_FORMAT);
    $node->set('field_legal_deadline', ['value' => $deadline_formatted]);
    $node->set('field_legal_deadline_original', ['value' => $deadline_formatted]);
  }
}

/**
 * Recalculates field_fullness_check_date when moving from pending_issues to fullness_check.
 */
function incoming_tweaks_recalculate_deadline_on_state_transition(NodeInterface $node): void {
  if (
    $node->isNew() ||
    !$node->hasField('moderation_state') ||
    !$node->original instanceof EntityInterface ||
    $node->get('moderation_state')->isEmpty()
  ) {
    return;
  }

  $previous_state = $node->original->get('moderation_state')->isEmpty() ? NULL : $node->original->get('moderation_state')->value;
  $current_state = $node->get('moderation_state')->value;

  if ($previous_state === 'pending_issues' && $current_state === 'fullness_check') {
    $today = new DrupalDateTime('now');
    $today->setTime(0, 0, 0);
    $today_formatted = $today->format(DateTimeItemInterface::DATE_STORAGE_FORMAT);
    $deadline = greek_holidays_calculate_date_after($today, 20);
    $deadline_formatted = $deadline->format(DateTimeItemInterface::DATE_STORAGE_FORMAT);

    $node->set('field_fullness_check_date', ['value' => $today_formatted]);
    $node->set('field_legal_deadline', ['value' => $deadline_formatted]);
    $node->set('field_legal_deadline_ext', ['value' => $deadline_formatted]);
  }
}

/**
 * Sets field_completion_date when the moderation state moves to published.
 */
function incoming_tweaks_set_completion_date_on_publish(NodeInterface $node): void {
  if (
    !$node->hasField('moderation_state') ||
    $node->get('moderation_state')->isEmpty() ||
    !$node->hasField('field_completion_date') ||
    !$node->get('field_completion_date')->isEmpty()
  ) {
    return;
  }

  $current_state = $node->get('moderation_state')->value;
  if ($current_state !== 'published') {
    return;
  }

  $previous_state = NULL;
  if (!$node->isNew() && $node->original instanceof EntityInterface && !$node->original->get('moderation_state')->isEmpty()) {
    $previous_state = $node->original->get('moderation_state')->value;
  }

  // Only set completion date when entering the published state.
  if ($previous_state !== 'published') {
    $completion_date = new DrupalDateTime('now');
    $completion_date->setTime(0, 0, 0);
    $node->set('field_completion_date', [
      'value' => $completion_date->format(DateTimeItemInterface::DATE_STORAGE_FORMAT),
    ]);
  }
}

/**
 * Ensures field_primary is set to on for new incoming nodes.
 */
function incoming_tweaks_set_primary_flag(NodeInterface $node): void {
  if ($node->hasField('field_primary')) {
    $node->set('field_primary', 1);
  }
}

/**
 * Ensures the node title is set to a non-empty value.
 */
function incoming_tweaks_ensure_title(NodeInterface $node): void {
  $title = trim((string) $node->label());
  if ($title === '') {
    $node->setTitle(t('Untitled incoming'));
  }
}

/**
 * Adds custom classes to inline entity form tables.
 */
function incoming_tweaks_preprocess_inline_entity_form_entity_table(array &$variables): void {
  if (!isset($variables['table']['#attributes']['class'])) {
    $variables['table']['#attributes']['class'] = [];
  }

  $variables['table']['#attributes']['class'] = array_values(array_unique(array_merge(
    $variables['table']['#attributes']['class'],
    [
      'govgr-table-simple',
    ]
  )));

  // Strip the inline edit button from the operations column and the first
  // "Remove" button from the first data row.
  $removed_first_remove = FALSE;
  foreach ($variables['table'] as &$row) {
    if (!is_array($row) || !isset($row['actions']) || !is_array($row['actions'])) {
      continue;
    }
    foreach (array_keys($row['actions']) as $key) {
      if (strpos($key, 'ief_entity_edit') === 0) {
        unset($row['actions'][$key]);
      }
    }
    if (!$removed_first_remove) {
      foreach (array_keys($row['actions']) as $key) {
        if (strpos($key, 'ief_entity_remove') === 0) {
          unset($row['actions'][$key]);
          $removed_first_remove = TRUE;
          break;
        }
      }
    }
  }
  unset($row);
}

/**
 * Marks newly-related incoming nodes as non-primary.
 */
function incoming_tweaks_remove_primary_from_newly_related(NodeInterface $node): void {
  if (!$node->hasField('field_related_incoming') || !$node->original instanceof NodeInterface) {
    return;
  }

  $current_ids = incoming_tweaks_collect_related_incoming_ids($node);
  $original_ids = incoming_tweaks_collect_related_incoming_ids($node->original);

  $new_ids = array_diff($current_ids, $original_ids);
  if (!$new_ids) {
    return;
  }

  /** @var \Drupal\node\NodeStorageInterface $storage */
  $storage = \Drupal::entityTypeManager()->getStorage('node');
  $related_nodes = $storage->loadMultiple($new_ids);

  foreach ($related_nodes as $related) {
    if (!$related instanceof NodeInterface || !$related->hasField('field_primary')) {
      continue;
    }

    $related->set('field_primary', 0);
    $related->setNewRevision(FALSE);
    $related->save();
  }
}

/**
 * Restores primary status for nodes removed from field_related_incoming.
 */
function incoming_tweaks_restore_primary_for_removed_related(NodeInterface $node): void {
  if (!$node->hasField('field_related_incoming') || !$node->original instanceof NodeInterface) {
    return;
  }

  $current_ids = incoming_tweaks_collect_related_incoming_ids($node);
  $original_ids = incoming_tweaks_collect_related_incoming_ids($node->original);
  $removed_ids = array_diff($original_ids, $current_ids);
  if (!$removed_ids) {
    return;
  }

  /** @var \Drupal\node\NodeStorageInterface $storage */
  $storage = \Drupal::entityTypeManager()->getStorage('node');
  $removed_nodes = $storage->loadMultiple($removed_ids);
  foreach ($removed_nodes as $removed) {
    if (!$removed instanceof NodeInterface || !$removed->hasField('field_primary')) {
      continue;
    }

    $removed->set('field_primary', 1);
    $removed->setNewRevision(FALSE);
    $removed->save();
  }
}

/**
 * Collects related incoming IDs from field_related_incoming.
 *
 * @return int[]
 *   The list of related incoming node IDs.
 */
function incoming_tweaks_collect_related_incoming_ids(NodeInterface $node): array {
  if (!$node->hasField('field_related_incoming')) {
    return [];
  }

  $ids = [];
  foreach ($node->get('field_related_incoming') as $item) {
    if (!empty($item->target_id)) {
      $ids[] = (int) $item->target_id;
    }
  }

  return $ids;
}

/**
 * Adds a self-reference to field_related_incoming when available.
 */
function incoming_tweaks_add_self_related_incoming(NodeInterface $node): void {
  if (!$node->hasField('field_related_incoming')) {
    return;
  }

  $target_id = $node->id();
  if (!$target_id) {
    // No ID yet (e.g., first presave on new entity), nothing to link.
    return;
  }

  $related_field = $node->get('field_related_incoming');
  foreach ($related_field as $item) {
    if ((int) $item->target_id === (int) $target_id) {
      return;
    }
  }

  $related_field->appendItem(['target_id' => $target_id]);
}

/**
 * Implements hook_ENTITY_TYPE_insert() for nodes.
 */
function incoming_tweaks_node_insert(NodeInterface $node): void {
  if ($node->bundle() !== 'incoming') {
    return;
  }

  incoming_tweaks_add_self_related_incoming($node);
  incoming_tweaks_assign_reference_id($node);
}

/**
 * Implements hook_ENTITY_TYPE_update() for nodes.
 *
 * When an incoming moves from under_processing to for_signature, push it to
 * Docutracks via side_api and store the response on the node.
 */
function incoming_tweaks_node_update(NodeInterface $node): void {
  static $reverting = [];
  static $processing = [];
  static $processing_signed = [];

  incoming_tweaks_send_plan($node, $reverting, $processing);
  incoming_tweaks_get_plan_signed($node, $processing_signed);
}

/**
 * Sends a plan to Docutracks when moving to for_signature state.
 */
function incoming_tweaks_send_plan(NodeInterface $node, array &$reverting, array &$processing): void {
  if (
    $node->bundle() !== 'incoming' ||
    !$node->hasField('moderation_state') ||
    $node->get('moderation_state')->isEmpty() ||
    !$node->original instanceof EntityInterface ||
    $node->original->getEntityTypeId() !== 'node'
  ) {
    return;
  }

  $previous_state = $node->original->get('moderation_state')->isEmpty() ? NULL : $node->original->get('moderation_state')->value;
  $current_state = $node->get('moderation_state')->value;

  if ($previous_state !== 'under_processing' || $current_state !== 'for_signature') {
    return;
  }

  $nid = $node->id();

  // Avoid re-entrancy when we revert the node within this hook.
  if (!empty($reverting[$nid])) {
    return;
  }

  // Avoid multiple sends within the same request for the same node.
  if (!empty($processing[$nid])) {
    return;
  }
  $processing[$nid] = TRUE;

  $current_tries = incoming_tweaks_get_plan_dt_tries($node);
  $attempt_number = $current_tries + 1;

  $main_file_path = incoming_tweaks_resolve_single_file_path($node, 'field_plan');
  if ($main_file_path === NULL) {
    incoming_tweaks_revert_to_under_processing($node, $reverting, 'Missing plan file.', NULL, $attempt_number);
    \Drupal::logger('incoming_tweaks')->error('Unable to send incoming @nid to Docutracks: missing plan file (attempt @attempt).', [
      '@nid' => $nid,
      '@attempt' => $attempt_number,
    ]);
    \Drupal::messenger()->deleteByType(MessengerInterface::TYPE_STATUS);
    unset($processing[$nid]);
    return;
  }

  $attachment_paths = incoming_tweaks_resolve_file_paths($node, 'field_attachments');
  $subject = '';
  if ($node->hasField('field_subject') && !$node->get('field_subject')->isEmpty()) {
    $subject = strip_tags((string) $node->get('field_subject')->value);
    $subject = trim($subject);
  }
  if (mb_strlen($subject) > 100) {
    $subject = Unicode::substr($subject, 0, 100) . '...';
  }

  $node_title = (string) $node->label();
  $title = $subject !== '' ? sprintf('%s - %s', $node_title, $subject) : $node_title;

  $doc_payload = ['Document' => ['Title' => $title]];

  // The first request after a long idle period can be slow; give login more time.
  $timeout = 60.0;

  try {
    /** @var \Drupal\side_api\DocutracksClient $client */
    $client = \Drupal::service('side_api.docutracks_client');
    $payload = $client->prepareRegisterPayload($doc_payload, $main_file_path, $attachment_paths);
    $sanitized_payload = incoming_tweaks_sanitize_docutracks_payload($payload);

    $log_details = [
      'nid' => $node->id(),
      'attempt' => $attempt_number,
      'base_url' => $client->resolveBaseUrl(),
      'timeout' => $timeout,
      'main_file' => $main_file_path,
      'attachments' => $attachment_paths,
      'title' => $title,
      'moderation_state' => $current_state,
      'payload' => $sanitized_payload,
    ];

    \Drupal::logger('incoming_tweaks')->info('Sending incoming to Docutracks: @details', [
      '@details' => Json::encode($log_details, JSON_UNESCAPED_UNICODE | JSON_PRETTY_PRINT),
    ]);

    $jar = $client->loginToDocutracks(baseUrl: NULL, adminUser: NULL, adminPass: NULL, appUser: NULL, appPass: NULL, timeout: $timeout);
    $response = $client->registerDocument($payload, $jar, NULL, $timeout);

    $is_success = is_array($response) && !empty($response['Success']);

    // Persist the API response on the node without creating an extra revision.
    if ($node->hasField('field_plan_dt_api_response')) {
      $encoded = Json::encode($response, JSON_UNESCAPED_UNICODE | JSON_PRETTY_PRINT);
      incoming_tweaks_append_dt_response($node, $encoded);
    }
    if ($node->hasField('field_plan_dt_success')) {
      $node->set('field_plan_dt_success', $is_success ? 1 : 0);
    }
    if ($node->hasField('field_plan_dt_tries')) {
      $node->set('field_plan_dt_tries', $attempt_number);
    }
    if ($node->hasField('field_plan_dt_docid')) {
      $document_id = $response['DocumentReference'] ?? NULL;
      if ($document_id !== NULL) {
        $node->set('field_plan_dt_docid', $document_id);
      }
    }

    if ($is_success) {
      $node->setNewRevision(FALSE);
      $node->save();

      \Drupal::logger('incoming_tweaks')->info('Docutracks push succeeded', [
        'nid' => $nid,
        'attempt' => $attempt_number,
        'main_file' => $main_file_path,
        'attachments' => $attachment_paths,
        'response' => $response,
      ]);

      // Add a success message to inform the editor.
      \Drupal::messenger()->addStatus(t('Plan was transfered to SIDE'));
    }
    else {
      incoming_tweaks_revert_to_under_processing($node, $reverting, 'Docutracks returned non-success response.', Json::encode($response, JSON_UNESCAPED_UNICODE), $attempt_number);
      \Drupal::logger('incoming_tweaks')->warning('Docutracks push returned non-success', [
        'nid' => $nid,
        'attempt' => $attempt_number,
        'main_file' => $main_file_path,
        'attachments' => $attachment_paths,
        'response' => $response,
      ]);
    }
  }
  catch (\Throwable $throwable) {
    incoming_tweaks_revert_to_under_processing($node, $reverting, $throwable->getMessage(), NULL, $attempt_number);
    \Drupal::logger('incoming_tweaks')->error('Docutracks push failed for incoming @nid (attempt @attempt): @message', [
      '@nid' => $nid,
      '@attempt' => $attempt_number,
      '@message' => $throwable->getMessage(),
    ]);
  }
  finally {
    unset($processing[$nid]);
  }
}

/**
 * Downloads the signed plan from Docutracks when the node is published.
 */
function incoming_tweaks_get_plan_signed(NodeInterface $node, array &$processing_signed): void {
  if (
    $node->bundle() !== 'incoming' ||
    !$node->hasField('moderation_state') ||
    $node->get('moderation_state')->isEmpty() ||
    !$node->original instanceof EntityInterface ||
    $node->original->getEntityTypeId() !== 'node'
  ) {
    return;
  }

  $previous_state = $node->original->get('moderation_state')->isEmpty() ? NULL : $node->original->get('moderation_state')->value;
  $current_state = $node->get('moderation_state')->value;

  if ($previous_state !== 'for_signature' || $current_state !== 'published') {
    return;
  }

  $nid = $node->id();

  if (!empty($processing_signed[$nid])) {
    return;
  }
  $processing_signed[$nid] = TRUE;

  try {
    $doc_id = $node->get('field_plan_dt_docid')->value ?? NULL;
    if (!$doc_id) {
      \Drupal::logger('incoming_tweaks')->warning('Unable to fetch signed plan for incoming @nid: missing Docutracks document id.', ['@nid' => $nid]);
      incoming_tweaks_revert_to_for_signature($node, 'Missing Docutracks document id.');
      return;
    }

    /** @var \Drupal\side_api\DocutracksClient $client */
    $client = \Drupal::service('side_api.docutracks_client');
    $jar = $client->loginToDocutracks(timeout: 60.0);
    $doc = $client->fetchDocument((string) $doc_id, $jar);
    $file_id = $client->extractValueByPath($doc, 'Document.GeneratedFile.Id');

    if (!$file_id) {
      \Drupal::logger('incoming_tweaks')->warning('Unable to fetch signed plan for incoming @nid: GeneratedFile.Id not found for doc @doc.', [
        '@nid' => $nid,
        '@doc' => $doc_id,
      ]);
      incoming_tweaks_revert_to_for_signature($node, 'Signed file not available yet.');
      return;
    }

    $file = $client->downloadAndAttachFile((int) $file_id, (int) $doc_id, $node, 'field_plan_signed', $jar, NULL, TRUE);
    $node->setNewRevision(FALSE);
    $node->save();

    \Drupal::logger('incoming_tweaks')->info('Downloaded signed plan for incoming @nid and attached file @fid.', [
      '@nid' => $nid,
      '@fid' => $file->id(),
    ]);
  }
  catch (\Throwable $throwable) {
    \Drupal::logger('incoming_tweaks')->error('Failed to download signed plan for incoming @nid: @message', [
      '@nid' => $nid,
      '@message' => $throwable->getMessage(),
    ]);
    incoming_tweaks_revert_to_for_signature($node, $throwable->getMessage());
  }
  finally {
    unset($processing_signed[$nid]);
  }
}

/**
 * Ensures an auto-generated reference ID exists for the incoming node.
 */
function incoming_tweaks_assign_reference_id(NodeInterface $node): void {
  $updated = incoming_tweaks_populate_field_ref_id($node);

  if ($updated) {
    $reference = (string) $node->get('field_ref_id')->value;
    if ($reference !== '' && $node->label() !== $reference) {
      $node->setTitle($reference);
    }
  }

  // Avoid creating a revision just for the auto-generated values.
  $node->setNewRevision(FALSE);
  $node->save();
}

/**
 * Populates the reference ID field on existing nodes when empty.
 */
function incoming_tweaks_populate_field_ref_id(NodeInterface $node): bool {
  if (!$node->hasField('field_ref_id') || !$node->get('field_ref_id')->isEmpty()) {
    return FALSE;
  }

  $node->set('field_ref_id', incoming_tweaks_generate_reference_id($node));
 return TRUE;
}

/**
 * Generates the INC-#### identifier.
 */
function incoming_tweaks_generate_reference_id(NodeInterface $node): string {
  // Avoid incrementing the counter multiple times for the same node in a
  // single request (e.g., if generation is triggered twice during save).
  static $generated = [];
  $uuid = $node->uuid();
  if (isset($generated[$uuid])) {
    return $generated[$uuid];
  }

  $now = new DrupalDateTime('now');
  $year = (int) $now->format('Y');
  $sequence = incoming_tweaks_next_reference_sequence($year);

  return $generated[$uuid] = sprintf('INC-%d-%d', $year, $sequence);
}

/**
 * Retrieves and increments the per-year reference ID counter.
 */
function incoming_tweaks_next_reference_sequence(int $year): int {
  $state = \Drupal::state();
  $lock = \Drupal::lock();
  $lock_name = "incoming_tweaks.ref_counter.$year";
  $counter_key = "incoming_tweaks.ref_counter.$year";

  // Guard against concurrent increments to keep the counter consistent.
  $acquired = $lock->acquire($lock_name, 5.0);
  if (!$acquired) {
    \Drupal::logger('incoming_tweaks')->warning('Unable to acquire reference counter lock for @year, falling back to non-locked increment.', ['@year' => $year]);
  }

  $current = (int) $state->get($counter_key, 0);
  $next = max(1, $current + 1);
  $state->set($counter_key, $next);

  if ($acquired) {
    $lock->release($lock_name);
  }

  return $next;
}

/**
 * Returns the first readable file path for a file field.
 */
function incoming_tweaks_resolve_single_file_path(NodeInterface $node, string $field_name): ?string {
  $paths = incoming_tweaks_resolve_file_paths($node, $field_name);
  return $paths[0] ?? NULL;
}

/**
 * Returns all readable file paths for a file field.
 */
function incoming_tweaks_resolve_file_paths(NodeInterface $node, string $field_name): array {
  if (!$node->hasField($field_name)) {
    return [];
  }

  $paths = [];
  $file_system = \Drupal::service('file_system');

  foreach ($node->get($field_name) as $item) {
    $target_id = $item->target_id ?? NULL;
    if (!$target_id) {
      continue;
    }

    $file = File::load($target_id);
    if (!$file) {
      continue;
    }

    $uri = $file->getFileUri();
    $real_path = $file_system->realpath($uri);
    if ($real_path && is_readable($real_path)) {
      $paths[] = $real_path;
    }
  }

  return $paths;
}

/**
 * Remove Base64 contents before logging payloads.
 */
function incoming_tweaks_sanitize_docutracks_payload(array $payload): array {
  if (!isset($payload['Document']) || !is_array($payload['Document'])) {
    return $payload;
  }

  $document = $payload['Document'];

  if (isset($document['MainFile']) && is_array($document['MainFile'])) {
    unset($document['MainFile']['Base64File']);
  }

  if (isset($document['Attachments']) && is_array($document['Attachments'])) {
    foreach ($document['Attachments'] as &$attachment) {
      if (is_array($attachment)) {
        unset($attachment['Base64File']);
      }
    }
    unset($attachment);
  }

  $payload['Document'] = $document;
  return $payload;
}

/**
 * Get the persisted Docutracks attempt count for the node.
 */
function incoming_tweaks_get_plan_dt_tries(NodeInterface $node): int {
  if (!$node->hasField('field_plan_dt_tries')) {
    return 0;
  }

  // Prefer the stored value to avoid counting based on mutated in-memory state.
  if (!$node->isNew() && $node->id()) {
    $storage = \Drupal::entityTypeManager()->getStorage('node');
    /** @var \Drupal\node\NodeInterface|null $unchanged */
    $unchanged = $storage->loadUnchanged($node->id());
    if ($unchanged instanceof NodeInterface && !$unchanged->get('field_plan_dt_tries')->isEmpty()) {
      return (int) $unchanged->get('field_plan_dt_tries')->value;
    }
  }

  if (!$node->get('field_plan_dt_tries')->isEmpty()) {
    return (int) $node->get('field_plan_dt_tries')->value;
  }

  return 0;
}

/**
 * Set node back to under_processing, flag failure, save, and show warning.
 */
function incoming_tweaks_revert_to_under_processing(NodeInterface $node, array &$reverting, string $reason, ?string $response = NULL, ?int $attempt_number = NULL): void {
  $nid = $node->id();
  $reverting[$nid] = TRUE;

  if ($node->hasField('moderation_state')) {
    $node->set('moderation_state', 'under_processing');
  }
  if ($node->hasField('field_plan_dt_success')) {
    $node->set('field_plan_dt_success', 0);
  }
  if ($node->hasField('field_plan_dt_tries') && $attempt_number !== NULL) {
    $node->set('field_plan_dt_tries', $attempt_number);
  }
  if ($node->hasField('field_plan_dt_api_response') && $response !== NULL) {
    incoming_tweaks_append_dt_response($node, $response);
  }

  // Clear any pending status messages before saving the reverted node.
  \Drupal::messenger()->deleteByType(MessengerInterface::TYPE_STATUS);

  $node->setNewRevision(FALSE);
  $node->save();

  // Remove any pre-existing status messages to avoid mixed success/failure.
  \Drupal::messenger()->deleteByType(MessengerInterface::TYPE_STATUS);

  \Drupal::messenger()->addError(t('Docutracks transmission failed and the item was returned to Under processing. Reason: @reason', [
    '@reason' => $reason,
  ]));

  // Flag this request so form submit cleanup can remove any core success message.
  \Drupal::request()->attributes->set('incoming_tweaks_dt_failed', TRUE);

  unset($reverting[$nid]);
}

/**
 * Revert a published node back to for_signature when signed plan retrieval fails.
 */
function incoming_tweaks_revert_to_for_signature(NodeInterface $node, string $reason): void {
  $nid = $node->id();

  if ($node->hasField('moderation_state')) {
    $node->set('moderation_state', 'for_signature');
  }

  \Drupal::messenger()->deleteByType(MessengerInterface::TYPE_STATUS);

  $node->setNewRevision(FALSE);
  $node->save();

  \Drupal::messenger()->addError(t('Signed plan could not be fetched. Item returned to For signature. Reason: @reason', [
    '@reason' => $reason,
  ]));
}

/**
 * Append a response string to the API response field, preserving history.
 */
function incoming_tweaks_append_dt_response(NodeInterface $node, string $response): void {
  if (!$node->hasField('field_plan_dt_api_response')) {
    return;
  }

  $existing = '';
  if (!$node->get('field_plan_dt_api_response')->isEmpty()) {
    $existing = (string) $node->get('field_plan_dt_api_response')->value;
  }

  $timestamp = date('Y-m-d H:i:s');
  $entry = sprintf("[%s]\n%s", $timestamp, $response);

  $combined = $existing !== '' ? $existing . "\n\n" . $entry : $entry;
  $node->set('field_plan_dt_api_response', $combined);
}

/**
 * Submit handler to clear status messages when Docutracks failed.
 */
function incoming_tweaks_clear_status_on_docutracks_failure(array &$form, FormStateInterface $form_state): void {
  if (\Drupal::request()->attributes->get('incoming_tweaks_dt_failed')) {
    \Drupal::messenger()->deleteByType(MessengerInterface::TYPE_STATUS);
  }
}

/**
 * Remove success messages on page build when Docutracks failed.
 */
function incoming_tweaks_page_alter(array &$page): void {
  if (\Drupal::request()->attributes->get('incoming_tweaks_dt_failed')) {
    \Drupal::messenger()->deleteByType(MessengerInterface::TYPE_STATUS);
  }
}

/**
 * Keep AMKE add tab off the generic add form.
 */
function incoming_tweaks_menu_local_tasks_alter(array &$data, string $route_name): void {
  if ($route_name !== 'node.add') {
    return;
  }

  $route_params = \Drupal::routeMatch()->getParameters();
  if ($route_params->get('node_type') !== 'incoming') {
    return;
  }

  foreach ($data['tabs'] as $group_key => $tab_group) {
    unset($data['tabs'][$group_key]['incoming_tweaks.incoming_amke_add']);
  }
}

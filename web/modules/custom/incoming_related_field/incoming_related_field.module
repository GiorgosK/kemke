<?php

use Drupal\Core\Field\FieldDefinitionInterface;
use Drupal\Core\File\FileSystemInterface;
use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Render\Element;
use Drupal\Core\Site\Settings;
use Drupal\file\FileInterface;
use Drupal\node\NodeInterface;
use Drupal\paragraphs\ParagraphInterface;

/**
 * Limits inline forms for related incoming nodes.
 */
function incoming_related_field_inline_entity_form_entity_form_alter(array &$entity_form, FormStateInterface $form_state): void {
  if (($entity_form['#entity_type'] ?? '') !== 'node' || ($entity_form['#bundle'] ?? '') !== 'incoming') {
    return;
  }

  $op = $entity_form['#op'] ?? '';
  if (!in_array($op, ['add', 'duplicate'], TRUE)) {
    return;
  }

  $ief_id = $entity_form['#ief_id'] ?? NULL;
  if (!$ief_id) {
    return;
  }

  $field_definition = $form_state->get(['inline_entity_form', $ief_id, 'instance']);
  if (!$field_definition instanceof FieldDefinitionInterface || $field_definition->getName() !== 'field_related_incoming') {
    return;
  }

  $keep_fields = [
    'field_documents',
    'field_protocol_number_sender',
  ];
  $keep_always = ['actions'];

  foreach ($entity_form as $key => $element) {
    if (!is_array($element) || strpos((string) $key, '#') === 0) {
      continue;
    }
    if (in_array($key, $keep_always, TRUE)) {
      continue;
    }
    if (strpos((string) $key, 'field_') === 0 && in_array($key, $keep_fields, TRUE)) {
      continue;
    }
    unset($entity_form[$key]);
  }

  if (isset($entity_form['field_documents']['widget']) && is_array($entity_form['field_documents']['widget'])) {
    if (isset($entity_form['field_documents']['widget']['#header'])) {
      $entity_form['field_documents']['widget']['#header'] = [];
    }
    if (isset($entity_form['field_documents']['widget']['add_more'])) {
      $entity_form['field_documents']['widget']['add_more']['#access'] = FALSE;
    }
    foreach ($entity_form['field_documents']['widget'] as $delta => $item) {
      if (is_array($item) && isset($entity_form['field_documents']['widget'][$delta]['top'])) {
        unset($entity_form['field_documents']['widget'][$delta]['top']);
      }
    }
  }

  incoming_related_field_add_send_to_side_buttons($entity_form);
}

/**
 * Updates the add button label for related incoming items.
 */
function incoming_related_field_form_alter(array &$form, FormStateInterface $form_state, string $form_id): void {
  if (!in_array($form_id, ['node_incoming_form', 'node_incoming_edit_form'], TRUE)) {
    return;
  }

//  $form['#attached']['library'][] = 'incoming_related_field/ief_hide_actions';

  if (\Drupal::currentUser()->hasRole('amke_user')) {
    $selector = 'edit-field-related-incoming-actions-ief-add-existing';
    $name = 'ief-field_related_incoming-form-add-existing';
    incoming_related_field_update_button_access($form, $selector, $name, FALSE);
  }

  $label = 'Προσθήκη αρχείου';
  $selector = 'edit-field-related-incoming-actions-ief-add';
  $name = 'ief-field_related_incoming-form-add';

  // Try the common IEF actions structure first.
  if (isset($form['field_related_incoming']['widget']['actions']) && is_array($form['field_related_incoming']['widget']['actions'])) {
    foreach ($form['field_related_incoming']['widget']['actions'] as &$action) {
      if (is_array($action) && ($action['#type'] ?? '') === 'submit' && (($action['#name'] ?? '') === $name)) {
        $action['#value'] = $label;
      }
    }
    unset($action);
  }

  incoming_related_field_update_button_label($form, $selector, $name, $label);

  incoming_related_field_add_send_to_side_actions($form);

  if (isset($form['field_related_incoming']['incoming_related_field_messages'])) {
    unset($form['field_related_incoming']['incoming_related_field_messages']);
  }
}

/**
 * Recursively updates a button label by selector, name, or id.
 */
function incoming_related_field_update_button_label(array &$element, string $selector, string $name, string $label): void {
  $matches_selector = isset($element['#attributes']['data-drupal-selector']) && $element['#attributes']['data-drupal-selector'] === $selector;
  $matches_id = isset($element['#attributes']['id']) && $element['#attributes']['id'] === $selector;
  $matches_name = isset($element['#name']) && $element['#name'] === $name;

  if ($matches_selector || $matches_id || $matches_name) {
    if (isset($element['#value'])) {
      $element['#value'] = $label;
    }
    if (isset($element['#title'])) {
      $element['#title'] = $label;
    }
  }

  foreach ($element as &$child) {
    if (is_array($child)) {
      incoming_related_field_update_button_label($child, $selector, $name, $label);
    }
  }
  unset($child);
}

/**
 * Recursively updates a button access by selector, name, or id.
 */
function incoming_related_field_update_button_access(array &$element, string $selector, string $name, bool $access): void {
  $matches_selector = isset($element['#attributes']['data-drupal-selector']) && $element['#attributes']['data-drupal-selector'] === $selector;
  $matches_id = isset($element['#attributes']['id']) && $element['#attributes']['id'] === $selector;
  $matches_name = isset($element['#name']) && $element['#name'] === $name;

  if ($matches_selector || $matches_id || $matches_name) {
    $element['#access'] = $access;
  }

  foreach ($element as &$child) {
    if (is_array($child)) {
      incoming_related_field_update_button_access($child, $selector, $name, $access);
    }
  }
  unset($child);
}

/**
 * Adds "Send to SIDE" buttons to each related incoming row with a file.
 */
function incoming_related_field_add_send_to_side_actions(array &$form): void {
  if (\Drupal::currentUser()->hasRole('amke_user')) {
    return;
  }

  if (
    empty($form['field_related_incoming']['widget']['entities'])
    || !is_array($form['field_related_incoming']['widget']['entities'])
  ) {
    return;
  }

  foreach ($form['field_related_incoming']['widget']['entities'] as $delta => &$row) {
    if (!is_array($row)) {
      continue;
    }

    $node = incoming_related_field_extract_row_node($row);
    if (!$node instanceof NodeInterface) {
      continue;
    }
    if ($node->isNew() || !$node->id()) {
      continue;
    }

    $file = incoming_related_field_extract_related_file($node);
    if (!$file instanceof FileInterface) {
      continue;
    }

    if (empty($row['actions']) || !is_array($row['actions'])) {
      $row['actions'] = [];
    }

    $dt_docid_name = 'incoming_related_field_dt_docid_' . $delta;
    $existing_dt_docid = $node->hasField('field_dt_docid') ? ($node->get('field_dt_docid')->value ?? '') : '';
    $protocol_text = $node->hasField('field_protocol_number_doc') ? trim((string) ($node->get('field_protocol_number_doc')->value ?? '')) : '';
    $protocol_year = incoming_related_field_extract_entry_year($node);
    $use_protocol = ($protocol_text !== '' && $protocol_year > 0);
    $protocol_override_name = 'incoming_related_field_protocol_override_' . $delta;

    $row['actions']['incoming_related_dt_docid'] = [
      '#type' => 'textfield',
      '#title' => t('Α/Α ΣΗΔΕ'),
      '#title_display' => 'invisible',
      '#placeholder' => t('Α/Α ΣΗΔΕ'),
      '#name' => $dt_docid_name,
      '#default_value' => $existing_dt_docid,
      '#size' => 10,
      '#attributes' => [
        'class' => ['incoming-related-field-dt-docid'],
      ],
      '#access' => !$use_protocol,
      '#weight' => 5,
    ];

    $row['actions']['incoming_related_protocol_override'] = [
      '#type' => 'textfield',
      '#title' => t('Α.Π. Εισερχομένου'),
      '#title_display' => 'invisible',
      '#placeholder' => t('Α.Π. Εισερχομένου'),
      '#name' => $protocol_override_name,
      '#default_value' => $protocol_text,
      '#size' => 20,
      '#attributes' => [
        'class' => ['incoming-related-field-protocol-override'],
      ],
      '#access' => \Drupal::currentUser()->hasRole('administrator'),
      '#weight' => 6,
    ];

    if (incoming_related_field_should_show_send_button($node)) {
      $row['actions']['incoming_related_send_to_side'] = [
        '#type' => 'submit',
        '#value' => t('Πρωτοκόλληση στο ΣΗΔΕ'),
        '#name' => 'incoming_related_field_send_to_side_entity_' . $delta,
        '#submit' => ['incoming_related_field_send_to_side_entity_submit'],
        '#ajax' => [
          'callback' => 'incoming_related_field_send_to_side_ajax',
          'wrapper' => 'edit-field-related-incoming-wrapper',
        ],
        '#limit_validation_errors' => [],
        '#attributes' => [
          'class' => ['incoming-related-field-send-to-side'],
        ],
        '#incoming_related_field_context' => [
          'file_id' => (int) $file->id(),
          'node_id' => (int) $node->id(),
        ],
        '#weight' => 20,
      ];
    }

    $current_node = $form['#entity'] ?? NULL;
    $is_current_node = $delta === 0;
    if ($current_node instanceof NodeInterface && (int) $current_node->id() === (int) $node->id()) {
      $is_current_node = TRUE;
    }

    $corrected_action = [
      '#type' => 'submit',
      '#value' => t('Ορθή Επανάληψη Εγγράφου'),
      '#name' => 'incoming_related_field_get_corrected_' . $delta,
      '#submit' => ['incoming_related_field_get_corrected_document_submit'],
      '#limit_validation_errors' => [],
      '#attributes' => [
        'class' => ['incoming-related-field-get-corrected'],
      ],
      '#states' => [
        'enabled' => [
          ':input[name="' . $dt_docid_name . '"]' => ['filled' => TRUE],
        ],
      ],
      '#incoming_related_field_context' => [
        'node_id' => (int) $node->id(),
        'dt_docid_name' => $dt_docid_name,
        'protocol_override_name' => $protocol_override_name,
        'is_current_node' => $is_current_node,
        'use_protocol' => $use_protocol,
        'protocol_text' => $protocol_text,
        'protocol_year' => $protocol_year,
        'document_type_id' => 1,
      ],
      '#weight' => 15,
    ];

    $corrected_action['#ajax'] = [
      'callback' => 'incoming_related_field_get_corrected_ajax',
      'wrapper' => 'edit-field-related-incoming-wrapper',
    ];

    $row['actions']['incoming_related_get_corrected'] = $corrected_action;
  }
  unset($row);
}

/**
 * Find the node entity for a related incoming row.
 */
function incoming_related_field_extract_row_node(array $row): ?NodeInterface {
  if (!empty($row['#entity']) && $row['#entity'] instanceof NodeInterface) {
    return $row['#entity'];
  }

  foreach ($row as $value) {
    if (is_array($value) && isset($value['#entity']) && $value['#entity'] instanceof NodeInterface) {
      return $value['#entity'];
    }
  }

  return NULL;
}

/**
 * Find the first related document file on the incoming node.
 */
function incoming_related_field_extract_related_file(NodeInterface $node): ?FileInterface {
  if (!$node->hasField('field_documents') || $node->get('field_documents')->isEmpty()) {
    return NULL;
  }

  $paragraphs = $node->get('field_documents')->referencedEntities();
  foreach ($paragraphs as $paragraph) {
    if (!$paragraph instanceof ParagraphInterface || !$paragraph->hasField('field_files')) {
      continue;
    }
    if ($paragraph->get('field_files')->isEmpty()) {
      continue;
    }
    $file = $paragraph->get('field_files')->entity;
    if ($file instanceof FileInterface) {
      return $file;
    }
  }

  return NULL;
}

/**
 * Determine whether the send-to-SIDE button should be shown.
 */
function incoming_related_field_should_show_send_button(NodeInterface $node): bool {
  $fields = [
    'field_protocol_number_doc',
    'field_sender',
  ];

  foreach ($fields as $field_name) {
    if ($node->hasField($field_name) && !$node->get($field_name)->isEmpty()) {
      return FALSE;
    }
  }

  return TRUE;
}

/**
 * Submit handler for "Send to SIDE" in related incoming table.
 */
function incoming_related_field_send_to_side_entity_submit(array &$form, FormStateInterface $form_state): void {
  $trigger = $form_state->getTriggeringElement();
  $context = $trigger['#incoming_related_field_context'] ?? [];
  $file_id = $context['file_id'] ?? NULL;
  $node_id = $context['node_id'] ?? NULL;

  if (!$file_id || !$node_id) {
    \Drupal::messenger()->addError(t('Missing document reference for SIDE transfer.'));
    return;
  }

  /** @var \Drupal\file\FileInterface|null $file */
  $file = \Drupal::entityTypeManager()->getStorage('file')->load($file_id);
  if (!$file instanceof FileInterface) {
    \Drupal::messenger()->addError(t('The selected file could not be loaded.'));
    return;
  }

  try {
    $result = incoming_related_field_send_file_to_side($file, [
      'title' => incoming_related_field_build_doc_title($file, ['parent_node_id' => $node_id]),
    ]);
    $stamped_file = $result['file'];
    $doc = $result['document'];
    incoming_related_field_write_debug_doc($doc, $node_id);

    /** @var \Drupal\node\NodeInterface|null $node */
    $node = \Drupal::entityTypeManager()->getStorage('node')->load($node_id);
    if ($node instanceof NodeInterface && $node->hasField('field_documents')) {
      $paragraphs = $node->get('field_documents')->referencedEntities();
      foreach ($paragraphs as $paragraph) {
        if (!$paragraph instanceof ParagraphInterface || !$paragraph->hasField('field_files')) {
          continue;
        }
        if ($paragraph->get('field_files')->isEmpty()) {
          continue;
        }
        $original_file = $paragraph->get('field_files')->entity;
        $paragraph->set('field_files', [['target_id' => $stamped_file->id()]]);
        $paragraph->save();
        if ($original_file instanceof FileInterface && (int) $original_file->id() !== (int) $stamped_file->id()) {
          $original_file->delete();
        }
        break;
      }
    }

    incoming_related_field_apply_docutracks_fields($node, $doc, TRUE);

    \Drupal::messenger()->addStatus(t('Document was transferred to SIDE and stamped.'));
    $form_state->setRebuild(TRUE);
  }
  catch (\Throwable $throwable) {
    \Drupal::logger('incoming_related_field')->error('SIDE transfer failed for file @fid: @message', [
      '@fid' => $file_id,
      '@message' => $throwable->getMessage(),
    ]);
    \Drupal::messenger()->addError(t('SIDE transfer failed: @message', ['@message' => $throwable->getMessage()]));
  }
}

/**
 * Submit handler for fetching corrected document from Docutracks.
 */
function incoming_related_field_get_corrected_document_submit(array &$form, FormStateInterface $form_state): void {
  $trigger = $form_state->getTriggeringElement();
  $context = $trigger['#incoming_related_field_context'] ?? [];
  $node_id = $context['node_id'] ?? NULL;
  $dt_docid_name = $context['dt_docid_name'] ?? NULL;

  if (!$node_id || !$dt_docid_name) {
    \Drupal::messenger()->addError(t('Missing incoming reference for Docutracks lookup.'));
    $form_state->setRebuild(TRUE);
    return;
  }

  $input = $form_state->getUserInput();
  $use_protocol = !empty($context['use_protocol']);
  $doc_id = '';
  $protocol_text = '';
  $protocol_year = 0;
  $document_type_id = 1;
  $protocol_override_name = $context['protocol_override_name'] ?? NULL;
  $protocol_override = $protocol_override_name ? trim((string) ($input[$protocol_override_name] ?? '')) : '';
  $force_update_fields = TRUE;

  if ($use_protocol) {
    $protocol_text = trim((string) ($context['protocol_text'] ?? ''));
    if ($protocol_override !== '') {
      $protocol_text = $protocol_override;
    }
    $protocol_year = (int) ($context['protocol_year'] ?? 0);
    $document_type_id = (int) ($context['document_type_id'] ?? 1);
    if ($protocol_text === '' || $protocol_year <= 0) {
      \Drupal::messenger()->addError(t('Missing protocol details for Docutracks lookup.'));
      $form_state->setRebuild(TRUE);
      return;
    }
  }
  else {
    $doc_id = trim((string) ($input[$dt_docid_name] ?? ''));
    if ($doc_id === '') {
      \Drupal::messenger()->addError(t('Please provide an Α/Α ΣΗΔΕ value.'));
      $form_state->setRebuild(TRUE);
      return;
    }
  }

  /** @var \Drupal\node\NodeInterface|null $node */
  $node = \Drupal::entityTypeManager()->getStorage('node')->load($node_id);
  if (!$node instanceof NodeInterface) {
    \Drupal::messenger()->addError(t('The selected incoming document could not be loaded.'));
    $form_state->setRebuild(TRUE);
    return;
  }

  if (!$node->hasField('field_dt_docid')) {
    \Drupal::messenger()->addError(t('Missing Docutracks id field on incoming.'));
    $form_state->setRebuild(TRUE);
    return;
  }

  try {
    /** @var \Drupal\side_api\DocutracksClient $client */
    $client = \Drupal::service('side_api.docutracks_client');
    $jar = $client->loginToDocutracks();
    if ($use_protocol) {
      $doc = $client->fetchDocumentByProtocol($protocol_text, $protocol_year, $document_type_id, $jar);
      $doc_id = (string) incoming_related_field_extract_document_id($client, $doc);
      if ($doc_id === '' || $doc_id === '0') {
        \Drupal::messenger()->addError(t('Docutracks did not return a document id.'));
        $form_state->setRebuild(TRUE);
        return;
      }
    }
    else {
      $doc = $client->fetchDocument((string) $doc_id, $jar);
    }
    incoming_related_field_store_plan_docutracks_response($node, $doc);

    $incoming_settings = Settings::get('incoming_related_field', []);
    $skip_doc_check = is_array($incoming_settings) ? !empty($incoming_settings['skip_corrected_docid']) : FALSE;
    if (
      !$skip_doc_check
      && !incoming_related_field_validate_docutracks_metadata($node, $doc, [
        'field_sender',
        'field_protocol_number_doc',
      ])
    ) {
      if (!$force_update_fields) {
        \Drupal::messenger()->addError(t('Α/Α ΣΗΔΕ δεν ειναι σωστός.'));
        $form_state->setRebuild(TRUE);
        return;
      }
      \Drupal::logger('incoming_related_field')->warning('Docutracks metadata mismatch for node @nid but forcing field updates.', [
        '@nid' => $node->id(),
      ]);
    }

    $file_id = (int) ($client->extractValueByPath($doc, 'Document.GeneratedFile.Id') ?? 0);
    if (!$file_id) {
      \Drupal::messenger()->addError(t('Docutracks did not return a generated file id.'));
      $form_state->setRebuild(TRUE);
      return;
    }

    $filename = $client->extractValueByPath($doc, 'Document.GeneratedFile.FileName');
    $filename = incoming_related_field_prepare_docutracks_filename($filename, (int) $doc_id, $file_id);

    $corrected_file = incoming_related_field_download_docutracks_file(
      $client,
      $file_id,
      (int) $doc_id,
      $jar,
      $filename
    );

    if ($node->hasField('field_documents') && !$node->get('field_documents')->isEmpty()) {
      $paragraphs = $node->get('field_documents')->referencedEntities();
      foreach ($paragraphs as $paragraph) {
        if (!$paragraph instanceof ParagraphInterface || !$paragraph->hasField('field_files')) {
          continue;
        }
        $paragraph->set('field_files', [['target_id' => $corrected_file->id()]]);
        $paragraph->save();
        break;
      }
    }

    $node->set('field_dt_docid', $doc_id);
    incoming_related_field_apply_docutracks_fields($node, $doc, $force_update_fields);

    \Drupal::messenger()->addStatus(t('Corrected document was downloaded from Docutracks.'));
    $form_state->setRebuild(TRUE);
  }
  catch (\Throwable $throwable) {
    \Drupal::logger('incoming_related_field')->error('Docutracks corrected fetch failed for node @nid: @message', [
      '@nid' => $node_id,
      '@message' => $throwable->getMessage(),
    ]);
    \Drupal::messenger()->addError(t('Docutracks fetch failed: @message', ['@message' => $throwable->getMessage()]));
    incoming_related_field_store_plan_try_increment($node);
    $form_state->setRebuild(TRUE);
  }
}

/**
 * Ajax callback for the send-to-SIDE action.
 */
function incoming_related_field_send_to_side_ajax(array &$form, FormStateInterface $form_state): array {
  if (isset($form['field_related_incoming'])) {
    return $form['field_related_incoming'];
  }

  return $form;
}

/**
 * Ajax callback for corrected-document action.
 */
function incoming_related_field_get_corrected_ajax(array &$form, FormStateInterface $form_state) {
  $trigger = $form_state->getTriggeringElement();
  $context = $trigger['#incoming_related_field_context'] ?? [];
  $is_current_node = !empty($context['is_current_node']);

  if ($is_current_node && !empty($context['node_id'])) {
    $redirect = \Drupal\Core\Url::fromRoute('entity.node.edit_form', [
      'node' => (int) $context['node_id'],
    ])->toString();
    \Drupal::logger('incoming_related_field')->info('Corrected-document AJAX redirect for node @nid to @url', [
      '@nid' => (string) $context['node_id'],
      '@url' => $redirect,
    ]);
    $response = new \Drupal\Core\Ajax\AjaxResponse();
    incoming_related_field_add_message_commands($response);
    $response->addCommand(new \Drupal\Core\Ajax\RedirectCommand($redirect));
    return $response;
  }

  if (isset($form['field_related_incoming'])) {
    $response = new \Drupal\Core\Ajax\AjaxResponse();
    incoming_related_field_add_message_commands($response);
    \Drupal::messenger()->deleteAll();
    return $response;
  }

  return $form;
}

/**
 * Add queued messages to an AJAX response.
 */
function incoming_related_field_add_message_commands(\Drupal\Core\Ajax\AjaxResponse $response): void {
  $messages = \Drupal::messenger()->all();
  if ($messages === []) {
    return;
  }

  foreach ($messages as $type => $items) {
    foreach ($items as $message) {
      $response->addCommand(new \Drupal\Core\Ajax\MessageCommand($message, NULL, [
        'type' => $type,
      ]));
    }
  }

  $response->addCommand(new \Drupal\Core\Ajax\InvokeCommand(
    '[data-drupal-messages] .messages--status',
    'addClass',
    ['govgr-panel govgr-panel--confirmation govgr-panel__title']
  ));
  $response->addCommand(new \Drupal\Core\Ajax\InvokeCommand(
    '[data-drupal-messages] .messages--warning',
    'addClass',
    ['govgr-panel govgr-panel--warning govgr-panel__title']
  ));
  $response->addCommand(new \Drupal\Core\Ajax\InvokeCommand(
    '[data-drupal-messages] .messages--error',
    'addClass',
    ['govgr-panel govgr-panel--error govgr-panel__title']
  ));
}

/**
 * Adds "Send to SIDE" buttons for document rows that contain a file.
 */
function incoming_related_field_add_send_to_side_buttons(array &$entity_form): void {
  if (empty($entity_form['field_documents']['widget']) || !is_array($entity_form['field_documents']['widget'])) {
    return;
  }

  $parent_node = $entity_form['#entity'] ?? NULL;
  $parent_node_id = $parent_node instanceof NodeInterface ? (int) $parent_node->id() : NULL;

  foreach (Element::children($entity_form['field_documents']['widget']) as $delta) {
    if (empty($entity_form['field_documents']['widget'][$delta]['subform'])) {
      continue;
    }
    $subform =& $entity_form['field_documents']['widget'][$delta]['subform'];
    $paragraph = $subform['#entity'] ?? NULL;
    if (!$paragraph instanceof ParagraphInterface || !$paragraph->hasField('field_files')) {
      continue;
    }
    if ($paragraph->get('field_files')->isEmpty()) {
      continue;
    }

    $file = $paragraph->get('field_files')->entity;
    if (!$file instanceof FileInterface) {
      continue;
    }

    $subform['docutracks_send'] = [
      '#type' => 'submit',
      '#value' => t('Πρωτοκόλληση στο ΣΗΔΕ'),
      '#name' => 'incoming_related_field_send_to_side_' . $delta,
      '#submit' => ['incoming_related_field_send_to_side_submit'],
      '#limit_validation_errors' => [],
      '#attributes' => [
        'class' => ['incoming-related-field-send-to-side'],
      ],
      '#incoming_related_field_context' => [
        'file_id' => (int) $file->id(),
        'paragraph_id' => $paragraph->isNew() ? NULL : (int) $paragraph->id(),
        'parent_node_id' => $parent_node_id,
      ],
      '#weight' => 100,
    ];
  }
}

/**
 * Submit handler for sending a document to SIDE and attaching the stamped file.
 */
function incoming_related_field_send_to_side_submit(array &$form, FormStateInterface $form_state): void {
  $trigger = $form_state->getTriggeringElement();
  $context = $trigger['#incoming_related_field_context'] ?? [];
  $file_id = $context['file_id'] ?? NULL;
  if (!$file_id) {
    \Drupal::messenger()->addError(t('Missing file reference for SIDE transfer.'));
    return;
  }

  /** @var \Drupal\file\FileInterface|null $file */
  $file = \Drupal::entityTypeManager()->getStorage('file')->load($file_id);
  if (!$file instanceof FileInterface) {
    \Drupal::messenger()->addError(t('The selected file could not be loaded.'));
    return;
  }

  try {
    $result = incoming_related_field_send_file_to_side($file, [
      'title' => incoming_related_field_build_doc_title($file, $context),
    ]);
    $stamped_file = $result['file'];
    $paragraph_id = $context['paragraph_id'] ?? NULL;
    if ($paragraph_id) {
      $paragraph = \Drupal::entityTypeManager()->getStorage('paragraph')->load($paragraph_id);
      if ($paragraph instanceof ParagraphInterface && $paragraph->hasField('field_files')) {
        $paragraph->get('field_files')->appendItem(['target_id' => $stamped_file->id()]);
        $paragraph->save();
      }
    }

    \Drupal::messenger()->addStatus(t('Document was transferred to SIDE and stamped.'));
    $form_state->setRebuild(TRUE);
  }
  catch (\Throwable $throwable) {
    \Drupal::logger('incoming_related_field')->error('SIDE transfer failed for file @fid: @message', [
      '@fid' => $file_id,
      '@message' => $throwable->getMessage(),
    ]);
    \Drupal::messenger()->addError(t('SIDE transfer failed: @message', ['@message' => $throwable->getMessage()]));
  }
}

/**
 * Send a file to Docutracks and return the stamped file.
 *
 * @return array{document_id:int, file:\Drupal\file\FileInterface, response:array}
 */
function incoming_related_field_send_file_to_side(FileInterface $file, array $options = []): array {
  $file_system = \Drupal::service('file_system');
  $real_path = $file_system->realpath($file->getFileUri());
  if ($real_path === FALSE || !is_readable($real_path)) {
    throw new RuntimeException('Unable to read the file from disk.');
  }

  $title = $options['title'] ?? pathinfo($file->getFilename(), PATHINFO_FILENAME);
  $type_id = $options['type_id'] ?? 1;
  $doc_payload = ['Document' => ['Title' => $title]];

  /** @var \Drupal\side_api\DocutracksClient $client */
  $client = \Drupal::service('side_api.docutracks_client');
  $payload = $client->prepareRegisterPayload($doc_payload, $real_path, [], $type_id);
  $jar = $client->loginToDocutracks();
  $response = $client->registerDocument($payload, $jar);

  if (empty($response['Success'])) {
    throw new RuntimeException('Docutracks returned an unsuccessful response.');
  }

  $document_id = (int) ($response['DocumentReference'] ?? 0);
  if (!$document_id) {
    throw new RuntimeException('Docutracks did not return a document reference.');
  }

  $doc = $client->fetchDocument((string) $document_id, $jar);
  $generated_file_id = (int) ($client->extractValueByPath($doc, 'Document.GeneratedFile.Id') ?? 0);
  if (!$generated_file_id) {
    throw new RuntimeException('Stamped file is not available yet.');
  }

  $stamped_file = incoming_related_field_download_docutracks_file(
    $client,
    $generated_file_id,
    $document_id,
    $jar,
    incoming_related_field_build_stamped_filename($file)
  );

  return [
    'document_id' => $document_id,
    'file' => $stamped_file,
    'document' => $doc,
    'response' => $response,
  ];
}

/**
 * Apply Docutracks metadata to the incoming node.
 */
function incoming_related_field_apply_docutracks_fields(?NodeInterface $node, array $doc, bool $force = FALSE): void {
  if (!$node instanceof NodeInterface) {
    return;
  }

  /** @var \Drupal\side_api\DocutracksClient $client */
  $client = \Drupal::service('side_api.docutracks_client');
  $settings = Settings::get('incoming_related_field', []);
  $log_mapping = is_array($settings) ? !empty($settings['log_docutracks_mapping']) : FALSE;

  $mappings = [
    'field_protocol_number_doc' => [
      'Document.DocumentCopies.0.ProtocolText',
      'Document.DocumentCopies.ProtocolText',
      'Document.DocumentCopies.Protokollo.ProtocolText',
      'Document.ProtocolNumberDoc',
      'Document.ProtocolNumber',
      'Document.ProtocolNumberDocId',
    ],
    'field_sender' => [
      'Document.DocumentCopies.0.Sender',
      'Document.DocumentCopies.Sender',
      'Document.Sender',
      'Document.Sender.Name',
      'Document.Apostoleas.Name',
      'Document.Apostoleas_Name',
    ],
    'field_protocol_number_sender' => [
      'Document.DocumentCopies.0.SenderProtocol',
      'Document.DocumentCopies.SenderProtocol',
      'Document.ProtocolNumberSender',
      'Document.ProtocolNumberSenderDoc',
      'Document.ProtocolNumberSenderId',
    ],
  ];

  foreach ($mappings as $field_name => $paths) {
    if (!$node->hasField($field_name) || (!$force && !$node->get($field_name)->isEmpty())) {
      continue;
    }
    $found_path = NULL;
    $value = incoming_related_field_extract_doc_value($client, $doc, $paths, $found_path);
    if ($value !== NULL && $value !== '') {
      if ($field_name === 'field_protocol_number_doc') {
        $value = str_replace('\\/', '/', $value);
      }
      $node->set($field_name, $value);
      if ($log_mapping) {
        \Drupal::logger('incoming_related_field')->notice('Docutracks mapping for node @nid field @field from @path => @value', [
          '@nid' => $node->id(),
          '@field' => $field_name,
          '@path' => $found_path ?? 'n/a',
          '@value' => (string) $value,
        ]);
      }
    }
    elseif ($log_mapping) {
      \Drupal::logger('incoming_related_field')->warning('Docutracks mapping empty for node @nid field @field. Paths: @paths', [
        '@nid' => $node->id(),
        '@field' => $field_name,
        '@paths' => implode(', ', $paths),
      ]);
    }
  }

  $node->setNewRevision(FALSE);
  $node->save();
}

/**
 * Extract a value from the Docutracks document using multiple paths.
 */
function incoming_related_field_extract_doc_value(\Drupal\side_api\DocutracksClient $client, array $doc, array $paths, ?string &$found_path = NULL): ?string {
  foreach ($paths as $path) {
    $value = incoming_related_field_extract_value_by_path($doc, $path);
    if (is_object($value)) {
      $value = (array) $value;
    }
    if (is_array($value)) {
      $value = incoming_related_field_extract_scalar_from_array($value);
    }
    if (is_string($value) && trim($value) !== '') {
      $found_path = $path;
      return trim($value);
    }
    if (is_scalar($value) && $value !== NULL && $value !== '') {
      $found_path = $path;
      return (string) $value;
    }
  }

  return NULL;
}

/**
 * Extract a value by dot path, supporting arrays at any level.
 */
function incoming_related_field_extract_value_by_path(array $data, string $path): mixed {
  $parts = array_values(array_filter(explode('.', $path), static fn(string $part) => $part !== ''));
  return incoming_related_field_extract_value_by_parts($data, $parts, 0);
}

/**
 * Recursive helper for incoming_related_field_extract_value_by_path().
 */
function incoming_related_field_extract_value_by_parts(mixed $current, array $parts, int $index): mixed {
  if (is_object($current)) {
    $current = (array) $current;
  }
  if ($index >= count($parts)) {
    return $current;
  }

  $part = $parts[$index];

  if (is_array($current) && array_key_exists($part, $current)) {
    return incoming_related_field_extract_value_by_parts($current[$part], $parts, $index + 1);
  }

  if (is_array($current)) {
    $results = [];
    foreach ($current as $item) {
      if (is_object($item)) {
        $item = (array) $item;
      }
      if (!is_array($item)) {
        continue;
      }
      $value = incoming_related_field_extract_value_by_parts($item, $parts, $index);
      if ($value !== NULL) {
        $results[] = $value;
      }
    }
    if ($results !== []) {
      return $results;
    }
  }

  return NULL;
}

/**
 * Find the first scalar value within a nested array.
 */
function incoming_related_field_extract_scalar_from_array(array $value): ?string {
  $queue = [$value];
  while ($queue) {
    $current = array_shift($queue);
    foreach ($current as $item) {
      if (is_scalar($item) && $item !== NULL && $item !== '') {
        return (string) $item;
      }
      if (is_array($item)) {
        $queue[] = $item;
      }
    }
  }

  return NULL;
}

/**
 * Write the Docutracks response to a temporary JSON file for inspection.
 */
function incoming_related_field_write_debug_doc(array $doc, ?int $node_id = NULL): void {
  $payload = json_encode($doc, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE);
  if ($payload === FALSE) {
    return;
  }

  $file_system = \Drupal::service('file_system');
  $target_dir = 'public://docutracks/debug';
  if (!$file_system->prepareDirectory($target_dir, FileSystemInterface::CREATE_DIRECTORY | FileSystemInterface::MODIFY_PERMISSIONS)) {
    return;
  }
  $filename = $node_id ? ('incoming_' . $node_id . '_docutracks.json') : 'incoming_docutracks.json';
  $target_uri = $target_dir . '/' . $filename;

  /** @var \Drupal\file\FileRepositoryInterface $file_repository */
  $file_repository = \Drupal::service('file.repository');
  $file = $file_repository->writeData($payload, $target_uri, FileSystemInterface::EXISTS_REPLACE);
  if (!$file instanceof FileInterface) {
    return;
  }

  \Drupal::logger('incoming_related_field')->notice('Docutracks response saved to @path', [
    '@path' => $file->getFileUri(),
  ]);
  \Drupal::messenger()->addStatus(t('Docutracks response saved to @path', ['@path' => $file->getFileUri()]));
}

/**
 * Downloads a Docutracks file and writes it to public storage.
 */
function incoming_related_field_download_docutracks_file(
  \Drupal\side_api\DocutracksClient $client,
  int $file_id,
  int $document_id,
  \GuzzleHttp\Cookie\CookieJar $jar,
  string $filename
): FileInterface {
  $file_system = \Drupal::service('file_system');
  $tmp_path = $file_system->tempnam('temporary://', 'docutracks_');
  if ($tmp_path === FALSE) {
    throw new RuntimeException('Unable to create a temporary file for Docutracks download.');
  }

  $client->downloadFile($file_id, $document_id, $tmp_path, $jar, NULL, TRUE);
  $bytes = file_get_contents($tmp_path);
  @unlink($tmp_path);
  if ($bytes === FALSE) {
    throw new RuntimeException('Unable to read the stamped file from the temporary path.');
  }

  $target_dir = 'public://docutracks';
  if (!$file_system->prepareDirectory($target_dir, FileSystemInterface::CREATE_DIRECTORY | FileSystemInterface::MODIFY_PERMISSIONS)) {
    throw new RuntimeException(sprintf('Unable to prepare directory %s for stamped file.', $target_dir));
  }

  /** @var \Drupal\file\FileRepositoryInterface $file_repository */
  $file_repository = \Drupal::service('file.repository');
  $stamped_file = $file_repository->writeData($bytes, $target_dir . '/' . $filename, FileSystemInterface::EXISTS_RENAME);
  if (!$stamped_file instanceof FileInterface) {
    throw new RuntimeException('Failed to create file entity for stamped Docutracks file.');
  }

  $stamped_file->setPermanent();
  $stamped_file->save();

  return $stamped_file;
}

/**
 * Build a safe title for the Docutracks document.
 */
function incoming_related_field_build_doc_title(FileInterface $file, array $context): string {
  $title = pathinfo($file->getFilename(), PATHINFO_FILENAME);
  if (!empty($context['parent_node_id'])) {
    $title = sprintf('incoming-%d-%s', (int) $context['parent_node_id'], $title);
  }
  return $title;
}

/**
 * Build a filename for the stamped file.
 */
function incoming_related_field_build_stamped_filename(FileInterface $file): string {
  $base = pathinfo($file->getFilename(), PATHINFO_FILENAME);
  $extension = pathinfo($file->getFilename(), PATHINFO_EXTENSION);
  $suffix = 'stamped';
  $extension = $extension !== '' ? '.' . $extension : '.pdf';
  return $base . '-' . $suffix . $extension;
}

/**
 * Build a safe filename for Docutracks-generated files.
 */
function incoming_related_field_prepare_docutracks_filename(mixed $filename, int $document_id, int $file_id): string {
  $file_system = \Drupal::service('file_system');
  $fallback = 'docutracks-correction-' . $document_id . '-' . $file_id . '.pdf';

  if (!is_string($filename)) {
    return $fallback;
  }

  $filename = trim($filename);
  if ($filename === '') {
    return $fallback;
  }

  $filename = $file_system->basename($filename);
  if ($filename === '') {
    return $fallback;
  }

  return $filename;
}

/**
 * Extract a document id from a Docutracks response.
 */
function incoming_related_field_extract_document_id(\Drupal\side_api\DocutracksClient $client, array $doc): int {
  $paths = [
    'Document.Id',
    'DocumentReference',
    'Document.DocumentId',
  ];
  foreach ($paths as $path) {
    $value = $client->extractValueByPath($doc, $path);
    if (is_numeric($value)) {
      return (int) $value;
    }
  }
  return 0;
}

/**
 * Extract protocol year from entry date.
 */
function incoming_related_field_extract_entry_year(NodeInterface $node): int {
  if (!$node->hasField('field_entry_date') || $node->get('field_entry_date')->isEmpty()) {
    return 0;
  }
  $value = (string) ($node->get('field_entry_date')->value ?? '');
  if ($value === '') {
    return 0;
  }
  try {
    $date = new \DateTime($value);
    return (int) $date->format('Y');
  }
  catch (\Throwable) {
    return 0;
  }
}

/**
 * Validate Docutracks metadata matches existing incoming values.
 */
function incoming_related_field_validate_docutracks_metadata(NodeInterface $node, array $doc, array $fields): bool {
  $mappings = [
    'field_sender' => [
      'Document.DocumentCopies.0.Sender',
      'Document.DocumentCopies.Sender',
      'Document.Sender',
      'Document.Sender.Name',
      'Document.Apostoleas.Name',
      'Document.Apostoleas_Name',
    ],
    'field_protocol_number_doc' => [
      'Document.DocumentCopies.0.ProtocolText',
      'Document.DocumentCopies.ProtocolText',
      'Document.DocumentCopies.Protokollo.ProtocolText',
      'Document.ProtocolNumberDoc',
      'Document.ProtocolNumber',
      'Document.ProtocolNumberDocId',
    ],
  ];

  /** @var \Drupal\side_api\DocutracksClient $client */
  $client = \Drupal::service('side_api.docutracks_client');

  foreach ($fields as $field_name) {
    if (empty($mappings[$field_name])) {
      continue;
    }
    if (!$node->hasField($field_name) || $node->get($field_name)->isEmpty()) {
      continue;
    }

    $expected = trim((string) $node->get($field_name)->value);
    if ($expected === '') {
      continue;
    }

    $actual = incoming_related_field_extract_doc_value($client, $doc, $mappings[$field_name]);
    $actual = $actual !== NULL ? trim((string) $actual) : '';

    if ($field_name === 'field_protocol_number_doc') {
      $expected = str_replace('\\/', '/', $expected);
      $actual = str_replace('\\/', '/', $actual);
    }

    if ($actual === '' || $actual !== $expected) {
      return FALSE;
    }
  }

  return TRUE;
}

/**
 * Store Docutracks response and increment plan tries for corrected fetch.
 */
function incoming_related_field_store_plan_docutracks_response(NodeInterface $node, array $response): void {
  $updated = FALSE;

  if ($node->hasField('field_plan_dt_api_response')) {
    $encoded = json_encode($response, JSON_UNESCAPED_UNICODE | JSON_PRETTY_PRINT);
    if ($encoded !== FALSE) {
      $existing = $node->get('field_plan_dt_api_response')->value ?? '';
      $entry = sprintf("[%s]\n%s", date('Y-m-d H:i:s'), $encoded);
      $combined = trim($existing) !== '' ? $existing . "\n\n" . $entry : $entry;
      $node->set('field_plan_dt_api_response', $combined);
      $updated = TRUE;
    }
  }

  if (incoming_related_field_increment_plan_tries($node)) {
    $updated = TRUE;
  }

  if ($updated) {
    $node->setNewRevision(FALSE);
    $node->save();
  }
}

/**
 * Increment plan tries and return TRUE if updated.
 */
function incoming_related_field_increment_plan_tries(NodeInterface $node): bool {
  if (!$node->hasField('field_plan_dt_tries')) {
    return FALSE;
  }

  $current = $node->get('field_plan_dt_tries')->value ?? 0;
  $node->set('field_plan_dt_tries', (int) $current + 1);
  return TRUE;
}

/**
 * Increment plan tries and persist if updated.
 */
function incoming_related_field_store_plan_try_increment(NodeInterface $node): void {
  if (incoming_related_field_increment_plan_tries($node)) {
    $node->setNewRevision(FALSE);
    $node->save();
  }
}

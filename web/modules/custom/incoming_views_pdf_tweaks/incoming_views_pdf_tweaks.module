<?php

/**
 * @file
 * Hooks for Incoming Views PDF Tweaks.
 */

use Drupal\Component\Utility\UrlHelper;
use Drupal\views\ViewExecutable;

/**
 * Implements hook_views_pre_build().
 *
 * Kept intentionally empty for backward-compatible hook discovery.
 */
function incoming_views_pdf_tweaks_views_pre_build(ViewExecutable $view): void {}

/**
 * Implements hook_views_pre_view().
 *
 * Kept intentionally empty for backward-compatible hook discovery.
 */
function incoming_views_pdf_tweaks_views_pre_view(ViewExecutable $view, string $display_id, array &$args): void {}

/**
 * Implements hook_views_pre_render().
 */
function incoming_views_pdf_tweaks_views_pre_render(ViewExecutable $view): void {
  if (!in_array($view->id(), ['incoming', 'incoming_amke'], TRUE)) {
    return;
  }

  // Ensure exposed input is populated for exports and headers.
  $query = \Drupal::request()->query->all();
  $query = array_filter($query, static function ($value) {
    if (is_array($value)) {
      return array_filter($value, static fn($item) => $item !== '' && $item !== NULL) !== [];
    }
    return $value !== '' && $value !== NULL;
  });
  unset($query['page'], $query['_format'], $query['op']);

  if (
    $view->id() === 'incoming'
    && $view->display_handler
    && $view->display_handler->getPluginId() === 'data_export'
  ) {
    $from_display = (string) ($query['from_display'] ?? '');

    if ($from_display === 'page_1' && empty($query['state'])) {
      $defaults = incoming_views_pdf_tweaks_default_states_for_display($view, 'page_1');
      if (!empty($defaults)) {
        $query['state'] = $defaults;
      }
    }

    if ($from_display === 'page_4' && empty($query['state'])) {
      $defaults = incoming_views_pdf_tweaks_default_states_for_display($view, 'page_4');
      if (!empty($defaults)) {
        $query['state'] = $defaults;
      }
    }

    if ($from_display === 'page_5') {
      $query['state'] = 'incoming_processing-published';
      unset($query['no_state']);
    }
  }

  if (
    $view->id() === 'incoming_amke'
    && $view->display_handler
    && $view->display_handler->getPluginId() === 'data_export'
    && !isset($query['status'])
    && isset($query['field_amke_status_value'])
  ) {
    // Backward compatibility with older AMKE exposed filter identifiers.
    $query['status'] = $query['field_amke_status_value'];
  }

  // PDF exports should not include operation links.
  if ($view->id() === 'incoming_amke' && $view->current_display === 'data_export_2') {
    unset($view->field['operations']);
  }

  $view->setExposedInput($query);
}

/**
 * Implements hook_views_post_build().
 */
function incoming_views_pdf_tweaks_views_post_build(ViewExecutable $view): void {
  if (
    $view->id() === 'incoming'
    && in_array($view->current_display, ['page_1', 'page_4', 'page_5'], TRUE)
  ) {
    incoming_views_pdf_tweaks_adjust_incoming_export_links($view);
    return;
  }

  if (
    $view->id() === 'incoming_amke'
    && in_array($view->current_display, ['page_1', 'page_2', 'page_3'], TRUE)
  ) {
    incoming_views_pdf_tweaks_adjust_incoming_amke_export_links($view);
  }
}

/**
 * Rewrites export links for the incoming view.
 */
function incoming_views_pdf_tweaks_adjust_incoming_export_links(ViewExecutable $view): void {
  if (empty($view->feedIcons)) {
    return;
  }

  foreach ($view->feedIcons as &$icon) {
    if (empty($icon['#url']) || !is_string($icon['#url'])) {
      continue;
    }

    $parsed = UrlHelper::parse($icon['#url']);
    if (empty($parsed['path']) || !is_string($parsed['path'])) {
      continue;
    }
    $existing = $parsed['query'] ?? [];

    if ($view->current_display === 'page_5') {
      $existing['from_display'] = 'page_5';
      $existing['state'] = 'incoming_processing-published';
      $existing['from_completed'] = '1';
      unset($existing['no_state']);
    }
    else {
      $existing['from_display'] = $view->current_display;
      unset($existing['no_state']);
      unset($existing['from_completed']);

      if (empty($existing['state']) || $existing['state'] === 'All') {
        $defaults = incoming_views_pdf_tweaks_default_states_for_display($view, $view->current_display);
        if (!empty($defaults)) {
          $existing['state'] = $defaults;
        }
      }
    }

    $query_string = UrlHelper::buildQuery($existing);
    $icon['#url'] = $parsed['path']
      . ($query_string !== '' ? '?' . $query_string : '')
      . (!empty($parsed['fragment']) ? '#' . $parsed['fragment'] : '');
  }
}

/**
 * Rewrites export links for the AMKE incoming view.
 */
function incoming_views_pdf_tweaks_adjust_incoming_amke_export_links(ViewExecutable $view): void {
  if (empty($view->feedIcons)) {
    return;
  }

  foreach ($view->feedIcons as &$icon) {
    if (empty($icon['#url']) || !is_string($icon['#url'])) {
      continue;
    }

    $parsed = UrlHelper::parse($icon['#url']);
    if (empty($parsed['path']) || !is_string($parsed['path'])) {
      continue;
    }
    $existing = $parsed['query'] ?? [];

    // Keep compatibility with legacy AMKE status identifier.
    if (!isset($existing['status']) && isset($existing['field_amke_status_value'])) {
      $existing['status'] = $existing['field_amke_status_value'];
      unset($existing['field_amke_status_value']);
    }

    // Preserve display-specific status defaults when not explicitly provided.
    if (!isset($existing['status'])) {
      if ($view->current_display === 'page_1') {
        $status_default = incoming_views_pdf_tweaks_filter_default_value($view, 'status');
        if ($status_default !== NULL) {
          $existing['status'] = is_array($status_default) ? array_values($status_default) : $status_default;
        }
      }
      elseif ($view->current_display === 'page_3') {
        $existing['status'] = 'published';
      }
    }

    $query_string = UrlHelper::buildQuery($existing);
    $icon['#url'] = $parsed['path']
      . ($query_string !== '' ? '?' . $query_string : '')
      . (!empty($parsed['fragment']) ? '#' . $parsed['fragment'] : '');
  }
}

/**
 * Gets the configured default value for an exposed filter identifier.
 *
 * @return mixed
 *   The configured default value, or NULL when not found.
 */
function incoming_views_pdf_tweaks_filter_default_value(ViewExecutable $view, string $identifier) {
  $display = $view->storage->getDisplay($view->current_display);
  $filters = $display['display_options']['filters'] ?? [];
  foreach ($filters as $filter) {
    if (!empty($filter['exposed']) && ($filter['expose']['identifier'] ?? '') === $identifier) {
      return $filter['value'] ?? NULL;
    }
  }

  $default_display = $view->storage->getDisplay('default');
  $default_filters = $default_display['display_options']['filters'] ?? [];
  foreach ($default_filters as $filter) {
    if (!empty($filter['exposed']) && ($filter['expose']['identifier'] ?? '') === $identifier) {
      return $filter['value'] ?? NULL;
    }
  }

  return NULL;
}

/**
 * Gets default moderation state values for a specific display.
 */
function incoming_views_pdf_tweaks_default_states_for_display(ViewExecutable $view, string $display_id): array {
  $display = $view->storage->getDisplay($display_id);
  $filters = $display['display_options']['filters'] ?? [];
  foreach ($filters as $filter) {
    if (
      ($filter['plugin_id'] ?? '') === 'moderation_state_filter'
      && !empty($filter['exposed'])
      && (($filter['expose']['identifier'] ?? '') === 'state')
      && !empty($filter['value'])
    ) {
      return array_values($filter['value']);
    }
  }

  return [];
}

/**
 * Implements hook_theme().
 */
function incoming_views_pdf_tweaks_theme(): array {
  $path = \Drupal::service('extension.list.module')
    ->getPath('incoming_views_pdf_tweaks');
  return [
    'pdf_serialization_pdf_header__incoming' => [
      'base hook' => 'pdf_serialization_pdf_header',
      'template' => 'pdf-serialization-pdf-header--incoming',
      'path' => $path . '/templates',
    ],
    'pdf_serialization_pdf__incoming' => [
      'base hook' => 'pdf_serialization_pdf',
      'template' => 'pdf-serialization-pdf--incoming',
      'path' => $path . '/templates',
    ],
  ];
}

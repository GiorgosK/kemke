<?php

use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Entity\Display\EntityViewDisplayInterface;
use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Menu\LocalTaskManagerInterface;
use Drupal\Core\Routing\RouteMatchInterface;
use Drupal\node\NodeInterface;
use Symfony\Component\Routing\RouteCollection;
use Drupal\user\Entity\User;


/**
 * Hide grouped elements for AMKE users on node forms.
 */
function amke_tweaks_form_node_form_alter(array &$form, FormStateInterface $form_state): void {
  if (amke_tweaks_is_inline_ief_node_form($form)) {
    return;
  }

  $form_object = $form_state->getFormObject();
  $entity = $form_object?->getEntity();
  if (!$form_object || !$entity instanceof NodeInterface || $entity->bundle() !== 'incoming') {
    return;
  }

  $account = \Drupal::currentUser();
  $state = $entity->hasField('moderation_state') ? $entity->get('moderation_state')->value : NULL;
  $has_primary_document_file = amke_tweaks_has_primary_document_file($entity);
  $is_draft = in_array($state, ['temp', 'draft', NULL, ''], TRUE);
  $allow_protocol_number_sender = ($entity->isNew() && $is_draft)
    || (!$entity->isNew() && $state === 'temp' && !$has_primary_document_file);
  if ($account->hasRole('amke_user')) {
    // AMKE users: keep the original field restrictions.
    $keep_fields_edit_form = [
      'field_ref_id',
      // 'field_documents',
      'field_entry_date',
      'field_protocol_number_sender',
      'field_subject',
      'field_remarks',
      'field_related_incoming',
      // 'field_attachments',
      // 'field_plan',
    ];
    $keep_fields_new_form = [
      'field_ref_id',
      'field_documents',
      'field_protocol_number_sender',
      'field_subject',
    ];
    $keep_fields = $entity->isNew() ? $keep_fields_new_form : $keep_fields_edit_form;
    if (!$allow_protocol_number_sender) {
      $keep_fields = array_values(array_diff($keep_fields, ['field_protocol_number_sender']));
    }
    if ($state === 'temp') {
      if (!$has_primary_document_file) {
        if (!in_array('field_documents', $keep_fields, TRUE)) {
          $keep_fields[] = 'field_documents';
        }
        if (!in_array('field_protocol_number_sender', $keep_fields, TRUE)) {
          $keep_fields[] = 'field_protocol_number_sender';
        }
        $keep_fields = array_values(array_diff($keep_fields, ['field_related_incoming']));
      }
      else {
        $keep_fields = array_values(array_diff($keep_fields, ['field_documents', 'field_protocol_number_sender']));
        if (!in_array('field_related_incoming', $keep_fields, TRUE)) {
          $keep_fields[] = 'field_related_incoming';
        }
      }
    }
    $keep_always = ['actions'];

    foreach ($form as $key => $element) {
      if (!is_array($element) || strpos((string) $key, '#') === 0) {
        continue;
      }
      if (strpos((string) $key, 'field_') === 0) {
        if (!in_array($key, $keep_fields, TRUE) && !in_array($key, $keep_always, TRUE)) {
          unset($form[$key]);
        }
      }
    }

    // AMKE users can edit subject while incoming is in temp state.
    if (!$entity->isNew() && isset($form['field_subject']) && $state !== 'temp') {
      amke_tweaks_render_subject_read_only($form, $entity);
    }

    amke_tweaks_limit_documents_widget($form);
    if (
      $state === 'temp' &&
      !$entity->isNew() &&
      !$has_primary_document_file
    ) {
      if (isset($form['field_documents']['widget']['add_more'])) {
        $form['field_documents']['widget']['add_more']['#access'] = TRUE;
      }
      if (isset($form['field_documents']['add_more'])) {
        $form['field_documents']['add_more']['#access'] = TRUE;
      }
    }

    if (amke_tweaks_should_hide_fullness_check($entity)) {
      $form['#after_build'][] = 'amke_tweaks_hide_fullness_check_button_after_build';
    }

    // Allow AMKE users to save new incoming nodes without transition errors.
    if ($form_object->getEntity()->isNew()) {
      $form['#validate'][] = 'amke_tweaks_incoming_new_validate';
    }
    $form['#validate'][] = 'amke_tweaks_incoming_ief_transition_validate';

    // Auto-fill legal entity from the user's profile on submit.
    $form['#submit'][] = 'amke_tweaks_autofill_legal_entity';

    if (isset($form['actions']['submit'])) {
      $form['actions']['submit']['#value'] = t('Αποστολή προς ΚΕΜΚΕ');
    }

    if (($entity->isNew() || $state === 'temp') && isset($form['actions'])) {
      amke_tweaks_relabel_temp_workflow_action($form['actions']);
    }

    if ($state === 'temp') {
      if (isset($form['group_remarks'])) {
        $form['group_remarks']['#access'] = FALSE;
      }
      if (isset($form['edit_group_remarks'])) {
        $form['edit_group_remarks']['#access'] = FALSE;
      }
      if (isset($form['field_remarks'])) {
        $form['field_remarks']['#access'] = FALSE;
      }
    }
    return;
  }

  // Non-AMKE users: show documents on add, hide related; swap on edit.
  $is_new = $entity->isNew();
  $has_primary_document_file = amke_tweaks_has_primary_document_file($entity);
  if (isset($form['field_documents'])) {
    $form['field_documents']['#access'] = $is_new || (!$is_new && !$has_primary_document_file);
    amke_tweaks_limit_documents_widget($form);
    if (!$is_new && !$has_primary_document_file) {
      if (isset($form['field_documents']['widget']['add_more'])) {
        $form['field_documents']['widget']['add_more']['#access'] = TRUE;
      }
      if (isset($form['field_documents']['add_more'])) {
        $form['field_documents']['add_more']['#access'] = TRUE;
      }
    }
  }
  if (isset($form['field_protocol_number_sender'])) {
    $form['field_protocol_number_sender']['#access'] = $allow_protocol_number_sender || $account->hasRole('administrator');
  }
  if (isset($form['field_related_incoming'])) {
    $form['field_related_incoming']['#access'] = !$is_new && $has_primary_document_file;
  }

  // Auto-fill legal entity from the user's profile on submit.
  $form['#submit'][] = 'amke_tweaks_autofill_legal_entity';
}

/**
 * Initializes new AMKE incoming nodes in the temp state.
 */
function amke_tweaks_entity_create(EntityInterface $entity): void {
  if (!$entity instanceof NodeInterface || $entity->bundle() !== 'incoming') {
    return;
  }

  $account = \Drupal::currentUser();
  if (!$account->hasRole('amke_user')) {
    return;
  }

  // Only force temp on the main incoming add form, never on nested IEF forms.
  if (!amke_tweaks_is_main_incoming_add_request() || amke_tweaks_is_ief_request()) {
    return;
  }

  if ($entity->hasField('moderation_state')) {
    $state = $entity->get('moderation_state')->value ?? '';
    if ($state === '' || $state === 'draft') {
      $entity->set('moderation_state', 'temp');
    }
  }
}

/**
 * Submit handler: keep new AMKE incoming in temp.
 */
function amke_tweaks_set_new_incoming_temp_submit(array &$form, FormStateInterface $form_state): void {
  $form_object = $form_state->getFormObject();
  if (!$form_object || !method_exists($form_object, 'getEntity')) {
    return;
  }

  $entity = $form_object->getEntity();
  if (!$entity instanceof NodeInterface || !$entity->isNew() || $entity->bundle() !== 'incoming') {
    return;
  }

  if (\Drupal::currentUser()->hasRole('amke_user') && $entity->hasField('moderation_state')) {
    $entity->set('moderation_state', 'temp');
  }
}

/**
 * Submit handler: send new AMKE incoming to KEMKE (draft).
 */
function amke_tweaks_set_new_incoming_draft_submit(array &$form, FormStateInterface $form_state): void {
  $form_object = $form_state->getFormObject();
  if (!$form_object || !method_exists($form_object, 'getEntity')) {
    return;
  }

  $entity = $form_object->getEntity();
  if (!$entity instanceof NodeInterface || !$entity->isNew() || $entity->bundle() !== 'incoming') {
    return;
  }

  if (\Drupal::currentUser()->hasRole('amke_user') && $entity->hasField('moderation_state')) {
    $entity->set('moderation_state', 'draft');
  }
}

/**
 * After-build callback to hide the "Προς ΚΕΜΚΕ" button.
 */
function amke_tweaks_hide_fullness_check_button_after_build(array $form, FormStateInterface $form_state): array {
  $form_object = $form_state->getFormObject();
  $entity = $form_object?->getEntity();
  if (!$entity instanceof NodeInterface || $entity->bundle() !== 'incoming') {
    return $form;
  }

  $account = \Drupal::currentUser();
  if (!$account->hasRole('amke_user')) {
    return $form;
  }

  $state = $entity->hasField('moderation_state') ? $entity->get('moderation_state')->value : NULL;
  if ($state !== 'pending_issues') {
    return $form;
  }

  amke_tweaks_hide_element_by_id($form, 'edit-moderation-state-fullness-check');
  return $form;
}

/**
 * Check whether the "Προς ΚΕΜΚΕ" transition should be hidden.
 */
function amke_tweaks_should_hide_fullness_check(NodeInterface $entity): bool {
  if (!$entity->hasField('field_legal_entity')) {
    return TRUE;
  }

  $items = $entity->get('field_legal_entity')->referencedEntities();
  if (count($items) !== 1) {
    return TRUE;
  }

  $term = reset($items);
  if (!$term || $term->getEntityTypeId() !== 'taxonomy_term') {
    return TRUE;
  }

  $children = \Drupal::entityTypeManager()->getStorage('taxonomy_term')->loadChildren($term->id());
  return !empty($children);
}

/**
 * Recursively hide elements by matching id.
 */
function amke_tweaks_hide_element_by_id(array &$element, string $id): void {
  if (isset($element['#id']) && $element['#id'] === $id) {
    $element['#access'] = FALSE;
  }

  foreach (\Drupal\Core\Render\Element::children($element) as $key) {
    amke_tweaks_hide_element_by_id($element[$key], $id);
  }
}

function amke_tweaks_field_group_form_process_build_alter(array &$element, FormStateInterface $form_state, &$complete_form) {
  $account = \Drupal::currentUser();
  if (!$account->hasRole('amke_user')) {
    return;
  }

  $group_changes = [
    'field_entry_date' => 'group_general',
    'field_protocol_number_sender' => 'group_files',
  ];
  foreach ($group_changes as $key => $group) {
    $element[$key]['#group'] = $group;
  }
}

/**
 * Add custom access checks on select routes.
 */
function amke_tweaks_route_alter(RouteCollection $collection): void {
  if ($route = $collection->get('entity.node.canonical')) {
    $route->setRequirement('_custom_access', 'Drupal\\amke_tweaks\\Access\\AmkeTweaksAccessCheck::nodeView');
  }
  if ($route = $collection->get('activities_mods.node_activity')) {
    $route->setRequirement('_custom_access', 'Drupal\\amke_tweaks\\Access\\AmkeTweaksAccessCheck::nodeActivity');
  }
}

/**
 * Use the AMKE view mode for incoming nodes when AMKE users view them.
 */
function amke_tweaks_entity_view_mode_alter(&$view_mode, EntityInterface $entity, ?array &$context = NULL): void {
  if (
    !$entity instanceof NodeInterface ||
    $entity->bundle() !== 'incoming'
  ) {
    return;
  }

  $context = $context ?? [];

  $account = \Drupal::currentUser();
  if (!$account->hasRole('amke_user')) {
    return;
  }

  // Canonical node pages use the "full" view mode by default.
  if ($view_mode === 'full') {
    $view_mode = 'amke_view';
  }
}

/**
 * Hide plan tab group on incoming view pages for AMKE users.
 */
function amke_tweaks_entity_view_alter(array &$build, EntityInterface $entity, EntityViewDisplayInterface $display): void {
  if (!$entity instanceof NodeInterface || $entity->bundle() !== 'incoming') {
    return;
  }

  if (\Drupal::routeMatch()->getRouteName() !== 'entity.node.canonical') {
    return;
  }

  if (!\Drupal::currentUser()->hasRole('amke_user')) {
    return;
  }

  amke_tweaks_hide_incoming_plan_group($build);
}

/**
 * Sync AMKE status with moderation state on save.
 */
function amke_tweaks_entity_presave(EntityInterface $entity): void {
  if (!$entity instanceof NodeInterface || $entity->bundle() !== 'incoming') {
    return;
  }

  $current_state = $entity->hasField('moderation_state') && !$entity->get('moderation_state')->isEmpty()
    ? (string) $entity->get('moderation_state')->value
    : '';
  $previous_state = ($entity->original instanceof NodeInterface && $entity->original->hasField('moderation_state') && !$entity->original->get('moderation_state')->isEmpty())
    ? (string) $entity->original->get('moderation_state')->value
    : '';
  $is_temp_edit_context = $current_state === 'temp' || ($previous_state === 'temp' && $current_state === 'draft');

  // For AMKE users, autofill legal entity from their profile when missing.
  $account = \Drupal::currentUser();
  if (
    $account->hasRole('amke_user') &&
    !$entity->isNew() &&
    !$is_temp_edit_context &&
    $entity->hasField('field_subject') &&
    $entity->original instanceof NodeInterface &&
    $entity->original->hasField('field_subject')
  ) {
    $entity->set('field_subject', $entity->original->get('field_subject')->getValue());
  }

  if ($account->hasRole('amke_user') && $entity->hasField('field_legal_entity') && $entity->get('field_legal_entity')->isEmpty()) {
    $user = User::load($account->id());
    if ($user && $user->hasField('field_legal_entity') && !$user->get('field_legal_entity')->isEmpty()) {
      $entity->set('field_legal_entity', $user->get('field_legal_entity')->getValue());
    }
  }

  if (!$entity->hasField('moderation_state') || !$entity->hasField('field_amke_status')) {
    return;
  }

  if (
    $account->hasRole('amke_user') &&
    $entity->isNew() &&
    amke_tweaks_is_main_incoming_add_request() &&
    !amke_tweaks_is_ief_request()
  ) {
    $state = $entity->get('moderation_state')->value ?? '';
    if ($state === '') {
      $entity->set('moderation_state', 'temp');
    }
  }

  $state = $entity->get('moderation_state')->value;
  if ($state === NULL || $state === '') {
    return;
  }

  $map = [
    'temp' => 'temp',                // Πρόχειρο -> Πρόχειρο
    'draft' => 'processing',           // Προς χρέωση -> Υπό επεξεργασία
    'fullness_check' => 'processing',  // Έλεγχος πληρότητας -> Υπό επεξεργασία
    'pending_issues' => 'issues', // Με εκκρεμότητες -> Με εκκρεμότητες
    'under_processing' => 'processing',   // Υπό επεξεργασία -> Υπό επεξεργασία
    'for_signature' => 'processing',      // Εγκεκριμένο - Προς υπογραφή -> Υπό επεξεργασία
    'published' => 'published',           // Ολοκληρωμένο -> Ολοκληρωμένο
  ];

  if (isset($map[$state])) {
    $entity->set('field_amke_status', $map[$state]);
  }
}

/**
 * Remove transition access errors for new incoming nodes by AMKE users.
 */
function amke_tweaks_incoming_new_validate(array &$form, FormStateInterface $form_state): void {
  $form_object = $form_state->getFormObject();
  $entity = $form_object?->getEntity();
  $account = \Drupal::currentUser();

  if (
    !$entity instanceof NodeInterface ||
    !$entity->isNew() ||
    $entity->bundle() !== 'incoming' ||
    !$account->hasRole('amke_user')
  ) {
    return;
  }

  $errors = $form_state->getErrors();
  if (!$errors) {
    return;
  }

  $cleaned = [];
  foreach ($errors as $name => $message) {
    $text = (string) $message;
    // Skip the transition access violation.
    if (stripos($text, 'transition') !== FALSE) {
      continue;
    }
    $cleaned[$name] = $message;
  }

  if (count($cleaned) !== count($errors)) {
    $form_state->clearErrors();
    foreach ($cleaned as $name => $message) {
      $form_state->setErrorByName($name, $message);
    }
  }
}

/**
 * Remove moderation transition-access errors during IEF nested interactions.
 */
function amke_tweaks_incoming_ief_transition_validate(array &$form, FormStateInterface $form_state): void {
  $form_object = $form_state->getFormObject();
  $entity = $form_object?->getEntity();
  $account = \Drupal::currentUser();

  if (
    !$entity instanceof NodeInterface ||
    $entity->bundle() !== 'incoming' ||
    !$account->hasRole('amke_user')
  ) {
    return;
  }

  $trigger = $form_state->getTriggeringElement();
  $trigger_name = (string) ($trigger['#name'] ?? '');
  if ($trigger_name === '') {
    $trigger_name = (string) \Drupal::request()->request->get('_triggering_element_name', '');
  }

  $has_ief_context = str_starts_with($trigger_name, 'ief-')
    || isset($form['field_related_incoming']['form'])
    || isset($form['field_documents']['widget']['add_more'])
    || isset($form['field_related_incoming']['widget']['actions']);

  if (!$has_ief_context) {
    return;
  }

  $errors = $form_state->getErrors();
  if (!$errors) {
    return;
  }

  $cleaned = [];
  foreach ($errors as $name => $message) {
    $text = mb_strtolower((string) $message);
    $is_transition_error = str_contains($text, 'transition')
      || str_contains($text, 'μετάβα')
      || str_contains($text, 'access to transition')
      || str_contains($text, 'state transition');

    if ($is_transition_error) {
      continue;
    }
    $cleaned[$name] = $message;
  }

  if (count($cleaned) !== count($errors)) {
    $form_state->clearErrors();
    foreach ($cleaned as $name => $message) {
      $form_state->setErrorByName($name, $message);
    }
  }
}

/**
 * Hide the "View" local task when editing a node.
 */
function amke_tweaks_menu_local_tasks_alter(array &$data, $route_name, $cacheable_metadata = NULL): void {
  if ($route_name === 'node.add') {
    $route_params = \Drupal::routeMatch()->getParameters();
    if ($route_params->get('node_type') === 'incoming') {
      foreach ($data['tabs'] as $group_key => $tab_group) {
        unset($data['tabs'][$group_key]['amke_tweaks.incoming_amke_add']);
      }
    }
    return;
  }

  if ($route_name !== 'entity.node.edit_form') {
    return;
  }

  $route_match = \Drupal::routeMatch();
  $node = $route_match?->getParameter('node');
  if (!$node instanceof NodeInterface) {
    return;
  }

  $account = \Drupal::currentUser();
  if (!$account->hasRole('amke_user')) {
    return;
  }

  // Ensure local tasks vary by role so removal is not cached for everyone.
  $data['#cache']['contexts'][] = 'user.roles';

  foreach ($data['tabs'] as &$tab_set) {
    if (!is_array($tab_set)) {
      continue;
    }
    foreach (array_keys($tab_set) as $key) {
      if (str_contains($key, 'entity.node.canonical')) {
        unset($tab_set[$key]);
      }
    }
  }
  unset($tab_set);
}

/**
 * Submit handler to copy legal entity from user profile onto the node.
 */
function amke_tweaks_autofill_legal_entity(array &$form, FormStateInterface $form_state): void {
  $form_object = $form_state->getFormObject();
  $node = $form_object?->getEntity();
  if (!$node instanceof NodeInterface || $node->bundle() !== 'incoming') {
    return;
  }

  if (!$node->hasField('field_legal_entity')) {
    return;
  }

  $account = \Drupal::currentUser();
  $user = User::load($account->id());
  if (!$user || !$user->hasField('field_legal_entity') || $user->get('field_legal_entity')->isEmpty()) {
    return;
  }

  $value = $user->get('field_legal_entity')->getValue();
  $node->set('field_legal_entity', $value);
}

/**
 * Limit the documents field to a single item and hide "add more".
 */
function amke_tweaks_limit_documents_widget(array &$form): void {
  if (empty($form['field_documents']) || !is_array($form['field_documents'])) {
    return;
  }

  if (isset($form['field_documents']['widget']) && is_array($form['field_documents']['widget'])) {
    $form['field_documents']['widget']['#cardinality'] = 1;
    $form['field_documents']['widget']['#max_delta'] = 0;
    if (isset($form['field_documents']['widget']['add_more'])) {
      $form['field_documents']['widget']['add_more']['#access'] = FALSE;
    }
  }

  if (isset($form['field_documents']['add_more'])) {
    $form['field_documents']['add_more']['#access'] = FALSE;
  }
}

/**
 * Hide plan tab group and fields from incoming render arrays.
 */
function amke_tweaks_hide_incoming_plan_group(array &$build): void {
  if (isset($build['group_plan'])) {
    $build['group_plan']['#access'] = FALSE;
  }

  $keys = [
    'field_plan',
    'field_plan_dt_api_response',
  ];
  foreach ($keys as $key) {
    if (isset($build[$key])) {
      $build[$key]['#access'] = FALSE;
    }
  }
}

/**
 * Replace subject widget with read-only rendered content.
 */
function amke_tweaks_render_subject_read_only(array &$form, NodeInterface $entity): void {
  if (
    !isset($form['field_subject']) ||
    !$entity->hasField('field_subject') ||
    $entity->get('field_subject')->isEmpty()
  ) {
    return;
  }

  $subject = $entity->get('field_subject')->first();
  if (!$subject) {
    return;
  }

  $weight = $form['field_subject']['#weight'] ?? 0;
  $group = $form['field_subject']['#group'] ?? NULL;
  $title = $form['field_subject']['widget'][0]['value']['#title'] ?? t('Θέμα');

  $form['field_subject'] = [
    '#type' => 'container',
    '#weight' => $weight,
  ];

  if ($group !== NULL) {
    $form['field_subject']['#group'] = $group;
  }

  $form['field_subject']['label'] = [
    '#type' => 'item',
    '#title' => $title,
  ];

  $form['field_subject']['value'] = [
    '#type' => 'processed_text',
    '#text' => (string) $subject->value,
    '#format' => (string) ($subject->format ?? 'full_html'),
  ];
}

/**
 * Detects inline entity forms to avoid altering nested IEF incoming forms.
 */
function amke_tweaks_is_inline_ief_node_form(array $form): bool {
  return !empty($form['#ief_id']) || !empty($form['#inline_entity_form']);
}

/**
 * Detects current request as an inline entity form (IEF) submission.
 */
function amke_tweaks_is_ief_request(): bool {
  $request = \Drupal::request();
  $trigger_name = (string) $request->request->get('_triggering_element_name', '');
  if ($trigger_name !== '' && str_starts_with($trigger_name, 'ief-')) {
    return TRUE;
  }

  $op = (string) $request->request->get('op', '');
  return $op !== '' && str_contains($op, 'Δημιουργία');
}

/**
 * Detects the main add-incoming request (not nested IEF subforms).
 */
function amke_tweaks_is_main_incoming_add_request(): bool {
  $route_name = \Drupal::routeMatch()->getRouteName();
  return in_array($route_name, ['node.add', 'entity.node.add_form'], TRUE);
}

/**
 * Relabels the temp workflow action button for AMKE edit forms.
 */
function amke_tweaks_relabel_temp_workflow_action(array &$actions): void {
  foreach (\Drupal\Core\Render\Element::children($actions) as $key) {
    if (!isset($actions[$key]) || !is_array($actions[$key])) {
      continue;
    }
    amke_tweaks_relabel_temp_workflow_action($actions[$key]);
  }

  $classes = $actions['#attributes']['class'] ?? [];
  if (!is_array($classes)) {
    $classes = [];
  }

  $matches = in_array('workflow-buttons-stay_temp', $classes, TRUE)
    || (($actions['#attributes']['data-drupal-selector'] ?? '') === 'edit-moderation-state-temp')
    || (($actions['#id'] ?? '') === 'edit-moderation-state-temp');

  if (!$matches) {
    return;
  }

  if (isset($actions['#value'])) {
    $actions['#value'] = t('Αποθήκευση πρόχειρο');
  }
  if (isset($actions['#title'])) {
    $actions['#title'] = t('Αποθήκευση πρόχειρο');
  }
}

/**
 * Checks whether incoming already has a primary uploaded file in documents.
 */
function amke_tweaks_has_primary_document_file(NodeInterface $entity): bool {
  if (!$entity->hasField('field_documents') || $entity->get('field_documents')->isEmpty()) {
    return FALSE;
  }

  foreach ($entity->get('field_documents')->referencedEntities() as $paragraph) {
    if (
      $paragraph instanceof \Drupal\paragraphs\ParagraphInterface &&
      $paragraph->hasField('field_files') &&
      !$paragraph->get('field_files')->isEmpty()
    ) {
      return TRUE;
    }
  }

  return FALSE;
}

<?php

use Drupal\Core\Access\AccessResult;
use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Session\AccountInterface;
use Drupal\node\NodeInterface;
use Symfony\Component\Routing\RouteCollection;


/**
 * Hide grouped elements for AMKE users on node forms.
 */
function amke_tweaks_form_node_form_alter(array &$form, FormStateInterface $form_state): void {
  $form_object = $form_state->getFormObject();
  if (!$form_object || $form_object->getEntity()->bundle() !== 'incoming') {
    return;
  }

  $account = \Drupal::currentUser();
  if (!$account->hasRole('amke_user')) {
    return;
  }

  $keep_fields = [
    'field_ref_id',
    'field_documents',
    'field_entry_date',
    'field_subject',
    'field_remarks',
    'field_attachments',
    'field_plan',
  ];
  $keep_always = ['actions'];

  foreach ($form as $key => $element) {
    if (!is_array($element)) {
      continue;
    }
    if (strpos((string) $key, '#') === 0) {
      continue;
    }
    if (strpos((string) $key, 'field_') === 0) {
      if (!in_array($key, $keep_fields, TRUE) && !in_array($key, $keep_always, TRUE)) {
        unset($form[$key]);
      }
    }
  }

  // Allow AMKE users to save new incoming nodes without transition errors.
  if ($form_object->getEntity()->isNew()) {
    $form['#validate'][] = 'amke_tweaks_incoming_new_validate';
  }
}

function amke_tweaks_field_group_form_process_build_alter(array &$element, FormStateInterface $form_state, &$complete_form) {
  $group_changes = [
    'field_entry_date' => 'group_general',
  ];
  foreach ($group_changes as $key => $group) {
    $element[$key]['#group'] = $group;
  }
}

/**
 * Add custom access checks on select routes.
 */
function amke_tweaks_route_alter(RouteCollection $collection): void {
  if ($route = $collection->get('entity.node.canonical')) {
    $route->setRequirement('_custom_access', 'Drupal\\amke_tweaks\\Access\\AmkeTweaksAccessCheck::nodeView');
  }
  if ($route = $collection->get('activities_mods.node_activity')) {
    $route->setRequirement('_custom_access', 'Drupal\\amke_tweaks\\Access\\AmkeTweaksAccessCheck::nodeActivity');
  }
}

/**
 * Global node access guard for AMKE users.
 */
function amke_tweaks_node_access(NodeInterface $node, $op, AccountInterface $account): AccessResult {
  if ($op === 'view' && $account->hasRole('amke_user')) {
    return AccessResult::forbidden()->cachePerUser();
  }

  return AccessResult::neutral();
}

/**
 * Sync AMKE status with moderation state on save.
 */
function amke_tweaks_entity_presave(EntityInterface $entity): void {
  if (!$entity instanceof NodeInterface || $entity->bundle() !== 'incoming') {
    return;
  }

  if (!$entity->hasField('moderation_state') || !$entity->hasField('field_amke_status')) {
    return;
  }

  $state = $entity->get('moderation_state')->value;
  if ($state === NULL || $state === '') {
    return;
  }

  $map = [
    'draft' => 'processing',           // Προς χρέωση -> Υπό επεξεργασία
    'fullness_check' => 'processing',  // Έλεγχος πληρότητας -> Υπό επεξεργασία
    'pending_issues' => 'issues', // Με εκκρεμότητες -> Με εκκρεμότητες
    'under_processing' => 'processing',   // Υπό επεξεργασία -> Υπό επεξεργασία
    'for_signature' => 'processing',      // Εγκεκριμένο - Προς υπογραφή -> Υπό επεξεργασία
    'published' => 'published',           // Ολοκληρωμένο -> Ολοκληρωμένο
  ];

  if (isset($map[$state])) {
    $entity->set('field_amke_status', $map[$state]);
  }
}

/**
 * Remove transition access errors for new incoming nodes by AMKE users.
 */
function amke_tweaks_incoming_new_validate(array &$form, FormStateInterface $form_state): void {
  $form_object = $form_state->getFormObject();
  $entity = $form_object?->getEntity();
  $account = \Drupal::currentUser();

  if (
    !$entity instanceof NodeInterface ||
    !$entity->isNew() ||
    $entity->bundle() !== 'incoming' ||
    !$account->hasRole('amke_user')
  ) {
    return;
  }

  $errors = $form_state->getErrors();
  if (!$errors) {
    return;
  }

  $cleaned = [];
  foreach ($errors as $name => $message) {
    $text = (string) $message;
    // Skip the transition access violation.
    if (stripos($text, 'transition') !== FALSE) {
      continue;
    }
    $cleaned[$name] = $message;
  }

  if (count($cleaned) !== count($errors)) {
    $form_state->clearErrors();
    foreach ($cleaned as $name => $message) {
      $form_state->setErrorByName($name, $message);
    }
  }
}

<?php

declare(strict_types=1);

use Drupal\Core\Datetime\DrupalDateTime;
use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Render\Element;
use Drupal\Core\Url;
use Drupal\Component\Utility\Html;

/**
 * Builds the opinion reference ID, e.g. "ΓΝ-2025-1".
 */
function opinion_ref_id_tweaks_build_reference_id(int $year, int $sequence): string {
  return sprintf('ΓΝ-%d-%d', $year, $sequence);
}

/**
 * Generates the next reference ID without incrementing the counter.
 */
function opinion_ref_id_tweaks_generate_reference_id(?int $year = NULL): string {
  $now = new DrupalDateTime('now');
  $year = $year ?? (int) $now->format('Y');
  $sequence = opinion_ref_id_tweaks_next_reference_sequence($year, FALSE);

  return opinion_ref_id_tweaks_build_reference_id($year, $sequence);
}

/**
 * Validates uniqueness and increments the next number if available.
 */
function opinion_ref_id_tweaks_check_unique_and_increment(string $value, ?int $exclude_nid = NULL): bool {
  $value = trim($value);
  if ($value === '') {
    return FALSE;
  }

  $query = \Drupal::entityQuery('node')
    ->accessCheck(FALSE)
    ->condition('type', 'incoming')
    ->condition('field_opinion_ref_id', $value);
  if ($exclude_nid) {
    $query->condition('nid', $exclude_nid, '<>');
  }

  $existing = $query->count()->execute();
  if ($existing > 0) {
    return FALSE;
  }

  $year = opinion_ref_id_tweaks_extract_year($value);
  $next = opinion_ref_id_tweaks_next_reference_sequence($year, TRUE);
  $state = \Drupal::state();
  $state->set('opinion_ref_id_tweaks.next_number', max(1, $next + 1));
  $state->set('opinion_ref_id_tweaks.next_number_year', $year);

  return TRUE;
}

/**
 * Retrieves the per-year sequence, optionally incrementing it.
 */
function opinion_ref_id_tweaks_next_reference_sequence(int $year, bool $increment): int {
  $state = \Drupal::state();
  $lock = \Drupal::lock();
  $lock_name = "opinion_ref_id_tweaks.ref_counter.$year";
  $counter_key = "opinion_ref_id_tweaks.ref_counter.$year";

  $acquired = $lock->acquire($lock_name, 5.0);
  if (!$acquired) {
    \Drupal::logger('opinion_ref_id_tweaks')->warning('Unable to acquire reference counter lock for @year, falling back to non-locked increment.', ['@year' => $year]);
  }

  opinion_ref_id_tweaks_sync_next_number_year($year);
  $state = \Drupal::state();
  $next_number = max(1, (int) $state->get('opinion_ref_id_tweaks.next_number', 1));
  $default_current = max(0, $next_number - 1);

  $stored = (int) $state->get($counter_key, $default_current);
  $current = max($stored, $default_current);
  opinion_ref_id_tweaks_sync_next_number_state($year, $current + 1);
  $next = max(1, $current + 1);

  if ($increment) {
    $state->set($counter_key, $next);
  }

  if ($acquired) {
    $lock->release($lock_name);
  }

  return $next;
}

/**
 * Extracts the year from a reference ID, defaulting to current year.
 */
function opinion_ref_id_tweaks_extract_year(string $value): int {
  if (preg_match('/^ΓΝ-(\\d{4})-\\d+$/u', $value, $matches)) {
    return (int) $matches[1];
  }

  $now = new DrupalDateTime('now');
  return (int) $now->format('Y');
}

/**
 * Resets next number when the year changes while keeping it editable later.
 */
function opinion_ref_id_tweaks_sync_next_number_year(int $year): void {
  $state = \Drupal::state();
  $stored_year = (int) $state->get('opinion_ref_id_tweaks.next_number_year', 0);

  if ($stored_year === 0) {
    $state->set('opinion_ref_id_tweaks.next_number_year', $year);
    return;
  }

  if ($stored_year !== $year) {
    $state->set('opinion_ref_id_tweaks.next_number', 1);
    $state->set('opinion_ref_id_tweaks.next_number_year', $year);
  }
}

/**
 * Keeps next_number config and state counter aligned.
 */
function opinion_ref_id_tweaks_sync_next_number_state(int $year, int $desired_next): void {
  $desired_next = max(1, $desired_next);
  $state = \Drupal::state();
  $config_next = max(1, (int) $state->get('opinion_ref_id_tweaks.next_number', 1));

  $counter_key = "opinion_ref_id_tweaks.ref_counter.$year";
  $state_current = (int) $state->get($counter_key, max(0, $config_next - 1));

  $target_next = max($desired_next, $config_next, $state_current + 1);

  if ($config_next !== $target_next) {
    $state->set('opinion_ref_id_tweaks.next_number', $target_next);
    $state->set('opinion_ref_id_tweaks.next_number_year', $year);
  }

  $target_current = $target_next - 1;
  if ($state_current !== $target_current) {
    $state->set($counter_key, $target_current);
  }
}

/**
 * Adds the "Get next" link to incoming edit/add forms.
 */
function opinion_ref_id_tweaks_form_alter(array &$form, FormStateInterface $form_state, string $form_id): void {
  if (!in_array($form_id, ['node_incoming_form', 'node_incoming_edit_form'], TRUE)) {
    return;
  }

  if (!isset($form['field_opinion_ref_id']['widget'][0]['value'])) {
    return;
  }

  $form['#attached']['library'][] = 'core/drupal.ajax';

  $field = &$form['field_opinion_ref_id']['widget'][0]['value'];
  $field['#attributes']['id'] = $field['#attributes']['id'] ?? 'opinion-ref-id-field';

  $generate_url = Url::fromRoute('opinion_ref_id_tweaks.generate_next', [], [
    'query' => [
      '_wrapper_format' => 'drupal_ajax',
      'target' => $field['#attributes']['id'],
    ],
  ])->toString();

  $field['#suffix'] = ($field['#suffix'] ?? '') . ' <a class="use-ajax opinion-ref-id-generate" data-dialog-type="ajax" data-opinion-ref-id-target="' . Html::escape($field['#attributes']['id']) . '" href="' . Html::escape($generate_url) . '">' . t('Get next') . '</a>';

  $form['field_opinion_ref_id']['widget'][0]['#attributes']['class'][] = 'container-inline';

  $form['#after_build'][] = 'opinion_ref_id_tweaks_after_build_fix_missing_parents';
  $form['#validate'][] = 'opinion_ref_id_tweaks_incoming_validate';
}

/**
 * After-build callback to avoid FormState::getError() notices.
 */
function opinion_ref_id_tweaks_after_build_fix_missing_parents(array $form, FormStateInterface $form_state): array {
  opinion_ref_id_tweaks_fill_missing_parents($form);
  return $form;
}

/**
 * Recursively fill missing #parents based on current tree path.
 */
function opinion_ref_id_tweaks_fill_missing_parents(array &$element, array $tree_path = []): void {
  if (!isset($element['#parents']) || !is_array($element['#parents'])) {
    $element['#parents'] = isset($element['#array_parents']) && is_array($element['#array_parents'])
      ? $element['#array_parents']
      : $tree_path;
  }

  foreach (Element::children($element) as $child_key) {
    if (!isset($element[$child_key]) || !is_array($element[$child_key])) {
      continue;
    }
    opinion_ref_id_tweaks_fill_missing_parents($element[$child_key], array_merge($tree_path, [(string) $child_key]));
  }
}

/**
 * Validates the opinion reference ID for incoming forms.
 */
function opinion_ref_id_tweaks_incoming_validate(array &$form, FormStateInterface $form_state): void {
  $value = (string) $form_state->getValue(['field_opinion_ref_id', 0, 'value']);
  $value = trim($value);
  if ($value === '') {
    return;
  }

  if ($form_state->get('opinion_ref_id_tweaks_incremented')) {
    return;
  }

  $entity = $form_state->getFormObject()->getEntity();
  if ($entity && $entity->hasField('field_opinion_ref_id') && !$entity->isNew()) {
    $original = (string) $entity->get('field_opinion_ref_id')->value;
    if ($original === $value) {
      return;
    }
  }

  $exclude_nid = $entity && !$entity->isNew() ? (int) $entity->id() : NULL;
  if (!opinion_ref_id_tweaks_check_unique_and_increment($value, $exclude_nid)) {
    $form_state->setErrorByName('field_opinion_ref_id][0][value', t('This opinion reference ID already exists.'));
    return;
  }

  $form_state->set('opinion_ref_id_tweaks_incremented', TRUE);
}

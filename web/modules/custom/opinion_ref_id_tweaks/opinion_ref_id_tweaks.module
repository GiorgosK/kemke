<?php

declare(strict_types=1);

use Drupal\Core\Datetime\DrupalDateTime;
use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Entity\EntityStorageException;
use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Render\Element;
use Drupal\Core\Url;
use Drupal\Component\Utility\Html;

const OPINION_REF_ID_TWEAKS_BYPASS_MIN_LENGTH = 10;

/**
 * Builds the opinion reference ID, e.g. "ΓΝ1-2026".
 */
function opinion_ref_id_tweaks_build_reference_id(int $year, int $sequence): string {
  return sprintf('ΓΝ%d-%d', $sequence, $year);
}

/**
 * Generates the next reference ID without incrementing the counter.
 */
function opinion_ref_id_tweaks_generate_reference_id(): string {
  $now = new DrupalDateTime('now');
  $year = (int) $now->format('Y');
  $sequence = opinion_ref_id_tweaks_next_reference_sequence();

  return opinion_ref_id_tweaks_build_reference_id($year, $sequence);
}

/**
 * Validates uniqueness for the submitted reference ID.
 */
function opinion_ref_id_tweaks_check_unique_and_increment(string $value, ?int $exclude_nid = NULL): bool {
  $value = trim($value);
  if ($value === '') {
    return FALSE;
  }

  $query = \Drupal::entityQuery('node')
    ->accessCheck(FALSE)
    ->condition('type', 'incoming')
    ->condition('field_opinion_ref_id', $value);
  if ($exclude_nid) {
    $query->condition('nid', $exclude_nid, '<>');
  }

  $existing = $query->count()->execute();
  return $existing === 0;
}

/**
 * Computes the next sequence by scanning existing opinion refs for current year.
 */
function opinion_ref_id_tweaks_next_reference_sequence(): int {
  $year = (int) (new DrupalDateTime('now'))->format('Y');
  $query = \Drupal::database()->select('node_field_data', 'nfd');
  $query->fields('ref', ['field_opinion_ref_id_value']);
  $query->join('node__field_opinion_ref_id', 'ref', 'ref.entity_id = nfd.nid AND ref.deleted = 0');
  $query->join('node__field_incoming_type', 'fit', 'fit.entity_id = nfd.nid AND fit.deleted = 0');
  $query->condition('nfd.type', 'incoming');
  $query->condition('fit.field_incoming_type_target_id', 3);
  $values = $query->distinct()->execute()->fetchCol();

  $max_sequence = 0;
  foreach ($values as $value) {
    $sequence = opinion_ref_id_tweaks_extract_sequence_for_current_year((string) $value);
    if ($sequence !== NULL && $sequence > $max_sequence) {
      $max_sequence = $sequence;
    }
  }

  return $max_sequence + 1;
}

/**
 * Extracts the sequence for current year from a reference ID.
 */
function opinion_ref_id_tweaks_extract_sequence_for_current_year(string $value): ?int {
  $year = (int) (new DrupalDateTime('now'))->format('Y');
  $value = trim($value);
  if ($value === '') {
    return NULL;
  }

  // New format: ΓΝ{sequence}-{year}, e.g. ΓΝ1-2026.
  if (preg_match('/^ΓΝ(\\d+)-(\\d{4})$/u', $value, $matches)) {
    if ((int) $matches[2] !== $year) {
      return NULL;
    }
    return max(1, (int) $matches[1]);
  }

  return NULL;
}

/**
 * Adds the "Get next" link to incoming edit/add forms.
 */
function opinion_ref_id_tweaks_form_alter(array &$form, FormStateInterface $form_state, string $form_id): void {
  if (!in_array($form_id, ['node_incoming_form', 'node_incoming_edit_form'], TRUE)) {
    return;
  }

  if (!isset($form['field_opinion_ref_id']['widget'][0]['value'])) {
    return;
  }

  $form['#attached']['library'][] = 'core/drupal.ajax';
  $form['#attached']['library'][] = 'core/drupal.states';
  $form['#attached']['library'][] = 'opinion_ref_id_tweaks/opinion_ref_id_tweaks';

  $field = &$form['field_opinion_ref_id']['widget'][0]['value'];
  $field['#attributes']['id'] = $field['#attributes']['id'] ?? 'opinion-ref-id-field';
  $field['#element_validate'][] = 'opinion_ref_id_tweaks_opinion_ref_id_element_validate';

  $generate_url = Url::fromRoute('opinion_ref_id_tweaks.generate_next', [], [
    'query' => [
      '_wrapper_format' => 'drupal_ajax',
      'target' => $field['#attributes']['id'],
    ],
  ])->toString();
  $opinions_url = Url::fromUri('internal:/incoming/all', [
    'query' => [
      'type' => 3,
      'order' => 'field_entry_date',
      'sort' => 'desc',
    ],
  ])->toString();

  $controls_prefix = '<div class="opinion-ref-id-controls">' .
    '<a class="use-ajax opinion-ref-id-generate" data-dialog-type="ajax" data-opinion-ref-id-target="' . Html::escape($field['#attributes']['id']) . '" href="' . Html::escape($generate_url) . '">' . t('Get next') . '</a>' .
    ' <a href="' . Html::escape($opinions_url) . '" target="_blank" rel="noopener noreferrer">Όλες οι Γνωμοδοτήσεις</a>';

  $form['field_opinion_ref_id']['widget'][0]['#attributes']['class'][] = 'container-inline';
  $bypass_default = opinion_ref_id_tweaks_default_bypass_checkbox_value($form_state);
  $form['field_opinion_ref_id']['widget'][0]['opinion_ref_id_bypass_check'] = [
    '#type' => 'checkbox',
    '#title' => t('Παράκαμψη ελέγχου'),
    '#default_value' => $bypass_default ? 1 : 0,
    '#prefix' => $controls_prefix,
    '#suffix' => '</div>',
    '#weight' => 20,
  ];

  if (isset($form['field_opinion_number_bypass']) && is_array($form['field_opinion_number_bypass'])) {
    $form['field_opinion_number_bypass']['#states'] = [
      'visible' => [
        ':input[name="field_opinion_ref_id[0][opinion_ref_id_bypass_check]"]' => ['checked' => TRUE],
      ],
      'required' => [
        ':input[name="field_opinion_ref_id[0][opinion_ref_id_bypass_check]"]' => ['checked' => TRUE],
      ],
    ];
  }

  $form['#after_build'][] = 'opinion_ref_id_tweaks_after_build_fix_missing_parents';
  $form['#validate'][] = 'opinion_ref_id_tweaks_incoming_validate';
}

/**
 * Element-level validation so duplicate check runs before generic validators.
 */
function opinion_ref_id_tweaks_opinion_ref_id_element_validate(array &$element, FormStateInterface $form_state, array &$complete_form): void {
  $value = trim((string) ($element['#value'] ?? ''));
  if ($value === '') {
    return;
  }

  $entity = $form_state->getFormObject()->getEntity();
  if (!opinion_ref_id_tweaks_should_validate_changed_value($entity, $value)) {
    return;
  }

  $exclude_nid = $entity && !$entity->isNew() ? (int) $entity->id() : NULL;
  if (!opinion_ref_id_tweaks_check_unique_and_increment($value, $exclude_nid)) {
    $form_state->setError($element, t('Ο Αριθμός Γνωμοδότησης @actual_number ειναι ήδη σε χρήση.', [
      '@actual_number' => $value,
    ]));
  }
}

/**
 * After-build callback to avoid FormState::getError() notices.
 */
function opinion_ref_id_tweaks_after_build_fix_missing_parents(array $form, FormStateInterface $form_state): array {
  opinion_ref_id_tweaks_fill_missing_parents($form);
  return $form;
}

/**
 * Recursively fill missing #parents based on current tree path.
 */
function opinion_ref_id_tweaks_fill_missing_parents(array &$element, array $tree_path = []): void {
  if (!isset($element['#parents']) || !is_array($element['#parents'])) {
    $element['#parents'] = isset($element['#array_parents']) && is_array($element['#array_parents'])
      ? $element['#array_parents']
      : $tree_path;
  }

  foreach (Element::children($element) as $child_key) {
    if (!isset($element[$child_key]) || !is_array($element[$child_key])) {
      continue;
    }
    opinion_ref_id_tweaks_fill_missing_parents($element[$child_key], array_merge($tree_path, [(string) $child_key]));
  }
}

/**
 * Validates the opinion reference ID for incoming forms.
 */
function opinion_ref_id_tweaks_incoming_validate(array &$form, FormStateInterface $form_state): void {
  if (isset($form['field_opinion_ref_id']['widget'][0]['value']) && $form_state->getError($form['field_opinion_ref_id']['widget'][0]['value'])) {
    return;
  }

  $value = (string) $form_state->getValue(['field_opinion_ref_id', 0, 'value']);
  $value = trim($value);
  if ($value === '') {
    return;
  }

  $entity = $form_state->getFormObject()->getEntity();
  if (!opinion_ref_id_tweaks_should_validate_changed_value($entity, $value)) {
    return;
  }

  $exclude_nid = $entity && !$entity->isNew() ? (int) $entity->id() : NULL;
  if (!opinion_ref_id_tweaks_is_valid_current_year_reference_format($value)) {
    $current_year = (int) (new DrupalDateTime('now'))->format('Y');
    $form_state->setErrorByName('field_opinion_ref_id][0][value', t('Ο Αριθμός Γνωμοδότησης πρέπει να είναι της μορφής ΓΝ5-@year.', [
      '@year' => $current_year,
    ]));
    return;
  }

  $bypass = opinion_ref_id_tweaks_form_state_has_bypass_flag($form_state);
  $bypass_reason = opinion_ref_id_tweaks_extract_bypass_reason_from_form_state($form_state);

  if ($bypass) {
    if (mb_strlen($bypass_reason) < OPINION_REF_ID_TWEAKS_BYPASS_MIN_LENGTH) {
      $form_state->setErrorByName('field_opinion_number_bypass][0][value', t('Η αιτιολόγηση παράκαμψης πρέπει να έχει τουλάχιστον @min χαρακτήρες.', [
        '@min' => OPINION_REF_ID_TWEAKS_BYPASS_MIN_LENGTH,
      ]));
      return;
    }
  }

  if (!$bypass && opinion_ref_id_tweaks_is_opinion_incoming($form_state, $entity)) {
    $expected_next = opinion_ref_id_tweaks_generate_reference_id();
    if ($value !== $expected_next) {
      $expected_sequence = opinion_ref_id_tweaks_extract_sequence_for_current_year($expected_next) ?? 0;
      $form_state->setErrorByName('field_opinion_ref_id][0][value', t('Ο επόμενος επιτρεπόμενος Αριθμός Γνωμοδότησης είναι το @expected_sequence (@expected_next). Εάν επιθυμείτε να χρησιμοποιήσετε τον αριθμό @actual_number πατήστε την Παράκαμψη ελέγχου και προσπαθήστε ξανά', [
        '@expected_sequence' => $expected_sequence,
        '@expected_next' => $expected_next,
        '@actual_number' => $value,
      ]));
      return;
    }
  }

  if (!opinion_ref_id_tweaks_check_unique_and_increment($value, $exclude_nid)) {
    $form_state->setErrorByName('field_opinion_ref_id][0][value', t('Ο Αριθμός Γνωμοδότησης @actual_number ειναι ήδη σε χρήση.', [
      '@actual_number' => $value,
    ]));
    return;
  }

}

/**
 * Checks if the current form entity is an opinion incoming (type = 3).
 */
function opinion_ref_id_tweaks_is_opinion_incoming(FormStateInterface $form_state, $entity): bool {
  $submitted = $form_state->getValue(['field_incoming_type', 0, 'target_id']);
  if ($submitted !== NULL && $submitted !== '') {
    return (int) $submitted === 3;
  }

  if ($entity && $entity->hasField('field_incoming_type') && !$entity->get('field_incoming_type')->isEmpty()) {
    return (int) $entity->get('field_incoming_type')->target_id === 3;
  }

  return FALSE;
}

/**
 * Implements hook_entity_presave().
 */
function opinion_ref_id_tweaks_entity_presave(EntityInterface $entity): void {
  if ($entity->getEntityTypeId() !== 'node' || $entity->bundle() !== 'incoming') {
    return;
  }

  // Skip strict opinion ref validation for programmatic/background saves
  // (reports, batch operations, etc.) where the opinion field is not being
  // submitted through the node form request.
  if (!opinion_ref_id_tweaks_request_contains_opinion_ref_submission()) {
    return;
  }

  if (!$entity->hasField('field_opinion_ref_id')) {
    return;
  }

  $value = trim((string) $entity->get('field_opinion_ref_id')->value);
  // Empty opinion ref values are always allowed on presave.
  if ($value === '') {
    return;
  }

  if (!opinion_ref_id_tweaks_should_validate_changed_value($entity, $value)) {
    return;
  }

  $bypass = opinion_ref_id_tweaks_request_has_bypass_flag();
  $bypass_reason = opinion_ref_id_tweaks_extract_bypass_reason_from_request();

  if ($bypass && mb_strlen($bypass_reason) < OPINION_REF_ID_TWEAKS_BYPASS_MIN_LENGTH) {
    throw new EntityStorageException((string) t('Η αιτιολόγηση παράκαμψης πρέπει να έχει τουλάχιστον @min χαρακτήρες.', [
      '@min' => OPINION_REF_ID_TWEAKS_BYPASS_MIN_LENGTH,
    ]));
  }

  if (!$entity->hasField('field_incoming_type') || $entity->get('field_incoming_type')->isEmpty() || (int) $entity->get('field_incoming_type')->target_id !== 3) {
    return;
  }

  $exclude_nid = !$entity->isNew() ? (int) $entity->id() : NULL;
  if (!opinion_ref_id_tweaks_check_unique_and_increment($value, $exclude_nid)) {
    throw new EntityStorageException((string) t('Ο Αριθμός Γνωμοδότησης @actual_number ειναι ήδη σε χρήση.', [
      '@actual_number' => $value,
    ]));
  }

  if (!opinion_ref_id_tweaks_is_valid_current_year_reference_format($value)) {
    $current_year = (int) (new DrupalDateTime('now'))->format('Y');
    throw new EntityStorageException((string) t('Ο Αριθμός Γνωμοδότησης πρέπει να είναι της μορφής ΓΝ5-@year.', [
      '@year' => $current_year,
    ]));
  }

  if (!$bypass) {
    $expected_next = opinion_ref_id_tweaks_generate_reference_id();
    if ($value !== $expected_next) {
      $expected_sequence = opinion_ref_id_tweaks_extract_sequence_for_current_year($expected_next) ?? 0;
      throw new EntityStorageException((string) t('Ο επόμενος επιτρεπόμενος Αριθμός Γνωμοδότησης είναι το @expected_sequence (@expected_next). Εάν επιθυμείτε να χρησιμοποιήσετε τον αριθμό @actual_number πατήστε την Παράκαμψη ελέγχου και προσπαθήστε ξανά', [
        '@expected_sequence' => $expected_sequence,
        '@expected_next' => $expected_next,
        '@actual_number' => $value,
      ]));
    }
  }
}

/**
 * Checks whether the current request submitted the bypass flag.
 */
function opinion_ref_id_tweaks_request_has_bypass_flag(): bool {
  $request = \Drupal::requestStack()->getCurrentRequest();
  if (!$request) {
    return FALSE;
  }

  $direct_value = $request->request->get('opinion_ref_id_bypass_check');
  if ($direct_value !== NULL && in_array((string) $direct_value, ['1', 'true', 'on'], TRUE)) {
    return TRUE;
  }

  $field_values = $request->request->all('field_opinion_ref_id');
  if (is_array($field_values) && isset($field_values[0]) && is_array($field_values[0])) {
    $nested_value = $field_values[0]['opinion_ref_id_bypass_check'] ?? NULL;
    if ($nested_value !== NULL && in_array((string) $nested_value, ['1', 'true', 'on'], TRUE)) {
      return TRUE;
    }
  }

  return FALSE;
}

/**
 * Checks whether the bypass checkbox is enabled in submitted form values.
 */
function opinion_ref_id_tweaks_form_state_has_bypass_flag(FormStateInterface $form_state): bool {
  $direct_value = $form_state->getValue('opinion_ref_id_bypass_check');
  if ($direct_value !== NULL && in_array((string) $direct_value, ['1', 'true', 'on'], TRUE)) {
    return TRUE;
  }

  $nested_value = $form_state->getValue(['field_opinion_ref_id', 0, 'opinion_ref_id_bypass_check']);
  return $nested_value !== NULL && in_array((string) $nested_value, ['1', 'true', 'on'], TRUE);
}

/**
 * Checks whether current request includes submitted opinion ref field values.
 */
function opinion_ref_id_tweaks_request_contains_opinion_ref_submission(): bool {
  $request = \Drupal::requestStack()->getCurrentRequest();
  if (!$request) {
    return FALSE;
  }

  return $request->request->has('field_opinion_ref_id');
}

/**
 * Checks if an opinion reference matches ΓΝ{number}-{currentYear}.
 */
function opinion_ref_id_tweaks_is_valid_current_year_reference_format(string $value): bool {
  return opinion_ref_id_tweaks_extract_sequence_for_current_year($value) !== NULL;
}

/**
 * Checks if field_opinion_ref_id changed compared to stored entity value.
 */
function opinion_ref_id_tweaks_should_validate_changed_value(?EntityInterface $entity, string $new_value): bool {
  if (!$entity || $entity->isNew()) {
    return TRUE;
  }

  if (!$entity->hasField('field_opinion_ref_id')) {
    return FALSE;
  }

  $new_value = trim($new_value);

  $original_value = NULL;
  if (isset($entity->original) && $entity->original instanceof EntityInterface && $entity->original->hasField('field_opinion_ref_id')) {
    $original_value = trim((string) $entity->original->get('field_opinion_ref_id')->value);
  }
  else {
    $stored = \Drupal::entityTypeManager()->getStorage('node')->loadUnchanged($entity->id());
    if ($stored && $stored->hasField('field_opinion_ref_id')) {
      $original_value = trim((string) $stored->get('field_opinion_ref_id')->value);
    }
  }

  if ($original_value === NULL) {
    return TRUE;
  }

  return $new_value !== $original_value;
}

/**
 * Resolve default value for the bypass checkbox on form build/rebuild.
 */
function opinion_ref_id_tweaks_default_bypass_checkbox_value(FormStateInterface $form_state): bool {
  if (opinion_ref_id_tweaks_form_state_has_bypass_flag($form_state)) {
    return TRUE;
  }

  $reason = opinion_ref_id_tweaks_extract_bypass_reason_from_form_state($form_state);
  if ($reason !== '') {
    return TRUE;
  }

  $form_object = $form_state->getFormObject();
  if ($form_object && method_exists($form_object, 'getEntity')) {
    $entity = $form_object->getEntity();
    if (
      $entity instanceof EntityInterface
      && $entity->hasField('field_opinion_number_bypass')
      && !$entity->get('field_opinion_number_bypass')->isEmpty()
    ) {
      $existing = trim((string) ($entity->get('field_opinion_number_bypass')->value ?? ''));
      if ($existing !== '') {
        return TRUE;
      }
    }
  }

  return FALSE;
}

/**
 * Return bypass reason from submitted form values.
 */
function opinion_ref_id_tweaks_extract_bypass_reason_from_form_state(FormStateInterface $form_state): string {
  $value = $form_state->getValue(['field_opinion_number_bypass', 0, 'value']);
  if (!is_string($value)) {
    return '';
  }

  return trim($value);
}

/**
 * Return bypass reason from current HTTP request payload.
 */
function opinion_ref_id_tweaks_extract_bypass_reason_from_request(): string {
  $request = \Drupal::requestStack()->getCurrentRequest();
  if (!$request) {
    return '';
  }

  $field_values = $request->request->all('field_opinion_number_bypass');
  if (!is_array($field_values) || !isset($field_values[0]) || !is_array($field_values[0])) {
    return '';
  }

  $value = $field_values[0]['value'] ?? '';
  return is_string($value) ? trim($value) : '';
}
